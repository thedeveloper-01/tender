datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

generator client {
  provider = "prisma-client-js"
}

model Tender {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  source                String   // "GEM" | "CSPGCL"
  bidNumber             String   // unique per source; for CSPGCL use tender_notice_no or a generated key
  title                 String
  department            String?
  organization          String?
  category              String[] // multiple tags allowed (from analysis engine)
  locationState         String   @default("Chhattisgarh")
  locationCity          String?  // normalized to one of the 33 CG districts, or "Unspecified"
  startDate             DateTime?
  endDate               DateTime? // closing date — primary sort key (ascending)
  quantity              String?
  bidValue              Float?
  emdAmount             Float?
  valueExtractionStatus String   @default("not_attempted") // extracted | not_found | not_attempted
  viabilityScore        Int?     // 1-10, from shared analysis engine
  risks                 String[] // from shared analysis engine
  pdfPath               String?
  bidLink               String
  status                String   // "open" | "closed" — derived from endDate
  fetchedAt             DateTime
  sourceMeta            Json?    // source-specific extra fields
  rawJson               Json?

  @@unique([source, bidNumber])
}

model FetchLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  runAt         DateTime
  source        String   // "GEM" | "CSPGCL" | "ALL"
  found         Int
  newCount      Int
  updatedCount  Int
  pdfsDownloaded Int
  extractionOk   Int
  extractionFail Int
  cleanedRecords Int
  cleanedFiles   Int
  errors         String[]
}

model ArchivedTender {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  source      String
  bidNumber   String
  title       String
  locationCity String?
  endDate     DateTime?
  bidValue    Float?
  emdAmount   Float?
  archivedAt  DateTime
}
