MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/cgtenders
FETCH_TIME=06:00
PDF_RETENTION_DAYS=2
AUTO_DELETE_CLOSED_AFTER_DAYS=2
ARCHIVE_MODE=true
USE_MOCK_GEM=true
ADMIN_TOKEN=changeme
SITE_URL=https://cgtenders.com
PORT=4000

# Comma-free single origin or "*" for development.
# Set this to your Vercel frontend URL in production, e.g.
# CORS_ORIGIN=https://cgtenders.vercel.app
CORS_ORIGIN=*

# Where downloaded tender PDFs are stored. On Railway this should be a
# mounted volume path (e.g. /data/documents) so files survive redeploys.
DOCUMENTS_DIR=documents

# Set SKIP_GEM=true on Render / Railway — GEM tenders are fetched locally
# via gem_scraper_run.js (Playwright) and uploaded directly to MongoDB.
# The server pipeline only handles CSPGCL when this is true.
SKIP_GEM=true

# Set SKIP_SCHEDULER=true if you want to completely disable the background
# cron scheduler (e.g., on Render/live server).
SKIP_SCHEDULER=true
