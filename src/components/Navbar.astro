---
const nav = [
  { label: 'Home', href: '/' },
  { label: 'GeM Tenders', href: '/tenders/gem' },
  { label: 'CSPGCL Tenders', href: '/tenders/cspgcl' },
  { label: 'By District', href: '/districts' },
  { label: 'About', href: '/about' },
];
const path = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
}
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14 md:h-16">

      <a href="/" class="flex items-center gap-2.5 flex-shrink-0 group">
        <!-- Favicon-Style Logo Mark -->
        <svg aria-hidden="true" class="w-9 h-9 flex-shrink-0" viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="8" y="8" width="112" height="112" rx="22" fill="#0b1329" stroke="#1a56db" stroke-width="5"/>
          <text x="64" y="72" font-family="'Outfit', system-ui, -apple-system, sans-serif" font-weight="700" font-size="44" fill="#ffffff" text-anchor="middle">CG</text>
          <line x1="48" y1="88" x2="80" y2="88" stroke="#1a56db" stroke-width="5" stroke-linecap="round"/>
        </svg>
        <!-- Logo Text -->
        <div class="flex flex-col justify-center">
          <span class="font-bold text-gray-900 text-base md:text-lg tracking-wide leading-none font-['Outfit']">
            CG Tenders
          </span>
          <div class="h-[1.5px] bg-blue-200 mt-1 w-full"></div>
          <span class="text-[8px] md:text-[9px] text-[#1a56db] font-bold tracking-[0.08em] uppercase mt-0.5 leading-none font-['DM_Sans']">
            PROCUREMENT - SIMPLIFIED
          </span>
        </div>
      </a>

      <nav class="hidden md:flex items-center gap-1">
        {nav.map(({ label, href }) => (
          <a href={href}
            class={`px-3 py-1.5 rounded-md text-sm font-medium transition ${
              isActive(href)
                ? 'bg-blue-50 text-[#1A56DB]'
                : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
            }`}>
            {label}
          </a>
        ))}
      </nav>

      <button id="mobile-menu-btn" aria-label="Open menu"
        class="md:hidden p-2 rounded-md text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 py-2">
      {nav.map(({ label, href }) => (
        <a href={href}
          class={`block px-3 py-2 rounded-md text-sm font-medium transition ${
            isActive(href) ? 'bg-blue-50 text-[#1A56DB]' : 'text-gray-700 hover:bg-gray-50'
          }`}>
          {label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
