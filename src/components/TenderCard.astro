---
import { formatRupee, formatDate, daysLeft, tenderDetailPath } from '../lib/cities.js';

export interface Props {
  tender: {
    source: string;
    bidNumber: string;
    title: string;
    organization?: string | null;
    department?: string | null;
    locationCity?: string | null;
    endDate?: string | null;
    startDate?: string | null;
    bidValue?: number | null;
    emdAmount?: number | null;
    category?: string[];
    status?: string;
    risks?: string[];
    fetchedAt?: string;
    valueExtractionStatus?: string | null;
    sourceMeta?: {
      isEbidding?: boolean;
      pdfExtract?: {
        fields?: Record<string, { label: string; value: string }> | null;
        text?: string | null;
      } | null;
    } | null;
  };
}

const { tender: t } = Astro.props;

const dl = daysLeft(t.endDate);
const isUrgent = dl !== null && dl >= 0 && dl <= 2;
const isClosingSoon = dl !== null && dl > 2 && dl <= 7;
const isClosed = dl !== null && dl < 0;

const badgeLabel = dl == null ? null
  : dl < 0 ? 'Closed'
  : dl === 0 ? 'Closes today'
  : `${dl}d left`;

const badgeCls = dl == null ? ''
  : dl < 0 ? 'bg-gray-100 text-gray-500'
  : dl === 0 || isUrgent ? 'bg-red-100 text-red-700 font-semibold'
  : isClosingSoon ? 'bg-amber-100 text-amber-700'
  : 'bg-green-100 text-green-700';

const sourceBadgeCls = t.source === 'GEM'
  ? 'bg-violet-100 text-violet-700'
  : 'bg-amber-100 text-amber-700';

const detailUrl = tenderDetailPath(t);
const titleDisplay = t.title?.slice(0, 120) || 'Untitled Tender';
const orgDisplay = t.organization || t.department || null;

const fields = t.sourceMeta?.pdfExtract?.fields;
const FIELDS = [
  { key: 'mseExemption', label: 'MSE Exempt' },
  { key: 'startupExemption', label: 'Startup Exempt' },
  { key: 'experienceCriteria', label: 'Exp. Criteria' },
  { key: 'bidType', label: 'Bid Type' },
];
const foundFields = fields
  ? FIELDS.map(({ key, label }) => {
      const f = fields[key];
      return f?.value ? { label, value: f.value } : null;
    }).filter(Boolean)
  : [];

const risks = t.risks || [];
---

<article class="bg-white rounded-2xl border border-gray-200 hover:border-[#1A56DB]/40 hover:shadow-md transition duration-200 group">
  <div class="p-5 flex flex-col md:flex-row md:items-stretch gap-4">
    <!-- Column 1: Main Tender Info (flex-1) -->
    <div class="flex-1 min-w-0 flex flex-col justify-between">
      <div>
        <!-- Badges strip -->
        <div class="flex flex-wrap items-center gap-2 mb-2.5">
          <span class={`inline-flex items-center px-2 py-0.5 rounded-md text-[11px] font-bold tracking-wide uppercase ${sourceBadgeCls}`}>
            {t.source}
          </span>
          
          {t.locationCity && (
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[11px] font-medium bg-gray-100 text-gray-700">
              <svg class="w-3 h-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {t.locationCity}
            </span>
          )}

          {badgeLabel && (
            <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[11px] ${badgeCls}`}>
              {badgeLabel}
            </span>
          )}

          {t.sourceMeta?.isEbidding && (
            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[11px] bg-blue-50 text-blue-600 font-medium">e-Bidding</span>
          )}

          {t.category?.slice(0, 2).map((c: string) => (
            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[11px] bg-blue-50 text-blue-700 font-medium">{c}</span>
          ))}
        </div>

        <!-- Title -->
        <h2 class="text-sm md:text-base font-bold text-gray-900 line-clamp-2 mb-1 group-hover:text-[#1A56DB] transition leading-snug">
          <a href={detailUrl}>{titleDisplay}</a>
        </h2>

        <!-- Organisation -->
        {orgDisplay && (
          <p class="text-xs text-gray-500 mb-2 line-clamp-1">{orgDisplay}</p>
        )}
      </div>

      <!-- Subtitle / Extracted pdf data or Notice Number -->
      <div class="mt-2 space-y-2">
        <!-- Monospace Notice Number / ID -->
        <div class="flex flex-wrap items-center gap-x-3 text-[11px] text-gray-400 font-mono">
          <span>Notice No: <strong class="text-gray-600 font-medium select-all">{t.bidNumber}</strong></span>
          {t.valueExtractionStatus === 'not_found' && (
            <span class="text-red-500 italic font-sans font-normal">Value not extracted from PDF</span>
          )}
        </div>

        <!-- Inline GeM Extracted PDF Details -->
        {foundFields.length > 0 && (
          <div class="text-[11px] bg-violet-50/60 border border-violet-100/50 rounded-lg px-2.5 py-1.5 flex flex-wrap gap-x-4 gap-y-1">
            <span class="font-bold text-violet-500 uppercase tracking-wider mr-1">Bid Details:</span>
            {foundFields.map((field) => field && (
              <span class="text-gray-600">
                <span class="text-gray-400">{field.label}:</span> <strong class="font-semibold text-gray-700">{field.value}</strong>
              </span>
            ))}
          </div>
        )}

        <!-- Risks -->
        {risks.length > 0 && (
          <div class="flex flex-wrap gap-1 mt-1">
            <span class="text-[10px] font-bold text-red-500 uppercase tracking-wider self-center mr-1">Risk Flags:</span>
            {risks.slice(0, 3).map((r: string) => (
              <span class="text-[10px] bg-red-50 text-red-600 border border-red-100 px-1.5 py-0.5 rounded-md font-medium">{r}</span>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Column 2: Financial Details (w-full md:w-56) -->
    <div class="w-full md:w-56 flex-shrink-0 flex md:flex-col justify-center gap-y-2 border-t md:border-t-0 md:border-l md:border-r border-gray-100 pt-3 md:pt-0 md:px-5">
      <div class="flex-1 md:flex-none">
        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Bid Value</p>
        <p class="text-base font-extrabold text-[#1A56DB]">{formatRupee(t.bidValue)}</p>
      </div>
      <div class="flex-1 md:flex-none">
        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">EMD Amount</p>
        <p class="text-xs font-bold text-gray-800">{formatRupee(t.emdAmount)}</p>
      </div>
    </div>

    <!-- Column 3: Dates & Actions (w-full md:w-44) -->
    <div class="w-full md:w-44 flex-shrink-0 flex flex-col justify-between items-stretch md:items-end border-t md:border-t-0 pt-3 md:pt-0 md:pl-4">
      <div class="text-left md:text-right mb-3 md:mb-0">
        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Closing Date</p>
        <p class="text-xs font-semibold text-gray-700">{formatDate(t.endDate)}</p>
        {dl != null && (
          <p class={`text-[10px] mt-0.5 font-medium ${
            dl < 0 ? 'text-gray-400' : dl <= 2 ? 'text-red-600 font-semibold' : dl <= 7 ? 'text-amber-600' : 'text-green-600'
          }`}>
            {dl < 0 ? 'Closed' : dl === 0 ? 'Closes today' : `${dl} days left`}
          </p>
        )}
      </div>

      <a
        href={detailUrl}
        class="w-full text-center px-4 py-2 bg-blue-50 text-[#1A56DB] hover:bg-[#1A56DB] hover:text-white rounded-xl text-xs font-bold transition duration-150 shadow-sm"
        aria-label={`View details for ${titleDisplay}`}
      >
        View details
      </a>
    </div>
  </div>
</article>
