---
import { formatRupee, formatDate, daysLeft, tenderDetailPath } from '../lib/cities.js';

export interface Props {
  tender: {
    source: string;
    bidNumber: string;
    title: string;
    organization?: string | null;
    department?: string | null;
    locationCity?: string | null;
    endDate?: string | null;
    startDate?: string | null;
    bidValue?: number | null;
    emdAmount?: number | null;
    category?: string[];
    status?: string;
    risks?: string[];
    fetchedAt?: string;
    valueExtractionStatus?: string | null;
    sourceMeta?: {
      isEbidding?: boolean;
      pdfExtract?: {
        fields?: Record<string, { label: string; value: string }> | null;
        text?: string | null;
      } | null;
    } | null;
  };
}

const { tender: t } = Astro.props;

const dl = daysLeft(t.endDate);
const isUrgent = dl !== null && dl >= 0 && dl <= 2;
const isClosingSoon = dl !== null && dl > 2 && dl <= 7;
const isClosed = dl !== null && dl < 0;

const badgeLabel = dl == null ? null
  : dl < 0 ? 'Closed'
  : dl === 0 ? 'Closes today'
  : `${dl}d left`;

const badgeCls = dl == null ? ''
  : dl < 0 ? 'bg-gray-100 text-gray-500'
  : dl === 0 || isUrgent ? 'bg-red-100 text-red-700 font-semibold'
  : isClosingSoon ? 'bg-amber-100 text-amber-700'
  : 'bg-green-100 text-green-700';

const sourceBadgeCls = t.source === 'GEM'
  ? 'bg-violet-50 text-violet-700 border-violet-100'
  : 'bg-amber-50 text-amber-700 border-amber-100';

const detailUrl = tenderDetailPath(t);
const titleDisplay = t.title?.slice(0, 120) || 'Untitled Tender';
const orgDisplay = t.organization || t.department || null;

const fields = t.sourceMeta?.pdfExtract?.fields;
const gemBooleans: string[] = [];
let gemExperience: string | null = null;
if (t.source === 'GEM' && fields) {
  if (fields.mseExemption?.value) {
    gemBooleans.push(`MSE Exempt: ${fields.mseExemption.value}`);
  }
  if (fields.startupExemption?.value) {
    gemBooleans.push(`Startup Exempt: ${fields.startupExemption.value}`);
  }
  if (fields.bidType?.value) {
    gemBooleans.push(`Bid Type: ${fields.bidType.value}`);
  }
  if (fields.bidOfferValidity?.value) {
    gemBooleans.push(`Validity: ${fields.bidOfferValidity.value} Days`);
  }
  if (fields.experienceCriteria?.value) {
    gemExperience = fields.experienceCriteria.value;
  }
}

const hasValue = t.bidValue != null && t.bidValue > 0;
const valueDisplay = hasValue ? formatRupee(t.bidValue) : 'Not Available';
const valueClass = hasValue ? 'text-base font-extrabold text-emerald-600' : 'text-sm font-semibold text-gray-400 italic';

const hasEmd = t.emdAmount != null && t.emdAmount > 0;
const emdDisplay = hasEmd ? formatRupee(t.emdAmount) : 'N/A / Exempt';

const risks = t.risks || [];
---

<article class="bg-white rounded-2xl border border-gray-200 hover:border-blue-500/40 hover:shadow-lg transition duration-200 group relative overflow-hidden">
  <!-- Left indicator bar on hover -->
  <div class="absolute left-0 top-0 bottom-0 w-1 bg-transparent group-hover:bg-[#1A56DB] transition-all rounded-l-2xl"></div>
  
  <div class="p-5 flex flex-col lg:grid lg:grid-cols-[1fr_220px_160px] lg:divide-x lg:divide-gray-100 lg:items-center gap-5">
    <!-- Column 1: Main Tender Info -->
    <div class="min-w-0 flex flex-col justify-between pr-2">
      <div>
        <!-- Badges strip -->
        <div class="flex flex-wrap items-center gap-2 mb-2.5">
          <span class={`inline-flex items-center px-2 py-0.5 rounded text-[10px] font-extrabold tracking-wide uppercase border ${sourceBadgeCls}`}>
            {t.source}
          </span>

          {t.source === 'CSPGCL' && t.sourceMeta?.plantLabel && (
            <a href={t.bidLink} target="_blank" rel="noopener noreferrer" 
              class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-extrabold bg-blue-50 hover:bg-blue-100 text-blue-700 border border-blue-100 transition"
              aria-label={"View portal for " + t.sourceMeta.plantLabel}
            >
              {t.sourceMeta.plantLabel}
              <svg class="w-2.5 h-2.5 ml-1 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          )}

          
          {t.locationCity && (
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-bold bg-gray-50 text-gray-600 border border-gray-100">
              <svg class="w-3 h-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {t.locationCity}
            </span>
          )}

          {badgeLabel && (
            <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold ${badgeCls}`}>
              {badgeLabel}
            </span>
          )}

          {t.sourceMeta?.isEbidding && (
            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] bg-blue-50 text-blue-600 font-bold border border-blue-100">e-Bidding</span>
          )}

          {t.category?.slice(0, 2).map((c: string) => (
            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] bg-blue-50/60 text-blue-700 font-bold border border-blue-100/50">{c}</span>
          ))}
        </div>

        <!-- Title -->
        <h2 class="text-sm md:text-base font-bold text-gray-900 leading-snug mb-1 group-hover:text-[#1A56DB] transition-colors duration-150">
          <a href={detailUrl}>{titleDisplay}</a>
        </h2>

        <!-- Organisation -->
        {orgDisplay && (
          <p class="text-xs text-gray-500 font-medium line-clamp-1 mb-2.5">{orgDisplay}</p>
        )}
      </div>

      <!-- Subtitle / Extracted pdf data or Notice Number -->
      <div class="space-y-2 mt-1">
        <!-- Monospace Notice Number / ID -->
        <div class="flex flex-wrap items-center gap-x-3 text-[11px] text-gray-400 font-mono">
          <span>Notice No: <strong class="text-gray-600 font-semibold bg-gray-50 border border-gray-100 px-2 py-0.5 rounded select-all">{t.bidNumber}</strong></span>
          {t.valueExtractionStatus === 'not_found' && (
            <span class="text-red-500 font-sans font-normal italic">Value not extracted from PDF</span>
          )}
        </div>

        <!-- Inline GeM Extracted PDF Details -->
        {(gemBooleans.length > 0 || gemExperience) && (
          <div class="text-[11px] bg-violet-50/40 border border-violet-100/40 rounded-xl p-3">
            {gemBooleans.length > 0 && (
              <div class="flex flex-wrap items-center gap-x-2.5 gap-y-1 text-gray-600 font-medium">
                <span class="font-extrabold text-violet-700 uppercase tracking-wider text-[10px]">Bid Details:</span>
                {gemBooleans.map((b, idx) => (
                  <span class="flex items-center gap-2">
                    {idx > 0 && <span class="text-violet-200">•</span>}
                    <span>{b}</span>
                  </span>
                ))}
              </div>
            )}
            {gemExperience && (
              <div class="text-gray-500 mt-1.5 pt-1.5 border-t border-violet-100/30 flex items-start gap-1.5" title={gemExperience}>
                <span class="font-extrabold text-violet-700 uppercase tracking-wider text-[10px] flex-shrink-0 mt-0.5">Experience:</span>
                <p class="line-clamp-1 leading-snug font-medium text-gray-600 flex-1">{gemExperience}</p>
              </div>
            )}
          </div>
        )}

        <!-- Risks -->
        {risks.length > 0 && (
          <div class="flex flex-wrap items-center gap-1 mt-1">
            <span class="text-[10px] font-extrabold text-red-500 uppercase tracking-wider mr-1">Risk Flags:</span>
            {risks.slice(0, 3).map((r: string) => (
              <span class="text-[10px] bg-red-50 text-red-600 border border-red-100 px-2 py-0.5 rounded-md font-semibold">{r}</span>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Column 2: Financial Details -->
    <div class="lg:px-6 flex flex-row lg:flex-col justify-between lg:justify-center gap-y-3 gap-x-4 border-t lg:border-t-0 pt-3 lg:pt-0">
      <div class="flex-1 lg:flex-none">
        <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider mb-0.5">Bid Value</p>
        <p class={valueClass}>{valueDisplay}</p>
      </div>
      <div class="flex-1 lg:flex-none">
        <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider mb-0.5">EMD Amount</p>
        <p class="text-sm font-bold text-slate-800">{emdDisplay}</p>
      </div>
    </div>

    <!-- Column 3: Dates & Actions -->
    <div class="lg:pl-6 flex flex-col justify-center items-stretch lg:items-end gap-y-3 border-t lg:border-t-0 pt-3 lg:pt-0">
      <div class="text-left lg:text-right">
        <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider mb-0.5">Closing Date</p>
        <p class="text-sm font-bold text-slate-800">{formatDate(t.endDate)}</p>
        {dl != null && (
          <p class={`text-[10px] mt-0.5 font-semibold ${
            dl < 0 ? 'text-gray-400' : dl <= 2 ? 'text-red-600' : dl <= 7 ? 'text-amber-600' : 'text-green-600'
          }`}>
            {dl < 0 ? 'Closed' : dl === 0 ? 'Closes today' : `${dl} days left`}
          </p>
        )}
      </div>

      <a
        href={detailUrl}
        data-astro-prefetch
        class="w-full text-center px-4 py-2 bg-[#1A56DB] text-white hover:bg-blue-700 active:bg-blue-800 rounded-xl text-xs font-bold transition duration-150 shadow-sm hover:shadow-md hover:shadow-blue-500/10"
        aria-label={`View details for ${titleDisplay}`}
      >
        View details
      </a>
    </div>
  </div>
</article>
