---
---
<footer class="bg-white border-t border-gray-200 mt-12 md:mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">

      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-3 group">
          <!-- Stylized "G" Logo Mark -->
          <svg class="w-8 h-8 flex-shrink-0" viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M 78,38 A 32,32 0 1 0 78,90" stroke="#1A56DB" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M 54,64 H 78 V 78" stroke="#1A56DB" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <!-- Logo Text -->
          <div class="flex flex-col justify-center">
            <span class="font-bold text-gray-900 text-sm tracking-wide uppercase leading-none font-['Outfit']">
              CG Tenders<span class="text-gray-400 font-normal lowercase">.com</span>
            </span>
            <div class="h-[1px] bg-blue-200 mt-1 w-full"></div>
            <span class="text-[7.5px] text-gray-500 font-bold tracking-[0.08em] uppercase mt-0.5 leading-none font-['DM_Sans']">
              Procurement · Simplified
            </span>
          </div>
        </a>
        <p class="text-xs text-gray-500 leading-relaxed max-w-[200px]">
          Chhattisgarh government tender aggregator — GeM &amp; CSPGCL in one dashboard.
        </p>
        <p class="text-xs text-gray-400 mt-3">Updated daily at 06:00 IST</p>
      </div>

      <!-- Explore -->
      <div>
        <h4 class="text-xs font-semibold text-gray-900 uppercase tracking-wider mb-4">Explore</h4>
        <ul class="space-y-2">
          <li><a href="/tenders" class="text-sm text-gray-500 hover:text-[#1A56DB] transition">All Tenders</a></li>
          <li><a href="/districts" class="text-sm text-gray-500 hover:text-[#1A56DB] transition">By District</a></li>
          <li><a href="/tenders?source=GEM" class="text-sm text-gray-500 hover:text-[#1A56DB] transition">GeM Tenders</a></li>
          <li><a href="/tenders?source=CSPGCL" class="text-sm text-gray-500 hover:text-[#1A56DB] transition">CSPGCL Tenders</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs font-semibold text-gray-900 uppercase tracking-wider mb-4">Company</h4>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-gray-500 hover:text-[#1A56DB] transition">About</a></li>
          <li><a href="/contact" class="text-sm text-gray-500 hover:text-[#1A56DB] transition">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-xs font-semibold text-gray-900 uppercase tracking-wider mb-4">Legal</h4>
        <ul class="space-y-2">
          <li><a href="/privacy" class="text-sm text-gray-500 hover:text-[#1A56DB] transition">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-gray-500 hover:text-[#1A56DB] transition">Terms &amp; Conditions</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="text-xs text-gray-400">
        © {new Date().getFullYear()} CGTenders.com. Data sourced from official government portals.
        Not affiliated with any government body.
      </p>
      <div class="flex gap-4">
        <a href="/privacy" class="text-xs text-gray-400 hover:text-gray-600 transition">Privacy</a>
        <a href="/terms" class="text-xs text-gray-400 hover:text-gray-600 transition">Terms</a>
        <a href="/contact" class="text-xs text-gray-400 hover:text-gray-600 transition">Contact</a>
      </div>
    </div>
  </div>
</footer>

<style is:global>
  footer a { text-decoration: none; }
  footer a:focus { outline: 2px solid #1A56DB; outline-offset: 2px; border-radius: 2px; }
</style>
