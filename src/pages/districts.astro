---
import TenderLayout from '../layouts/TenderLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { fetchCities } from '../lib/api.js';

let cities = [];
try {
  const data = await fetchCities();
  cities = data.cities || [];
} catch (e) {
  console.error('[districts] API error:', e.message);
}

const withTenders = cities.filter(c => c.openCount > 0).sort((a,b) => b.openCount - a.openCount);
const withoutTenders = cities.filter(c => c.openCount === 0);
---

<TenderLayout
  title="Chhattisgarh Tender Districts — All 33 Districts | CGTenders.com"
  description="Browse government tenders by district in Chhattisgarh. All 33 districts including Raipur, Bilaspur, Durg, Korba and more."
  canonical="/districts"
>
  <Navbar />
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-1 font-['Outfit']">Browse by District</h1>
    <p class="text-sm text-gray-500 mb-8">All 33 Chhattisgarh districts — click to see open tenders</p>

    {withTenders.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-4">Districts with Open Tenders</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
          {withTenders.map(c => (
            <a href={`/tenders/${c.slug}`}
              class="flex flex-col items-center justify-center gap-1 bg-white border border-gray-200 rounded-xl p-4 hover:border-[#1A56DB] hover:shadow-sm transition text-center group">
              <span class="text-2xl font-extrabold text-[#1A56DB] font-['Outfit'] group-hover:scale-110 transition-transform">{c.openCount}</span>
              <span class="text-xs font-medium text-gray-700 leading-tight">{c.name}</span>
              <span class="text-xs text-gray-400">open tender{c.openCount !== 1 ? 's' : ''}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section>
      <h2 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-4">All Other Districts</h2>
      <div class="flex flex-wrap gap-2">
        {withoutTenders.map(c => (
          <a href={`/tenders/${c.slug}`}
            class="inline-flex items-center px-3 py-1.5 bg-white border border-gray-200 rounded-full text-sm text-gray-500 hover:border-[#1A56DB] hover:text-[#1A56DB] transition">
            {c.name}
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</TenderLayout>
