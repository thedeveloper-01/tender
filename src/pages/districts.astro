---
import TenderLayout from '../layouts/TenderLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { fetchCitiesCached } from '../lib/api.js';

let cities: any[] = [];
try {
  const data = await fetchCitiesCached(Astro.locals);
  cities = data.cities || [];
} catch (e: any) {
  console.error('[districts] API error:', e.message);
}

const DISTRICT_COORDS: Record<string, { x: number; y: number }> = {
  'Balrampur': { x: 260, y: 40 },
  'Surajpur': { x: 190, y: 70 },
  'Koriya': { x: 120, y: 70 },
  'Manendragarh-Chirmiri-Bharatpur': { x: 70, y: 90 },
  'Surguja': { x: 260, y: 100 },
  'Jashpur': { x: 370, y: 100 },
  'Korba': { x: 280, y: 180 },
  'Bilaspur': { x: 200, y: 200 },
  'Gaurela-Pendra-Marwahi': { x: 140, y: 170 },
  'Mungeli': { x: 130, y: 220 },
  'Raigarh': { x: 370, y: 210 },
  'Janjgir-Champa': { x: 280, y: 240 },
  'Sakti': { x: 330, y: 240 },
  'Sarangarh-Bilaigarh': { x: 350, y: 280 },
  'Kabirdham': { x: 80, y: 260 },
  'Bemetara': { x: 150, y: 290 },
  'Baloda Bazar': { x: 250, y: 290 },
  'Khairagarh-Chhuikhadan-Gandai': { x: 90, y: 310 },
  'Durg': { x: 140, y: 340 },
  'Raipur': { x: 210, y: 340 },
  'Mahasamund': { x: 300, y: 340 },
  'Rajnandgaon': { x: 70, y: 360 },
  'Mohla-Manpur-Ambagarh Chowki': { x: 70, y: 420 },
  'Balod': { x: 140, y: 400 },
  'Dhamtari': { x: 210, y: 400 },
  'Gariaband': { x: 260, y: 430 },
  'Kanker': { x: 140, y: 480 },
  'Kondagaon': { x: 220, y: 540 },
  'Narayanpur': { x: 120, y: 550 },
  'Bastar': { x: 240, y: 600 },
  'Bijapur': { x: 100, y: 620 },
  'Dantewada': { x: 170, y: 640 },
  'Sukma': { x: 240, y: 670 },
};

const CONNECTIONS = [
  ['Raipur', 'Durg'], ['Raipur', 'Bilaspur'], ['Raipur', 'Mahasamund'], ['Raipur', 'Baloda Bazar'], ['Raipur', 'Dhamtari'],
  ['Durg', 'Bemetara'], ['Durg', 'Balod'], ['Durg', 'Rajnandgaon'], ['Bilaspur', 'Mungeli'], ['Bilaspur', 'Korba'],
  ['Bilaspur', 'Janjgir-Champa'], ['Janjgir-Champa', 'Sakti'], ['Janjgir-Champa', 'Korba'], ['Korba', 'Surguja'],
  ['Surguja', 'Surajpur'], ['Surguja', 'Balrampur'], ['Surguja', 'Jashpur'], ['Surajpur', 'Koriya'],
  ['Dhamtari', 'Gariaband'], ['Dhamtari', 'Kanker'], ['Kanker', 'Kondagaon'], ['Kondagaon', 'Bastar'],
  ['Bastar', 'Dantewada'], ['Bastar', 'Sukma'], ['Dantewada', 'Bijapur'], ['Kondagaon', 'Narayanpur']
];

function getCoords(name: string) {
  const clean = name.trim().toLowerCase();
  for (const [key, val] of Object.entries(DISTRICT_COORDS)) {
    const lowerKey = key.toLowerCase();
    if (lowerKey === clean || clean.includes(lowerKey) || lowerKey.includes(clean)) {
      return val;
    }
  }
  return null;
}

const withTenders = cities.filter(c => c.openCount > 0).sort((a,b) => b.openCount - a.openCount);
const withoutTenders = cities.filter(c => c.openCount === 0).sort((a,b) => a.name.localeCompare(b.name));
---

<TenderLayout
  title="Chhattisgarh Tender Districts — All 33 Districts | CGTenders.com"
  description="Browse government tenders by district in Chhattisgarh. Interactive vector density heatmap for Raipur, Bilaspur, Durg, Korba and all 33 districts."
  canonical="/districts"
>
  <Navbar />
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 transition-colors duration-200">
    <div class="mb-8">
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-1 font-['Outfit']">Browse by District</h1>
      <p class="text-sm text-gray-500 dark:text-slate-400">All 33 Chhattisgarh districts — click to see open tenders</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[420px_1fr] gap-8 items-start">
      {/* Left Column: Stylized SVG Heatmap */}
      <section class="bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm flex flex-col items-center select-none">
        <div class="w-full border-b border-gray-100 dark:border-slate-850 pb-3 mb-4 flex items-center justify-between">
          <h2 class="text-xs font-extrabold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Tender density map</h2>
          <span class="text-[10px] bg-blue-50 dark:bg-blue-950/40 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-900/30 px-2 py-0.5 rounded font-bold">Interactive</span>
        </div>

        <svg viewBox="0 0 450 720" class="w-full max-w-[360px] h-auto">
          {/* Network Connection Grid lines */}
          {CONNECTIONS.map(([from, to]) => {
            const c1 = DISTRICT_COORDS[from];
            const c2 = DISTRICT_COORDS[to];
            if (c1 && c2) {
              return (
                <line x1={c1.x} y1={c1.y} x2={c2.x} y2={c2.y}
                  class="stroke-gray-100 dark:stroke-slate-800/80" stroke-width="1.5" stroke-dasharray="2 3" />
              );
            }
            return null;
          })}

          {/* District Nodes */}
          {cities.map(c => {
            const coords = getCoords(c.name);
            if (!coords) return null;
            const count = c.openCount;
            const isHigh = count >= 15;
            const isMed = count >= 5 && count < 15;
            const isLow = count > 0 && count < 5;
            
            const nodeColor = count === 0 ? 'fill-gray-200 dark:fill-slate-800 stroke-gray-300 dark:stroke-slate-700'
              : isHigh ? 'fill-blue-600 dark:fill-blue-500 stroke-blue-200 dark:stroke-blue-900/40'
              : isMed ? 'fill-blue-400 dark:fill-blue-400 stroke-blue-100 dark:stroke-blue-900/40'
              : 'fill-sky-300 dark:fill-sky-400 stroke-sky-100 dark:stroke-slate-900';
              
            const r = count === 0 ? 4 : isHigh ? 11 : isMed ? 8.5 : 6.5;
            
            return (
              <g class="group cursor-pointer">
                <a href={`/tenders/${c.slug}`}>
                  {/* Hover ring */}
                  <circle cx={coords.x} cy={coords.y} r={r + 5}
                    class="fill-transparent group-hover:fill-blue-500/10 dark:group-hover:fill-blue-400/10 transition duration-150" />
                  
                  {/* Core marker */}
                  <circle cx={coords.x} cy={coords.y} r={r}
                    class={`${nodeColor} transition duration-150`} stroke-width="1.5" />
                  
                  {/* Name Label */}
                  {count > 0 && (
                    <text x={coords.x} y={coords.y - r - 4}
                      class="fill-gray-500 dark:fill-slate-400 font-bold font-sans text-[8px] select-none group-hover:fill-[#1A56DB] dark:group-hover:fill-blue-400 transition"
                      text-anchor="middle">
                      {c.name}
                    </text>
                  )}
                  <title>{c.name}: {count} open tenders</title>
                </a>
              </g>
            );
          })}
        </svg>

        {/* Legend */}
        <div class="mt-6 flex flex-wrap items-center justify-center gap-4 text-[10px] text-gray-500 dark:text-slate-400 font-semibold border-t border-gray-100 dark:border-slate-850 pt-4 w-full">
          <div class="flex items-center gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-blue-600 dark:bg-blue-500"></span>
            <span>High (&ge;15)</span>
          </div>
          <div class="flex items-center gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-blue-400"></span>
            <span>Medium (5-14)</span>
          </div>
          <div class="flex items-center gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-sky-300 dark:bg-sky-400"></span>
            <span>Low (1-4)</span>
          </div>
          <div class="flex items-center gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-gray-200 dark:bg-slate-800"></span>
            <span>Zero</span>
          </div>
        </div>
      </section>

      {/* Right Column: Grid Lists */}
      <div class="space-y-10">
        {withTenders.length > 0 && (
          <section>
            <h2 class="text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-4">Districts with Open Tenders</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {withTenders.map(c => (
                <a href={`/tenders/${c.slug}`}
                  class="flex flex-col items-center justify-center gap-1 bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-xl p-4 hover:border-blue-500/40 hover:shadow-md transition text-center group">
                  <span class="text-2xl font-extrabold text-[#1A56DB] dark:text-blue-400 font-['Outfit'] group-hover:scale-110 transition-transform">{c.openCount}</span>
                  <span class="text-xs font-bold text-gray-700 dark:text-slate-200 leading-tight">{c.name}</span>
                  <span class="text-[10px] text-gray-400 dark:text-slate-500">open tender{c.openCount !== 1 ? 's' : ''}</span>
                </a>
              ))}
            </div>
          </section>
        )}

        <section>
          <h2 class="text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-4">All Other Districts</h2>
          <div class="flex flex-wrap gap-2">
            {withoutTenders.map(c => (
              <a href={`/tenders/${c.slug}`}
                class="inline-flex items-center px-3.5 py-1.5 bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-full text-xs font-semibold text-gray-500 dark:text-slate-400 hover:border-blue-500/40 hover:text-[#1A56DB] dark:hover:text-blue-400 transition">
                {c.name}
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </main>
  <Footer />
</TenderLayout>
