---
import TenderLayout from '../layouts/TenderLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { fetchTendersCached, fetchStatsCached, fetchCitiesCached } from '../lib/api.js';
import { formatRupee, formatDate, daysLeft, tenderDetailPath } from '../lib/cities.js';

let stats: { totalOpenTenders: number; totalEstimatedValue: number; bySource: Record<string,number>; lastFetchAt: string | null } = { totalOpenTenders: 0, totalEstimatedValue: 0, bySource: {}, lastFetchAt: null };
let gemTenders = [];
let cspgclTenders = [];
let topCities = [];

try {
  [stats, { tenders: gemTenders }, { tenders: cspgclTenders }, { cities: topCities }] = await Promise.all([
    fetchStatsCached(),
    fetchTendersCached({ status: 'open', source: 'GEM',    sort: 'endDate_asc', limit: 6 }),
    fetchTendersCached({ status: 'open', source: 'CSPGCL', sort: 'endDate_asc', limit: 6 }),
    fetchCitiesCached(),
  ]);
} catch (e) {
  console.error('[homepage] API error:', (e as Error).message);
}

const lastUpdated = stats.lastFetchAt
  ? new Date(stats.lastFetchAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })
  : null;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://cgtenders.com/#website',
      'name': 'CGTenders.com',
      'url': 'https://cgtenders.com',
      'description': 'Chhattisgarh government tender aggregator — GeM and CSPGCL portals in one place.',
      'potentialAction': {
        '@type': 'SearchAction',
        'target': { '@type': 'EntryPoint', 'urlTemplate': 'https://cgtenders.com/tenders?q={search_term_string}' },
        'query-input': 'required name=search_term_string'
      }
    },
    {
      '@type': 'Organization',
      '@id': 'https://cgtenders.com/#organization',
      'name': 'CGTenders.com',
      'url': 'https://cgtenders.com',
      'logo': {
        '@type': 'ImageObject',
        'url': 'https://cgtenders.com/favicon.svg',
        'caption': 'CGTenders.com Logo'
      }
    },
    {
      '@type': 'FAQPage',
      'mainEntity': [
        {
          '@type': 'Question',
          'name': 'What is e-tendering?',
          'acceptedAnswer': {
            '@type': 'Answer',
            'text': 'E-tendering (electronic tendering) is the process of publishing, managing, and bidding for procurement contracts online through an electronic tendering system. This increases efficiency, transparency, and access to public procurement contracts.'
          }
        },
        {
          '@type': 'Question',
          'name': 'How do I find CG government tenders?',
          'acceptedAnswer': {
            '@type': 'Answer',
            'text': 'You can easily search, filter, and track CG government tenders from portals like GeM and CSPGCL directly on CGTenders.com. You can filter by district, department, category, estimated bid value, and EMD.'
          }
        },
        {
          '@type': 'Question',
          'name': 'Is CGTenders.com free to use?',
          'acceptedAnswer': {
            '@type': 'Answer',
            'text': 'Yes, CGTenders.com is a free procurement aggregator platform allowing businesses to discover and analyze open bidding opportunities and tender notices across Chhattisgarh and India.'
          }
        },
        {
          '@type': 'Question',
          'name': 'What is the difference between e-procurement and e-tendering?',
          'acceptedAnswer': {
            '@type': 'Answer',
            'text': 'E-procurement covers the entire online procurement process, including procurement planning, management, and purchasing. E-tendering specifically refers to the initial bidding stage where suppliers submit bid responses electronically.'
          }
        },
        {
          '@type': 'Question',
          'name': 'How do I register as a bidder?',
          'acceptedAnswer': {
            '@type': 'Answer',
            'text': 'Bidders can register on official government portals (such as the GeM portal or state e-procurement boards) to submit formal bids. CGTenders.com lists notices and documents to help you identify active bidding opportunities.'
          }
        }
      ]
    }
  ]
};

// Shared card render helper (used in both sections)
type Tender = {
  source: string; bidNumber: string; title: string; organization?: string | null;
  locationCity?: string | null; endDate?: string | null; bidValue?: number | null;
  emdAmount?: number | null; viabilityScore?: number | null; category?: string[];
  risks?: string[];
};

function viabilityBg(score: number | null | undefined) {
  if (score == null) return 'bg-gray-100 text-gray-500';
  if (score >= 8) return 'bg-[#057A55] text-white';
  if (score >= 5) return 'bg-[#C27803] text-white';
  return 'bg-[#E02424] text-white';
}
---

<TenderLayout
  title="CGTenders.com | Chhattisgarh Government Tenders, E-Tendering & Procurement Notices"
  description="Find latest CG tenders, government e-tenders, procurement notices, public tenders, and bidding opportunities in Chhattisgarh and India on CGTenders.com."
  canonical="/"
  jsonLd={jsonLd}
>
  <Navbar />

  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-[#1a3c6e] via-[#102b54] to-[#0f1d33] text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16 flex flex-col lg:flex-row items-center gap-10">
        <div class="flex-1 space-y-6">
          <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/10 border border-white/20 rounded-full text-xs font-semibold tracking-wide text-blue-200">
            <span class="w-2 h-2 rounded-full bg-[#f5820d] animate-pulse"></span>
            Daily Aggregated e-Procurement Notices
          </div>
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold leading-tight tracking-tight font-['Outfit']">
            Chhattisgarh's Most Complete <span class="text-[#f5820d]">Tender &amp; Procurement</span> Portal
          </h1>
          <p class="text-gray-300 text-sm md:text-base max-w-2xl font-['DM_Sans']">
            Discover government e-tenders, procurement notices, supply tenders, and bidding opportunities across CG and India — all in one place.
          </p>

          <!-- Search Bar -->
          <form action="/tenders" method="GET" class="relative max-w-xl w-full flex items-center bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden p-1.5">
            <div class="pl-3 text-gray-400">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </div>
            <input type="text" name="q" placeholder="Search by keyword, department, or tender ID..." class="w-full pl-3 pr-24 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none border-none" />
            <button type="submit" class="bg-[#f5820d] hover:bg-[#e07204] text-white px-5 py-2.5 rounded-lg text-sm font-bold tracking-wide transition shadow-sm">
              Search
            </button>
          </form>

          <!-- CTA Buttons -->
          <div class="flex flex-wrap gap-4 pt-2">
            <a href="/tenders" class="px-6 py-3 bg-[#f5820d] hover:bg-[#e07204] text-white font-bold rounded-xl transition shadow-md hover:shadow-lg">
              Browse Tenders
            </a>
            <a href="/contact" class="px-6 py-3 bg-white/10 hover:bg-white/20 border border-white/30 text-white font-bold rounded-xl transition">
              Post a Tender
            </a>
          </div>
        </div>

        <!-- Stats Bar -->
        <div class="w-full lg:w-80 xl:w-96 flex-shrink-0 grid grid-cols-2 gap-4">
          <div class="bg-white/5 border border-white/10 rounded-2xl p-5 hover:bg-white/10 transition">
            <p class="text-2xl md:text-3xl font-extrabold text-[#f5820d] font-['Outfit']">{stats.totalOpenTenders}+</p>
            <p class="text-xs text-gray-300 font-medium mt-1">Active Tenders</p>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-2xl p-5 hover:bg-white/10 transition">
            <p class="text-2xl md:text-3xl font-extrabold text-[#f5820d] font-['Outfit']">180+</p>
            <p class="text-xs text-gray-300 font-medium mt-1">Departments Listed</p>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-2xl p-5 hover:bg-white/10 transition">
            <p class="text-2xl md:text-3xl font-extrabold text-[#f5820d] font-['Outfit']">28</p>
            <p class="text-xs text-gray-300 font-medium mt-1">States Covered</p>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-2xl p-5 hover:bg-white/10 transition">
            <p class="text-2xl md:text-3xl font-extrabold text-[#f5820d] font-['Outfit']">5,000+</p>
            <p class="text-xs text-gray-300 font-medium mt-1">Registered Bidders</p>
          </div>
        </div>
      </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 space-y-12">

      <!-- ── GeM Section ─────────────────────────────────────────────── -->
      <section>
        <div class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-3">
            <!-- GeM accent bar -->
            <div class="w-1 h-8 rounded-full bg-violet-500"></div>
            <div>
              <h2 class="text-lg md:text-xl font-bold text-gray-900 font-['Outfit']">GeM Portal Tenders</h2>
              <p class="text-xs text-gray-500">Government e-Marketplace — Chhattisgarh</p>
            </div>
            <span class="ml-1 px-2.5 py-0.5 bg-violet-100 text-violet-700 text-xs font-bold rounded-full">
              {stats.bySource?.GEM || 0} open
            </span>
          </div>
          <a href="/tenders?source=GEM"
            class="inline-flex items-center gap-1 text-sm font-medium text-violet-600 hover:underline">
            View all GeM
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        {gemTenders.length === 0 ? (
          <div class="text-center py-10 bg-violet-50 rounded-2xl border border-violet-100 text-violet-400 text-sm">
            No GeM tenders loaded yet.
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {gemTenders.map((t: Tender) => {
              const dl = daysLeft(t.endDate);
              return (
                <a href={tenderDetailPath(t)}
                  class="group flex flex-col bg-white border border-violet-100 hover:border-violet-400 hover:shadow-md transition rounded-2xl overflow-hidden">
                  <!-- Violet top bar -->
                  <div class="h-1 bg-gradient-to-r from-violet-500 to-purple-400"></div>
                  <div class="p-5 flex flex-col flex-1">
                    <!-- Header -->
                    <div class="flex items-center justify-between gap-2 mb-3">
                      <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-bold bg-violet-100 text-violet-700">
                        GeM
                      </span>
                      <div class="flex items-center gap-1.5">
                        {t.category?.slice(0,1).map((c: string) => (
                          <span class="text-xs bg-violet-50 text-violet-600 px-2 py-0.5 rounded-md font-medium">{c}</span>
                        ))}
                        {dl != null && (
                          <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${dl <= 0 ? 'bg-gray-100 text-gray-500' : dl <= 2 ? 'bg-red-100 text-red-700' : dl <= 7 ? 'bg-amber-100 text-amber-700' : 'bg-green-100 text-green-700'}`}>
                            {dl < 0 ? 'Closed' : dl === 0 ? 'Today' : `${dl}d`}
                          </span>
                        )}
                      </div>
                    </div>

                    <!-- Title -->
                    <h3 class="text-sm font-semibold text-gray-900 line-clamp-2 mb-1.5 group-hover:text-violet-700 transition leading-snug flex-1">
                      {t.title}
                    </h3>
                    {t.organization && (
                      <p class="text-xs text-gray-400 line-clamp-1 mb-3">{t.organization}</p>
                    )}

                    <!-- Values -->
                    <div class="grid grid-cols-2 gap-2 text-xs mt-auto pt-3 border-t border-violet-50">
                      <div>
                        <p class="text-gray-400">Bid Value</p>
                        <p class="font-semibold text-gray-800">{formatRupee(t.bidValue)}</p>
                      </div>
                      <div>
                        <p class="text-gray-400">EMD</p>
                        <p class="font-semibold text-gray-800">{formatRupee(t.emdAmount)}</p>
                      </div>
                      <div>
                        <p class="text-gray-400">Closing</p>
                        <p class="font-medium text-gray-700">{formatDate(t.endDate)}</p>
                      </div>
                      <div>
                        <p class="text-gray-400">District</p>
                        <p class="font-medium text-gray-700">{t.locationCity || 'Unspecified'}</p>
                      </div>
                    </div>

                    <!-- Footer -->
                    <div class="flex items-center justify-between mt-3">
                      {t.viabilityScore != null && (
                        <span class={`text-xs font-bold px-2 py-0.5 rounded-md ${viabilityBg(t.viabilityScore)}`}>
                          {t.viabilityScore}/10
                        </span>
                      )}
                      <span class="ml-auto text-xs text-violet-600 font-medium group-hover:underline">View details →</span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </section>

      <!-- ── CSPGCL Section ───────────────────────────────────────────── -->
      <section>
        <div class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-3">
            <!-- Amber accent bar -->
            <div class="w-1 h-8 rounded-full bg-amber-500"></div>
            <div>
              <h2 class="text-lg md:text-xl font-bold text-gray-900 font-['Outfit']">CSPGCL Tenders</h2>
              <p class="text-xs text-gray-500">Chhattisgarh State Power Generation Company</p>
            </div>
            <span class="ml-1 px-2.5 py-0.5 bg-amber-100 text-amber-700 text-xs font-bold rounded-full">
              {stats.bySource?.CSPGCL || 0} open
            </span>
          </div>
          <a href="/tenders?source=CSPGCL"
            class="inline-flex items-center gap-1 text-sm font-medium text-amber-600 hover:underline">
            View all CSPGCL
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        {cspgclTenders.length === 0 ? (
          <div class="text-center py-10 bg-amber-50 rounded-2xl border border-amber-100 text-amber-400 text-sm">
            No CSPGCL tenders loaded yet.
          </div>
        ) : (
          <!-- CSPGCL as table-style rows on md+, cards on mobile -->
          <div class="bg-white border border-amber-100 rounded-2xl overflow-hidden">
            <!-- Table header (desktop) -->
            <div class="hidden md:grid grid-cols-[2fr_1fr_1fr_1fr_1fr_auto] gap-4 px-5 py-3 bg-amber-50 border-b border-amber-100 text-xs font-semibold text-amber-700 uppercase tracking-wide">
              <span>Tender / Organisation</span>
              <span>Bid Value</span>
              <span>EMD</span>
              <span>Closing</span>
              <span>District</span>
              <span></span>
            </div>

            {cspgclTenders.map((t: Tender, i: number) => {
              const dl = daysLeft(t.endDate);
              return (
                <a href={tenderDetailPath(t)}
                  class={`group flex flex-col md:grid md:grid-cols-[2fr_1fr_1fr_1fr_1fr_auto] md:items-center gap-3 md:gap-4 px-5 py-4 hover:bg-amber-50/60 transition border-b border-gray-100 last:border-0`}>

                  <!-- Title + org (mobile card style + desktop col) -->
                  <div>
                    <div class="flex items-center gap-2 mb-1 md:mb-0.5">
                      <span class="md:hidden inline-flex items-center px-2 py-0.5 rounded-md text-xs font-bold bg-amber-100 text-amber-700">CSPGCL</span>
                      {t.category?.slice(0,1).map((c: string) => (
                        <span class="text-xs bg-amber-50 text-amber-600 px-2 py-0.5 rounded-md font-medium">{c}</span>
                      ))}
                      {dl != null && (
                        <span class={`md:hidden text-xs px-2 py-0.5 rounded-full font-medium ${dl <= 0 ? 'bg-gray-100 text-gray-500' : dl <= 2 ? 'bg-red-100 text-red-700' : dl <= 7 ? 'bg-amber-100 text-amber-700' : 'bg-green-100 text-green-700'}`}>
                          {dl < 0 ? 'Closed' : dl === 0 ? 'Today' : `${dl}d`}
                        </span>
                      )}
                    </div>
                    <p class="text-sm font-semibold text-gray-900 line-clamp-2 group-hover:text-amber-700 transition leading-snug">
                      {t.title}
                    </p>
                    {t.organization && (
                      <p class="text-xs text-gray-400 mt-0.5 line-clamp-1">{t.organization}</p>
                    )}
                  </div>

                  <!-- Value -->
                  <div>
                    <p class="text-xs text-gray-400 md:hidden">Bid Value</p>
                    <p class="text-sm font-semibold text-gray-900">{formatRupee(t.bidValue)}</p>
                  </div>

                  <!-- EMD -->
                  <div>
                    <p class="text-xs text-gray-400 md:hidden">EMD</p>
                    <p class="text-sm font-semibold text-gray-900">{formatRupee(t.emdAmount)}</p>
                  </div>

                  <!-- Closing -->
                  <div>
                    <p class="text-xs text-gray-400 md:hidden">Closing</p>
                    <div>
                      <p class="text-sm text-gray-700">{formatDate(t.endDate)}</p>
                      {dl != null && (
                        <span class={`hidden md:inline text-xs font-medium ${dl <= 0 ? 'text-gray-400' : dl <= 2 ? 'text-red-600' : dl <= 7 ? 'text-amber-600' : 'text-green-600'}`}>
                          {dl < 0 ? 'Closed' : dl === 0 ? 'Today' : `${dl}d left`}
                        </span>
                      )}
                    </div>
                  </div>

                  <!-- District -->
                  <div>
                    <p class="text-xs text-gray-400 md:hidden">District</p>
                    <p class="text-sm text-gray-700">{t.locationCity || 'Unspecified'}</p>
                  </div>

                  <!-- Score + arrow -->
                  <div class="flex items-center gap-2 justify-between md:justify-end">
                    {t.viabilityScore != null && (
                      <span class={`text-xs font-bold px-2 py-0.5 rounded-md ${viabilityBg(t.viabilityScore)}`}>
                        {t.viabilityScore}/10
                      </span>
                    )}
                    <svg class="w-4 h-4 text-amber-400 group-hover:text-amber-600 transition flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </section>

      <!-- ── Districts strip ─────────────────────────────────────────── -->
      {topCities.filter((c: {openCount: number}) => c.openCount > 0).length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-bold text-gray-900 font-['Outfit']">Active Districts</h2>
            <a href="/districts" class="text-sm font-medium text-[#1A56DB] hover:underline">All 33 districts →</a>
          </div>
          <div class="flex flex-wrap gap-2">
            {topCities
              .filter((c: {openCount: number}) => c.openCount > 0)
              .sort((a: {openCount: number}, b: {openCount: number}) => b.openCount - a.openCount)
              .slice(0, 18)
              .map((c: {name: string; slug: string; openCount: number}) => (
                <a href={`/tenders/${c.slug}`}
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-[#1A56DB] hover:text-[#1A56DB] transition">
                  {c.name}
                  <span class="bg-blue-50 text-[#1A56DB] text-xs font-semibold px-1.5 py-0.5 rounded-full">{c.openCount}</span>
                </a>
              ))
            }
          </div>
        </section>
      )}

      <!-- Featured Tender Categories -->
      <section class="mt-16">
        <div class="text-center max-w-2xl mx-auto mb-10">
          <h2 class="text-xl md:text-2xl font-bold text-gray-900 font-['Outfit']">Featured Tender Categories</h2>
          <p class="text-xs md:text-sm text-gray-500 mt-1.5 font-['DM_Sans']">Explore open bidding contracts across major industries and sectors in Chhattisgarh</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <!-- 1 -->
          <a href="/tenders?category=Civil Works" class="group flex flex-col items-center text-center p-6 bg-white border border-gray-200 hover:border-[#f5820d]/40 rounded-2xl shadow-sm hover:shadow-md transition">
            <div class="w-12 h-12 rounded-xl bg-orange-50 text-[#f5820d] flex items-center justify-center mb-3 group-hover:bg-[#f5820d] group-hover:text-white transition">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <span class="text-sm font-semibold text-gray-800 leading-snug group-hover:text-[#f5820d] font-['Outfit']">Construction &amp; Civil Works</span>
          </a>
          <!-- 2 -->
          <a href="/tenders?category=Electrical" class="group flex flex-col items-center text-center p-6 bg-white border border-gray-200 hover:border-[#f5820d]/40 rounded-2xl shadow-sm hover:shadow-md transition">
            <div class="w-12 h-12 rounded-xl bg-orange-50 text-[#f5820d] flex items-center justify-center mb-3 group-hover:bg-[#f5820d] group-hover:text-white transition">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <span class="text-sm font-semibold text-gray-800 leading-snug group-hover:text-[#f5820d] font-['Outfit']">Electrical &amp; Power</span>
          </a>
          <!-- 3 -->
          <a href="/tenders?category=IT %26 Software" class="group flex flex-col items-center text-center p-6 bg-white border border-gray-200 hover:border-[#f5820d]/40 rounded-2xl shadow-sm hover:shadow-md transition">
            <div class="w-12 h-12 rounded-xl bg-orange-50 text-[#f5820d] flex items-center justify-center mb-3 group-hover:bg-[#f5820d] group-hover:text-white transition">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <span class="text-sm font-semibold text-gray-800 leading-snug group-hover:text-[#f5820d] font-['Outfit']">IT &amp; Software</span>
          </a>
          <!-- 4 -->
          <a href="/tenders?category=General" class="group flex flex-col items-center text-center p-6 bg-white border border-gray-200 hover:border-[#f5820d]/40 rounded-2xl shadow-sm hover:shadow-md transition">
