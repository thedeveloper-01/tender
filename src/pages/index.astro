        summary::-webkit-details-marker { display: none; }
        .q-num { background: #1a3c6e; color: #fff; font-size: 11px; font-weight: 700; min-width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        details[open] .q-num { background: #f5820d; }
