---
import TenderLayout from '../layouts/TenderLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { fetchTendersCached, fetchStatsCached, fetchCitiesCached } from '../lib/api.js';
import { formatRupee, formatDate, daysLeft, tenderDetailPath } from '../lib/cities.js';

let stats: { totalOpenTenders: number; totalEstimatedValue: number; bySource: Record<string,number>; lastFetchAt: string | null } = { totalOpenTenders: 0, totalEstimatedValue: 0, bySource: {}, lastFetchAt: null };
let gemTenders = [];
let cspgclTenders = [];
let topCities = [];

try {
  [stats, { tenders: gemTenders }, { tenders: cspgclTenders }, { cities: topCities }] = await Promise.all([
    fetchStatsCached(),
    fetchTendersCached({ status: 'open', source: 'GEM',    sort: 'endDate_asc', limit: 12 }),
    fetchTendersCached({ status: 'open', source: 'CSPGCL', sort: 'endDate_asc', limit: 12 }),
    fetchCitiesCached(),
  ]);
} catch (e) {
  console.error('[homepage] API error:', (e as Error).message);
}

const lastUpdated = stats.lastFetchAt
  ? new Date(stats.lastFetchAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })
  : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'CGTenders.com',
  url: 'https://cgtenders.com',
  description: 'Chhattisgarh government tender aggregator — GeM and CSPGCL portals in one place.',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: 'https://cgtenders.com/tenders?q={search_term_string}' },
    'query-input': 'required name=search_term_string',
  },
};

// Shared card render helper (used in both sections)
type Tender = {
  source: string; bidNumber: string; title: string; organization?: string | null;
  locationCity?: string | null; endDate?: string | null; bidValue?: number | null;
  emdAmount?: number | null; viabilityScore?: number | null; category?: string[];
  risks?: string[];
};
---

<TenderLayout
  title="CGTenders.com — Chhattisgarh Government Tender Aggregator"
  description="Browse open government tenders from GeM and CSPGCL portals in Chhattisgarh — enriched with risk analysis and PDF-extracted details."
  canonical="/"
  jsonLd={jsonLd}
>
  <Navbar />

  <main>
    <!-- Hero strip -->
    <section class="bg-gradient-to-r from-[#1A56DB] to-[#1e3a8a] text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-white/10 border border-white/20 rounded-full text-xs font-medium">
                <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
                Updated daily · GeM + CSPGCL
              </span>
            </div>
            <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold leading-tight font-['Outfit']">
              Chhattisgarh Government Tenders
            </h1>
            <p class="text-blue-200 text-sm mt-1.5">
              GeM and CSPGCL open tenders in one place
              {lastUpdated && <span> · Last updated {lastUpdated}</span>}
            </p>
          </div>

          <!-- Stats -->
          <div class="flex flex-wrap gap-3">
            <div class="bg-white/10 border border-white/20 rounded-xl px-4 py-2.5 text-center min-w-[80px]">
              <p class="text-2xl font-extrabold font-['Outfit'] leading-none">{stats.totalOpenTenders}</p>
              <p class="text-xs text-blue-200 mt-0.5">Open</p>
            </div>
            <div class="bg-violet-500/30 border border-violet-400/40 rounded-xl px-4 py-2.5 text-center min-w-[80px]">
              <p class="text-2xl font-extrabold font-['Outfit'] leading-none">{stats.bySource?.GEM || 0}</p>
              <p class="text-xs text-violet-200 mt-0.5">GeM</p>
            </div>
            <div class="bg-amber-500/20 border border-amber-400/30 rounded-xl px-4 py-2.5 text-center min-w-[80px]">
              <p class="text-2xl font-extrabold font-['Outfit'] leading-none">{stats.bySource?.CSPGCL || 0}</p>
              <p class="text-xs text-amber-200 mt-0.5">CSPGCL</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 space-y-12">

      <!-- ── GeM Section ─────────────────────────────────────────────── -->
      <section>
        <div class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-3">
            <!-- GeM accent bar -->
            <div class="w-1 h-8 rounded-full bg-violet-500"></div>
            <div>
              <h2 class="text-lg md:text-xl font-bold text-gray-900 font-['Outfit']">GeM Portal Tenders</h2>
              <p class="text-xs text-gray-500">Government e-Marketplace — Chhattisgarh</p>
            </div>
            <span class="ml-1 px-2.5 py-0.5 bg-violet-100 text-violet-700 text-xs font-bold rounded-full">
              {stats.bySource?.GEM || 0} open
            </span>
          </div>
          <a href="/tenders?source=GEM"
            class="inline-flex items-center gap-1 text-sm font-medium text-violet-600 hover:underline">
            View all GeM
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        {gemTenders.length === 0 ? (
          <div class="text-center py-10 bg-violet-50 rounded-2xl border border-violet-100 text-violet-400 text-sm">
            No GeM tenders loaded yet.
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {gemTenders.map((t: Tender) => {
              const dl = daysLeft(t.endDate);
              return (
                <a href={tenderDetailPath(t)}
                  class="group flex flex-col bg-white border border-violet-100 hover:border-violet-400 hover:shadow-md transition rounded-2xl overflow-hidden">
                  <!-- Violet top bar -->
                  <div class="h-1 bg-gradient-to-r from-violet-500 to-purple-400"></div>
                  <div class="p-5 flex flex-col flex-1">
                    <!-- Header -->
                    <div class="flex items-center justify-between gap-2 mb-3">
                      <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-bold bg-violet-100 text-violet-700">
                        GeM
                      </span>
                      <div class="flex items-center gap-1.5">
                        {t.category?.slice(0,1).map((c: string) => (
                          <span class="text-xs bg-violet-50 text-violet-600 px-2 py-0.5 rounded-md font-medium">{c}</span>
                        ))}
                        {dl != null && (
                          <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${dl <= 0 ? 'bg-gray-100 text-gray-500' : dl <= 2 ? 'bg-red-100 text-red-700' : dl <= 7 ? 'bg-amber-100 text-amber-700' : 'bg-green-100 text-green-700'}`}>
                            {dl < 0 ? 'Closed' : dl === 0 ? 'Today' : `${dl}d`}
                          </span>
                        )}
                      </div>
                    </div>

                    <!-- Title -->
                    <h3 class="text-sm font-semibold text-gray-900 line-clamp-2 mb-1.5 group-hover:text-violet-700 transition leading-snug flex-1">
                      {t.title}
                    </h3>
                    {t.organization && (
                      <p class="text-xs text-gray-400 line-clamp-1 mb-3">{t.organization}</p>
                    )}

                    <!-- Values -->
                    <div class="grid grid-cols-2 gap-2 text-xs mt-auto pt-3 border-t border-violet-50">
                      <div>
                        <p class="text-gray-400">Bid Value</p>
                        <p class="font-semibold text-gray-800">{formatRupee(t.bidValue)}</p>
                      </div>
                      <div>
                        <p class="text-gray-400">EMD</p>
                        <p class="font-semibold text-gray-800">{formatRupee(t.emdAmount)}</p>
                      </div>
                      <div>
                        <p class="text-gray-400">Closing</p>
                        <p class="font-medium text-gray-700">{formatDate(t.endDate)}</p>
                      </div>
                      <div>
                        <p class="text-gray-400">District</p>
                        <p class="font-medium text-gray-700">{t.locationCity || 'Unspecified'}</p>
                      </div>
                    </div>

                    <!-- Footer -->
                    <div class="flex items-center justify-between mt-3">
                      <span class="ml-auto text-xs text-violet-600 font-medium group-hover:underline">View details →</span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </section>

      <!-- ── CSPGCL Section ───────────────────────────────────────────── -->
      <section>
        <div class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-3">
            <!-- Amber accent bar -->
            <div class="w-1 h-8 rounded-full bg-amber-500"></div>
            <div>
              <h2 class="text-lg md:text-xl font-bold text-gray-900 font-['Outfit']">CSPGCL Tenders</h2>
              <p class="text-xs text-gray-500">Chhattisgarh State Power Generation Company</p>
            </div>
            <span class="ml-1 px-2.5 py-0.5 bg-amber-100 text-amber-700 text-xs font-bold rounded-full">
              {stats.bySource?.CSPGCL || 0} open
            </span>
          </div>
          <a href="/tenders?source=CSPGCL"
            class="inline-flex items-center gap-1 text-sm font-medium text-amber-600 hover:underline">
            View all CSPGCL
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        {cspgclTenders.length === 0 ? (
          <div class="text-center py-10 bg-amber-50 rounded-2xl border border-amber-100 text-amber-400 text-sm">
            No CSPGCL tenders loaded yet.
          </div>
        ) : (
          <!-- CSPGCL as table-style rows on md+, cards on mobile -->
          <div class="bg-white border border-amber-100 rounded-2xl overflow-hidden">
            <!-- Table header (desktop) -->
            <div class="hidden md:grid grid-cols-[2fr_1fr_1fr_1fr_1fr_auto] gap-4 px-5 py-3 bg-amber-50 border-b border-amber-100 text-xs font-semibold text-amber-700 uppercase tracking-wide">
              <span>Tender / Organisation</span>
              <span>Bid Value</span>
              <span>EMD</span>
              <span>Closing</span>
              <span>District</span>
              <span></span>
            </div>

            {cspgclTenders.map((t: Tender, i: number) => {
              const dl = daysLeft(t.endDate);
              return (
                <a href={tenderDetailPath(t)}
                  class={`group flex flex-col md:grid md:grid-cols-[2fr_1fr_1fr_1fr_1fr_auto] md:items-center gap-3 md:gap-4 px-5 py-4 hover:bg-amber-50/60 transition border-b border-gray-100 last:border-0`}>

                  <!-- Title + org (mobile card style + desktop col) -->
                  <div>
                    <div class="flex items-center gap-2 mb-1 md:mb-0.5">
                      <span class="md:hidden inline-flex items-center px-2 py-0.5 rounded-md text-xs font-bold bg-amber-100 text-amber-700">CSPGCL</span>
                      {t.category?.slice(0,1).map((c: string) => (
                        <span class="text-xs bg-amber-50 text-amber-600 px-2 py-0.5 rounded-md font-medium">{c}</span>
                      ))}
                      {dl != null && (
                        <span class={`md:hidden text-xs px-2 py-0.5 rounded-full font-medium ${dl <= 0 ? 'bg-gray-100 text-gray-500' : dl <= 2 ? 'bg-red-100 text-red-700' : dl <= 7 ? 'bg-amber-100 text-amber-700' : 'bg-green-100 text-green-700'}`}>
                          {dl < 0 ? 'Closed' : dl === 0 ? 'Today' : `${dl}d`}
                        </span>
                      )}
                    </div>
                    <p class="text-sm font-semibold text-gray-900 line-clamp-2 group-hover:text-amber-700 transition leading-snug">
                      {t.title}
                    </p>
                    {t.organization && (
                      <p class="text-xs text-gray-400 mt-0.5 line-clamp-1">{t.organization}</p>
                    )}
                  </div>

                  <!-- Value -->
                  <div>
                    <p class="text-xs text-gray-400 md:hidden">Bid Value</p>
                    <p class="text-sm font-semibold text-gray-900">{formatRupee(t.bidValue)}</p>
                  </div>

                  <!-- EMD -->
                  <div>
                    <p class="text-xs text-gray-400 md:hidden">EMD</p>
                    <p class="text-sm font-semibold text-gray-900">{formatRupee(t.emdAmount)}</p>
                  </div>

                  <!-- Closing -->
                  <div>
                    <p class="text-xs text-gray-400 md:hidden">Closing</p>
                    <div>
                      <p class="text-sm text-gray-700">{formatDate(t.endDate)}</p>
                      {dl != null && (
                        <span class={`hidden md:inline text-xs font-medium ${dl <= 0 ? 'text-gray-400' : dl <= 2 ? 'text-red-600' : dl <= 7 ? 'text-amber-600' : 'text-green-600'}`}>
                          {dl < 0 ? 'Closed' : dl === 0 ? 'Today' : `${dl}d left`}
                        </span>
                      )}
                    </div>
                  </div>

                  <!-- District -->
                  <div>
                    <p class="text-xs text-gray-400 md:hidden">District</p>
                    <p class="text-sm text-gray-700">{t.locationCity || 'Unspecified'}</p>
                  </div>

                  <!-- Arrow -->
                  <div class="flex items-center justify-end">
                    <svg class="w-4 h-4 text-amber-400 group-hover:text-amber-600 transition flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </section>

      <!-- ── Districts strip ─────────────────────────────────────────── -->
      {topCities.filter((c: {openCount: number}) => c.openCount > 0).length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-bold text-gray-900 font-['Outfit']">Active Districts</h2>
            <a href="/districts" class="text-sm font-medium text-[#1A56DB] hover:underline">All 33 districts →</a>
          </div>
          <div class="flex flex-wrap gap-2">
            {topCities
              .filter((c: {openCount: number}) => c.openCount > 0)
              .sort((a: {openCount: number}, b: {openCount: number}) => b.openCount - a.openCount)
              .slice(0, 18)
              .map((c: {name: string; slug: string; openCount: number}) => (
                <a href={`/tenders/${c.slug}`}
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-[#1A56DB] hover:text-[#1A56DB] transition">
                  {c.name}
                  <span class="bg-blue-50 text-[#1A56DB] text-xs font-semibold px-1.5 py-0.5 rounded-full">{c.openCount}</span>
                </a>
              ))
            }
          </div>
        </section>
      )}

      <!-- ── FAQ Section ────────────────────────────────────────────── -->
      <section class="max-w-4xl mx-auto pt-4">
        <div class="text-center mb-8">
          <p class="text-[11px] font-bold text-[#f5820d] uppercase tracking-wider">CGTenders.com — Chhattisgarh's Tender Portal</p>
          <h2 class="text-2xl font-bold text-gray-900 font-['Outfit'] mt-1">Tender & Bidding <span class="text-[#f5820d]">FAQs</span></h2>
          <div class="inline-block bg-[#f5820d] text-white text-xs font-semibold px-3 py-1 rounded-full mt-3">20 Questions Answered</div>
        </div>

        <div class="bg-white border-l-4 border-[#f5820d] rounded-r-xl p-4 mb-6 text-sm text-gray-600">
          Everything you need to know about government tenders, the e-tendering process, procurement contracts, and how bidding works in Chhattisgarh and across India.
        </div>

        <!-- GROUP 1 -->
        <div class="faq-group-label">Understanding Tenders & E-Procurement</div>

        <details>
          <summary><span class="q-num">1</span><span class="q-text">What is a government tender?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">A government tender is an official invitation issued by a government department or public authority to suppliers, contractors, or service providers to submit bids for a specific project, supply, or service. In Chhattisgarh, tenders are published by departments like PWD, Health, Education, and many more.</div>
        </details>

        <details>
          <summary><span class="q-num">2</span><span class="q-text">What is e-tendering?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">E-tendering (electronic tendering) is the process of submitting, receiving, and evaluating tender bids digitally through an online platform instead of paper-based methods. It makes the procurement process faster, transparent, and accessible from anywhere in India.</div>
        </details>

        <details>
          <summary><span class="q-num">3</span><span class="q-text">What is the difference between e-tendering and e-procurement?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">E-procurement covers the entire digital procurement lifecycle — from identifying a need, sourcing suppliers, raising purchase orders, to payment. E-tendering is one specific stage within e-procurement, focused on the competitive bidding process where vendors submit their quotes or proposals online.</div>
        </details>

        <details>
          <summary><span class="q-num">4</span><span class="q-text">What is a tender notice?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">A tender notice is an official public announcement by a government body inviting bids from eligible suppliers or contractors. It contains key details such as the scope of work, eligibility criteria, bid submission deadline, EMD amount, and contact information for the issuing authority.</div>
        </details>

        <details>
          <summary><span class="q-num">5</span><span class="q-text">What is public procurement and why does it matter?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">Public procurement refers to the process by which government bodies purchase goods, services, and works using public funds. It matters because it ensures taxpayer money is spent transparently and efficiently. In India, public procurement accounts for a significant portion of GDP, making it a major opportunity for businesses of all sizes.</div>
        </details>

        <!-- GROUP 2 -->
        <div class="faq-group-label">Eligibility & Documentation</div>

        <details>
          <summary><span class="q-num">6</span><span class="q-text">Who can participate in government tenders?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">Any registered business, firm, individual contractor, or supplier meeting the eligibility criteria set in the tender document can participate. Eligibility typically depends on financial turnover, years of experience, and possession of required licenses or certifications specific to the work.</div>
        </details>

        <details>
          <summary><span class="q-num">7</span><span class="q-text">What documents are required to bid for a tender?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">Common documents required include: GST registration certificate, PAN card, company registration proof, audited financial statements (last 2–3 years), experience certificates, EMD (Earnest Money Deposit) proof, and any technical qualification documents mentioned in the specific tender notice.</div>
        </details>

        <details>
          <summary><span class="q-num">8</span><span class="q-text">What is EMD (Earnest Money Deposit) in tendering?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">EMD is a security deposit submitted along with a tender bid to confirm the bidder's seriousness. It is usually 1–2% of the tender value. If the winning bidder refuses to accept the contract, the EMD is forfeited. It is refunded to all unsuccessful bidders after the bid is finalized and a contract is awarded.</div>
        </details>

        <!-- GROUP 3 -->
        <div class="faq-group-label">The Bidding Process</div>

        <details>
          <summary><span class="q-num">9</span><span class="q-text">How do I find CG government tenders on CGTenders.com?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">You can search tenders by keyword, department name, category, or tender ID using the search bar on CGTenders.com. You can also filter results by state, closing date, or tender value to quickly find the most relevant procurement opportunities for your business.</div>
        </details>

        <details>
          <summary><span class="q-num">10</span><span class="q-text">What is a two-bid system in tendering?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">In a two-bid system, bidders submit two separate envelopes: the first contains technical details and qualifications, and the second contains the financial (price) bid. The price bids are only opened for technically qualified bidders, ensuring quality is assessed before cost — preventing the lowest-cost but unqualified vendor from winning.</div>
        </details>

        <details>
          <summary><span class="q-num">11</span><span class="q-text">What is the difference between an open tender and a limited tender?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">An open tender is published publicly and any eligible vendor can apply. A limited tender (or restricted tender) is sent only to a pre-approved list of vendors, usually for specialized or sensitive procurement. Open tenders are the most common type for government procurement in India and are listed on CGTenders.com.</div>
        </details>

        <details>
          <summary><span class="q-num">12</span><span class="q-text">Can I withdraw or modify my bid after submission?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">In most e-tendering systems, you can modify or withdraw your bid before the submission deadline. After the deadline, bids are locked and cannot be changed. Always confirm the rules in the specific tender document before attempting to modify a submitted bid, as policies vary by department.</div>
        </details>

        <details>
          <summary><span class="q-num">13</span><span class="q-text">Is there a deadline to submit a tender bid?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">Yes. Every tender has a bid submission deadline clearly mentioned in the tender notice. Late submissions are not accepted in e-tendering systems. It is strongly advisable to submit at least 24–48 hours before the deadline to avoid last-minute technical issues or connectivity problems.</div>
        </details>

        <!-- GROUP 4 -->
        <div class="faq-group-label">Evaluation, Award & Contracts</div>

        <details>
          <summary><span class="q-num">14</span><span class="q-text">How is a tender evaluated and awarded?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">Tenders are evaluated based on criteria specified in the tender document. Most government tenders follow either L1 (Lowest Price) criteria or Quality-cum-Cost Based Selection (QCBS). The authority reviews all valid bids, disqualifies non-compliant ones, and awards the contract to the most suitable bidder.</div>
        </details>

        <details>
          <summary><span class="q-num">15</span><span class="q-text">What happens after I submit a tender bid?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">After submission, the authority opens and reviews all bids on the specified bid-opening date. Technical bids are evaluated first, followed by financial bids for qualified bidders. You may be asked for clarifications. The contract is then awarded and a Letter of Award (LOA) is issued to the winning bidder.</div>
        </details>

        <details>
          <summary><span class="q-num">16</span><span class="q-text">What is a procurement contract?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">A procurement contract is a legally binding agreement signed between the government authority and the winning bidder, outlining the terms of supply, scope of work, timelines, payment terms, and penalties for non-compliance. It is issued after the tender evaluation and award process is fully complete.</div>
        </details>

        <details>
          <summary><span class="q-num">17</span><span class="q-text">What is performance security in a procurement contract?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">Performance security (also called Performance Bank Guarantee or PBG) is a deposit — usually 5–10% of the contract value — provided by the winning bidder to guarantee satisfactory completion of the work. It is released after the contract is successfully fulfilled and the defect liability period ends.</div>
        </details>

        <details>
          <summary><span class="q-num">18</span><span class="q-text">What is a corrigendum in a tender?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">A corrigendum is an official amendment or correction issued by the tendering authority after the original tender notice is published. It may change the submission deadline, modify the scope of work, correct errors, or update eligibility criteria. Always check for corrigenda on CGTenders.com before submitting your bid.</div>
        </details>

        <!-- GROUP 5 -->
        <div class="faq-group-label">Specific Tender Types</div>

        <details>
          <summary><span class="q-num">19</span><span class="q-text">What are supply and delivery tenders?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">Supply and delivery tenders are government procurement notices inviting vendors to supply specific goods — such as medicines, stationery, equipment, or food — to government departments or institutions. These are among the most frequently published tender types on CGTenders.com and are open to registered suppliers across Chhattisgarh.</div>
        </details>

        <details>
          <summary><span class="q-num">20</span><span class="q-text">How do I stay updated on new CG tenders?</span><span class="chevron">&#8964;</span></summary>
          <div class="answer">On CGTenders.com, you can set up keyword or category alerts to get notified whenever a new matching tender is published. You can also bookmark the Latest Tenders page and check it regularly, or follow CGTenders.com on social media for real-time tender updates from Chhattisgarh and across India.</div>
        </details>
      </section>

      <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {"@type":"Question","name":"What is a government tender?","acceptedAnswer":{"@type":"Answer","text":"A government tender is an official invitation issued by a government department or public authority to suppliers, contractors, or service providers to submit bids for a specific project, supply, or service. In Chhattisgarh, government tenders are published by departments like PWD, Health, Education, and more."}},
          {"@type":"Question","name":"What is e-tendering?","acceptedAnswer":{"@type":"Answer","text":"E-tendering (electronic tendering) is the process of submitting, receiving, and evaluating tender bids digitally through an online platform instead of paper-based methods. It makes the procurement process faster, transparent, and accessible from anywhere."}},
          {"@type":"Question","name":"What is the difference between e-tendering and e-procurement?","acceptedAnswer":{"@type":"Answer","text":"E-procurement covers the entire digital procurement lifecycle — from identifying a need, sourcing suppliers, raising purchase orders, to payment. E-tendering is one specific stage within e-procurement, focused on the competitive bidding process where vendors submit their quotes or proposals online."}},
          {"@type":"Question","name":"How do I find CG government tenders on CGTenders.com?","acceptedAnswer":{"@type":"Answer","text":"You can search tenders by keyword, department name, category, or tender ID using the search bar on CGTenders.com. You can also filter results by state, closing date, or tender value to find the most relevant opportunities."}},
          {"@type":"Question","name":"Who can participate in government tenders?","acceptedAnswer":{"@type":"Answer","text":"Any registered business, firm, individual contractor, or supplier meeting the eligibility criteria set in the tender document can participate. Eligibility typically depends on financial turnover, experience, and possession of required licenses or certifications."}},
          {"@type":"Question","name":"What documents are required to bid for a tender?","acceptedAnswer":{"@type":"Answer","text":"Common documents required include: GST registration certificate, PAN card, company registration proof, audited financial statements (last 2–3 years), experience certificates, EMD (Earnest Money Deposit) proof, and any technical qualification documents mentioned in the tender notice."}},
          {"@type":"Question","name":"What is EMD (Earnest Money Deposit) in tendering?","acceptedAnswer":{"@type":"Answer","text":"EMD is a security deposit submitted along with a tender bid to confirm the bidder's seriousness. It is usually a percentage of the tender value (typically 1–2%). If the winning bidder refuses to accept the contract, the EMD is forfeited. It is refunded to unsuccessful bidders after the bid is finalized."}},
          {"@type":"Question","name":"What is a tender notice?","acceptedAnswer":{"@type":"Answer","text":"A tender notice is an official public announcement by a government body inviting bids from eligible suppliers or contractors. It contains key details such as the scope of work, eligibility criteria, bid submission deadline, EMD amount, and contact information for the issuing authority."}},
          {"@type":"Question","name":"What is a procurement contract?","acceptedAnswer":{"@type":"Answer","text":"A procurement contract is a legally binding agreement signed between the government authority and the winning bidder, outlining the terms of supply, work scope, timelines, payment terms, and penalties for non-compliance. It is issued after the tender evaluation and award process is complete."}},
          {"@type":"Question","name":"How is a tender evaluated and awarded?","acceptedAnswer":{"@type":"Answer","text":"Tenders are evaluated based on criteria specified in the tender document. Most government tenders follow either L1 (Lowest Price) criteria or Quality-cum-Cost Based Selection (QCBS). The authority reviews all valid bids, disqualifies non-compliant ones, and awards the contract to the most suitable bidder."}},
          {"@type":"Question","name":"What is the difference between an open tender and a limited tender?","acceptedAnswer":{"@type":"Answer","text":"An open tender is published publicly and any eligible vendor can apply. A limited tender (or restricted tender) is sent only to a pre-approved list of vendors, usually for specialized or sensitive procurement. Open tenders are the most common for government procurement in India."}},
          {"@type":"Question","name":"What is a two-bid system in tendering?","acceptedAnswer":{"@type":"Answer","text":"In a two-bid system, bidders submit two separate envelopes: the first contains technical details and qualifications, and the second contains the financial (price) bid. The price bids are only opened for technically qualified bidders, ensuring quality is assessed before cost."}},
          {"@type":"Question","name":"What is a corrigendum in a tender?","acceptedAnswer":{"@type":"Answer","text":"A corrigendum is an official amendment or correction issued by the tendering authority after the original tender notice is published. It may change the submission deadline, modify scope of work, correct errors, or update eligibility criteria. Always check for corrigenda before submitting a bid."}},
          {"@type":"Question","name":"What happens after I submit a tender bid?","acceptedAnswer":{"@type":"Answer","text":"After submission, the authority opens and reviews all bids on the specified bid-opening date. Technical bids are evaluated first, followed by financial bids for qualified bidders. You may be asked for clarifications. The contract is then awarded and a Letter of Award (LOA) is issued to the winner."}},
          {"@type":"Question","name":"Can I withdraw or modify my bid after submission?","acceptedAnswer":{"@type":"Answer","text":"In most e-tendering systems, you can modify or withdraw your bid before the submission deadline. After the deadline, bids are locked and cannot be changed. Always confirm the rules in the specific tender document before attempting to modify a submitted bid."}},
          {"@type":"Question","name":"What is performance security in a procurement contract?","acceptedAnswer":{"@type":"Answer","text":"Performance security (also called Performance Bank Guarantee or PBG) is a deposit — usually 5–10% of the contract value — provided by the winning bidder to guarantee satisfactory completion of the work. It is released after the contract is successfully fulfilled and the defect liability period ends."}},
          {"@type":"Question","name":"What are supply and delivery tenders?","acceptedAnswer":{"@type":"Answer","text":"Supply and delivery tenders are government procurement notices inviting vendors to supply specific goods — such as medicines, stationery, equipment, or food — to government departments or institutions. These are among the most common tender types listed on CGTenders.com."}},
          {"@type":"Question","name":"What are logistics tenders?","acceptedAnswer":{"@type":"Answer","text":"Logistics tenders are procurement notices for transportation, warehousing, and delivery services issued by government bodies. Examples include tenders for transporting goods between districts, managing public distribution system (PDS) logistics, or moving medical supplies to health centers."}},
          {"@type":"Question","name":"What is public procurement and why does it matter?","acceptedAnswer":{"@type":"Answer","text":"Public procurement refers to the process by which government bodies purchase goods, services, and works using public funds. It matters because it ensures taxpayer money is spent transparently and efficiently. In India, public procurement accounts for a significant portion of GDP, making it a major opportunity for businesses."}},
          {"@type":"Question","name":"How do I stay updated on new CG tenders?","acceptedAnswer":{"@type":"Answer","text":"On CGTenders.com, you can set up keyword or category alerts to get notified whenever a new matching tender is published. You can also bookmark the Latest Tenders page and check it regularly, or follow CGTenders.com on social media for real-time tender updates from Chhattisgarh and across India."}},
          {"@type":"Question","name":"Is there a deadline to submit a tender bid?","acceptedAnswer":{"@type":"Answer","text":"Yes. Every tender has a bid submission deadline, which is clearly mentioned in the tender notice. Late submissions are not accepted in e-tendering systems. It is advisable to submit at least 24–48 hours before the deadline to avoid last-minute technical issues."}}
        ]
      }
