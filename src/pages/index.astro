---
import TenderLayout from '../layouts/TenderLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import TenderDashboard from '../components/TenderDashboard.jsx';
import { fetchStatsCached, fetchCitiesCached } from '../lib/api.js';

let stats: { totalOpenTenders: number; totalEstimatedValue: number; bySource: Record<string,number>; lastFetchAt: string | null } = { totalOpenTenders: 0, totalEstimatedValue: 0, bySource: {}, lastFetchAt: null };
let topCities = [];

try {
  [stats, { cities: topCities }] = await Promise.all([
    fetchStatsCached(Astro.locals),
    fetchCitiesCached(Astro.locals),
  ]);
} catch (e) {
  console.error('[homepage] API error:', (e as Error).message);
}

const lastUpdated = stats.lastFetchAt
  ? new Date(stats.lastFetchAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })
  : null;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'CGTenders',
    alternateName: 'CG Tenders',
    url: 'https://cgtenders.com',
    description: 'Chhattisgarh government tender aggregator — GeM and CSPGCL portals unified with risk flags, PDF extraction, and daily updates.',
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: 'https://cgtenders.com/?q={search_term_string}' },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'CGTenders.com',
    alternateName: 'CG Tenders',
    url: 'https://cgtenders.com',
    logo: 'https://cgtenders.com/favicon.svg',
    description: 'Aggregator for Chhattisgarh government tenders from GeM and CSPGCL portals, with risk analysis and daily updates.',
  },
];
---

<TenderLayout
  title="CGTenders.com | Chhattisgarh Government Tenders"
  description="Find open GeM and CSPGCL tenders in Chhattisgarh — with risk flags, PDF bid extraction, and a unified dashboard. Updated daily. Browse by district, category, or closing date."
  canonical="/"
  jsonLd={jsonLd}
>
  <Navbar />

  <main style="min-height:100vh;background:#051424;">

    <!-- Stats bar -->
    <div style="background:#0d1c2d;border-bottom:1px solid #424754;">
      <div style="max-width:1440px;margin:0 auto;padding:10px 32px;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:12px;">
        <div style="display:flex;flex-wrap:wrap;gap:20px;align-items:center;">
          <div style="display:flex;align-items:center;gap:6px;">
            <span style="width:7px;height:7px;border-radius:50%;background:#4edea3;display:inline-block;animation:blink 2s ease-in-out infinite;"></span>
            <span style="font-size:12px;color:#c2c6d6;font-weight:500;">Updated daily · GeM + CSPGCL</span>
            {lastUpdated && <span style="font-size:11px;color:#8c909f;">· Last updated {lastUpdated}</span>}
          </div>
          <div style="display:flex;gap:16px;">
            <div style="text-align:center;">
              <span style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:18px;color:#adc6ff;">{stats.totalOpenTenders}</span>
              <span style="font-size:11px;color:#8c909f;margin-left:4px;">Open</span>
            </div>
            <div style="text-align:center;">
              <span style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:18px;color:#adc6ff;">{stats.bySource?.GEM || 0}</span>
              <span style="font-size:11px;color:#8c909f;margin-left:4px;">GeM</span>
            </div>
            <div style="text-align:center;">
              <span style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:18px;color:#ffb786;">{stats.bySource?.CSPGCL || 0}</span>
              <span style="font-size:11px;color:#8c909f;margin-left:4px;">CSPGCL</span>
            </div>
          </div>
        </div>

        <!-- Active districts strip -->
        {topCities.filter((c: {openCount: number}) => c.openCount > 0).length > 0 && (
          <div style="display:flex;flex-wrap:wrap;gap:6px;align-items:center;">
            <span style="font-size:10px;color:#8c909f;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;margin-right:4px;">Districts:</span>
            {topCities
              .filter((c: {openCount: number}) => c.openCount > 0)
              .sort((a: {openCount: number}, b: {openCount: number}) => b.openCount - a.openCount)
              .slice(0, 8)
              .map((c: {name: string; slug: string; openCount: number}) => (
                <a href={`/tenders/${c.slug}`}
                  style="display:inline-flex;align-items:center;gap:4px;padding:2px 10px;background:#122131;border:1px solid #424754;border-radius:100px;font-size:11px;color:#c2c6d6;text-decoration:none;transition:all 0.15s;"
                  onmouseover="this.style.borderColor='#adc6ff';this.style.color='#adc6ff';"
                  onmouseout="this.style.borderColor='#424754';this.style.color='#c2c6d6';"
                >
                  {c.name}
                  <span style="background:#1c2b3c;color:#adc6ff;font-size:9px;font-weight:700;padding:1px 5px;border-radius:100px;">{c.openCount}</span>
                </a>
              ))
            }
            <a href="/districts" style="font-size:11px;color:#adc6ff;text-decoration:none;padding:2px 10px;border:1px solid #424754;border-radius:100px;">All 33 →</a>
          </div>
        )}
      </div>
    </div>

    <!-- Dashboard (React island) -->
    <TenderDashboard client:load initialSource="GEM" />

    <!-- FAQ Section (SEO content) -->
    <div style="max-width:900px;margin:0 auto;padding:48px 32px 64px;">
      <div style="text-align:center;margin-bottom:36px;">
        <p style="font-size:10px;font-weight:700;color:#ffb786;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px;">CGTenders.com — Chhattisgarh's Tender Portal</p>
        <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:26px;color:#d4e4fa;margin:0;">Tender &amp; Bidding <span style="color:#ffb786;">FAQs</span></h2>
        <div style="display:inline-block;background:#df7412;color:#311400;font-size:11px;font-weight:700;padding:4px 14px;border-radius:100px;margin-top:12px;">20 Questions Answered</div>
      </div>

      <div style="background:#122131;border-left:3px solid #ffb786;border-radius:0 4px 4px 0;padding:14px 18px;margin-bottom:24px;font-size:14px;color:#c2c6d6;">
        Common questions about the e-tendering process, EMD, procurement contracts, and bidding in Chhattisgarh — answered in plain language.
      </div>

      <!-- GROUP 1 -->
      <div class="faq-group-label">Understanding Tenders &amp; E-Procurement</div>

      <details><summary><span class="q-num">1</span><span class="q-text">What is a government tender?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">A government tender is an official invitation issued by a government department or public authority to suppliers, contractors, or service providers to submit bids for a specific project, supply, or service. In Chhattisgarh, tenders are published by departments like PWD, Health, Education, and many more.</div>
      </details>

      <details><summary><span class="q-num">2</span><span class="q-text">What is e-tendering?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">E-tendering (electronic tendering) is the process of submitting, receiving, and evaluating tender bids digitally through an online platform instead of paper-based methods. It makes the procurement process faster, transparent, and accessible from anywhere in India.</div>
      </details>

      <details><summary><span class="q-num">3</span><span class="q-text">What is the difference between e-tendering and e-procurement?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">E-procurement covers the entire digital procurement lifecycle — from identifying a need, sourcing suppliers, raising purchase orders, to payment. E-tendering is one specific stage within e-procurement, focused on the competitive bidding process where vendors submit their quotes or proposals online.</div>
      </details>

      <details><summary><span class="q-num">4</span><span class="q-text">What is a tender notice?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">A tender notice is an official public announcement by a government body inviting bids from eligible suppliers or contractors. It contains key details such as the scope of work, eligibility criteria, bid submission deadline, EMD amount, and contact information for the issuing authority.</div>
      </details>

      <details><summary><span class="q-num">5</span><span class="q-text">What is public procurement and why does it matter?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">Public procurement refers to the process by which government bodies purchase goods, services, and works using public funds. It matters because it ensures taxpayer money is spent transparently and efficiently. In India, public procurement accounts for a significant portion of GDP, making it a major opportunity for businesses of all sizes.</div>
      </details>

      <!-- GROUP 2 -->
      <div class="faq-group-label">Eligibility &amp; Documentation</div>

      <details><summary><span class="q-num">6</span><span class="q-text">Who can participate in government tenders?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">Any registered business, firm, individual contractor, or supplier meeting the eligibility criteria set in the tender document can participate. Eligibility typically depends on financial turnover, years of experience, and possession of required licenses or certifications specific to the work.</div>
      </details>

      <details><summary><span class="q-num">7</span><span class="q-text">What documents are required to bid for a tender?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">Common documents required include: GST registration certificate, PAN card, company registration proof, audited financial statements (last 2–3 years), experience certificates, EMD (Earnest Money Deposit) proof, and any technical qualification documents mentioned in the specific tender notice.</div>
      </details>

      <details><summary><span class="q-num">8</span><span class="q-text">What is EMD (Earnest Money Deposit) in tendering?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">EMD is a security deposit submitted along with a tender bid to confirm the bidder's seriousness. It is usually 1–2% of the tender value. If the winning bidder refuses to accept the contract, the EMD is forfeited. It is refunded to all unsuccessful bidders after the bid is finalized and a contract is awarded.</div>
      </details>

      <!-- GROUP 3 -->
      <div class="faq-group-label">The Bidding Process</div>

      <details><summary><span class="q-num">9</span><span class="q-text">How do I find CG government tenders on CGTenders.com?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">You can search tenders by keyword, department name, category, or tender ID using the search input on our <a href="/" style="color:#adc6ff;text-decoration:underline;">Tenders search page</a>. You can also filter results by state, closing date, or tender value to quickly find the most relevant procurement opportunities for your business.</div>
      </details>

      <details><summary><span class="q-num">10</span><span class="q-text">What is a two-bid system in tendering?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">In a two-bid system, bidders submit two separate envelopes: the first contains technical details and qualifications, and the second contains the financial (price) bid. The price bids are only opened for technically qualified bidders, ensuring quality is assessed before cost — preventing the lowest-cost but unqualified vendor from winning.</div>
      </details>

      <details><summary><span class="q-num">11</span><span class="q-text">What is the difference between an open tender and a limited tender?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">An open tender is published publicly and any eligible vendor can apply. A limited tender (or restricted tender) is sent only to a pre-approved list of vendors, usually for specialized or sensitive procurement. Open tenders are the most common type for government procurement in India and are listed on CGTenders.com.</div>
      </details>

      <details><summary><span class="q-num">12</span><span class="q-text">Can I withdraw or modify my bid after submission?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">In most e-tendering systems, you can modify or withdraw your bid before the submission deadline. After the deadline, bids are locked and cannot be changed. Always confirm the rules in the specific tender document before attempting to modify a submitted bid, as policies vary by department.</div>
      </details>

      <details><summary><span class="q-num">13</span><span class="q-text">Is there a deadline to submit a tender bid?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">Yes. Every tender has a bid submission deadline clearly mentioned in the tender notice. Late submissions are not accepted in e-tendering systems. It is strongly advisable to submit at least 24–48 hours before the deadline to avoid last-minute technical issues or connectivity problems.</div>
      </details>

      <!-- GROUP 4 -->
      <div class="faq-group-label">Evaluation, Award &amp; Contracts</div>

      <details><summary><span class="q-num">14</span><span class="q-text">How is a tender evaluated and awarded?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">Tenders are evaluated based on criteria specified in the tender document. Most government tenders follow either L1 (Lowest Price) criteria or Quality-cum-Cost Based Selection (QCBS). The authority reviews all valid bids, disqualifies non-compliant ones, and awards the contract to the most suitable bidder.</div>
      </details>

      <details><summary><span class="q-num">15</span><span class="q-text">What happens after I submit a tender bid?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">After submission, the authority opens and reviews all bids on the specified bid-opening date. Technical bids are evaluated first, followed by financial bids for qualified bidders. You may be asked for clarifications. The contract is then awarded and a Letter of Award (LOA) is issued to the winning bidder.</div>
      </details>

      <details><summary><span class="q-num">16</span><span class="q-text">What is a procurement contract?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">A procurement contract is a legally binding agreement signed between the government authority and the winning bidder, outlining the terms of supply, scope of work, timelines, payment terms, and penalties for non-compliance. It is issued after the tender evaluation and award process is fully complete.</div>
      </details>

      <details><summary><span class="q-num">17</span><span class="q-text">What is performance security in a procurement contract?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">Performance security (also called Performance Bank Guarantee or PBG) is a deposit — usually 5–10% of the contract value — provided by the winning bidder to guarantee satisfactory completion of the work. It is released after the contract is successfully fulfilled and the defect liability period ends.</div>
      </details>

      <details><summary><span class="q-num">18</span><span class="q-text">What is a corrigendum in a tender?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">A corrigendum is an official amendment or correction issued by the tendering authority after the original tender notice is published. It may change the submission deadline, modify the scope of work, correct errors, or update eligibility criteria. Always check for corrigenda on CGTenders.com before submitting your bid.</div>
      </details>

      <!-- GROUP 5 -->
      <div class="faq-group-label">Specific Tender Types</div>

      <details><summary><span class="q-num">19</span><span class="q-text">What are supply and delivery tenders?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">Supply and delivery tenders are government procurement notices inviting vendors to supply specific goods — such as medicines, stationery, equipment, or food — to government departments or institutions. These are among the most frequently published tender types on CGTenders.com and are open to registered suppliers across Chhattisgarh.</div>
      </details>

      <details><summary><span class="q-num">20</span><span class="q-text">How do I stay updated on new CG tenders?</span><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg></summary>
        <div class="answer">On CGTenders.com, you can set up keyword or category alerts to get notified whenever a new matching tender is published. You can also bookmark the Latest Tenders page and check it regularly, or follow CGTenders.com on social media for real-time tender updates from Chhattisgarh and across India.</div>
      </details>
    </div>

    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {"@type":"Question","name":"What is a government tender?","acceptedAnswer":{"@type":"Answer","text":"A government tender is an official invitation issued by a government department or public authority to suppliers, contractors, or service providers to submit bids for a specific project, supply, or service."}},
        {"@type":"Question","name":"What is e-tendering?","acceptedAnswer":{"@type":"Answer","text":"E-tendering is the process of submitting, receiving, and evaluating tender bids digitally through an online platform instead of paper-based methods."}},
        {"@type":"Question","name":"Who can participate in government tenders?","acceptedAnswer":{"@type":"Answer","text":"Any registered business, firm, individual contractor, or supplier meeting the eligibility criteria set in the tender document can participate."}},
        {"@type":"Question","name":"What is EMD in tendering?","acceptedAnswer":{"@type":"Answer","text":"EMD (Earnest Money Deposit) is a security deposit submitted along with a tender bid to confirm the bidder's seriousness. It is usually 1–2% of the tender value."}},
        {"@type":"Question","name":"How do I find CG government tenders on CGTenders.com?","acceptedAnswer":{"@type":"Answer","text":"You can search tenders by keyword, department name, category, or tender ID using the search input on our Tenders search page at cgtenders.com."}}
      ]
    }
    </script>
  </main>

  <Footer />

  <style>
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
  </style>

  <script>
    // FAQ accordion accessibility
    document.querySelectorAll('details').forEach((el) => {
      const summary = el.querySelector('summary');
      if (summary) {
        summary.setAttribute('aria-expanded', el.open ? 'true' : 'false');
        el.addEventListener('toggle', () => {
          summary.setAttribute('aria-expanded', el.open ? 'true' : 'false');
        });
      }
    });
  </script>
</TenderLayout>
