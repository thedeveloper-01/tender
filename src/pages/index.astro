---
import TenderLayout from '../layouts/TenderLayout.astro';
import Footer from '../components/Footer.astro';
import { CITIES, cityToSlug } from '../lib/cities.js';

const API_URL = process.env.API_URL || 'http://localhost:4000';

let stats = {
  totalOpen: 0,
  totalValue: 0,
  countsBySource: { GEM: 0, CSPGCL: 0 },
  countsByCategory: {}
};
let featuredTenders = [];

try {
  const statsRes = await fetch(`${API_URL}/api/stats`);
  if (statsRes.ok) {
    stats = await statsRes.json();
  }
} catch (e) {
  console.error('[homepage] Failed to fetch stats:', e.message);
}

try {
  const tendersRes = await fetch(`${API_URL}/api/tenders?limit=6&status=open`);
  if (tendersRes.ok) {
    const data = await tendersRes.json();
    featuredTenders = data.tenders || [];
  }
} catch (e) {
  console.error('[homepage] Failed to fetch featured tenders:', e.message);
}

function getTenderSlug(tender) {
  const safeBid = encodeURIComponent(tender.bidNumber);
  const safeTitle = tender.title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '')
    .slice(0, 50);
  return `${tender.source.toLowerCase()}--${safeBid}--${safeTitle}`;
}

const formatRupee = (val) => {
  if (val == null || isNaN(val)) return 'Not specified';
  if (val >= 10000000) return `₹${(val / 10000000).toFixed(2)} Cr`;
  if (val >= 100000) return `₹${(val / 100000).toFixed(2)} Lakh`;
  return '₹' + Number(val).toLocaleString('en-IN');
};

const getDaysLeft = (dateStr) => {
  if (!dateStr) return null;
  const target = new Date(dateStr);
  if (isNaN(target.getTime())) return null;
  const now = new Date();
  const diffMs = target - now;
  return Math.ceil(diffMs / (1000 * 60 * 60 * 24));
};
---

<TenderLayout title="CGTenders.com | Chhattisgarh Government Tender Aggregator">
  <div class="min-h-screen flex flex-col bg-[#F8F9FC]">
    
    <!-- Hero Banner -->
    <section class="relative bg-gradient-to-br from-[#101F42] to-[#1E3A8A] text-white py-16 md:py-24 px-4 overflow-hidden border-b border-blue-900/30">
      <div class="absolute top-0 right-0 -mt-10 -mr-10 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 -mb-10 -ml-10 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto text-center relative z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/20 border border-blue-400/20 text-blue-200 text-xs font-semibold mb-6">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
          Chhattisgarh Government Tender Intelligence Hub
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-white mb-6">
          CGTenders<span class="text-blue-400">.com</span>
        </h1>
        <p class="text-base sm:text-lg md:text-xl text-blue-100/90 max-w-3xl mx-auto mb-10 font-normal leading-relaxed">
          Aggregating and analyzing open government opportunities across Chhattisgarh. Access verified tenders from the GeM portal and CSPGCL with smart AI categorization, viability scoring, and automated PDF value extraction.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/tenders" class="w-full sm:w-auto px-8 py-4 bg-[#1A56DB] hover:bg-blue-700 text-white font-semibold rounded-xl transition-all shadow-lg hover:shadow-blue-500/25 flex items-center justify-center gap-2">
            Browse All Tenders
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
          <a href="#districts" class="w-full sm:w-auto px-8 py-4 bg-white/10 hover:bg-white/15 border border-white/10 hover:border-white/20 text-white font-semibold rounded-xl transition-all flex items-center justify-center gap-2">
            Explore Districts
          </a>
        </div>
      </div>
    </section>

    <!-- Stats Grid -->
    <section class="max-w-7xl mx-auto px-4 -mt-8 relative z-20 w-full">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        
        <div class="bg-white rounded-2xl p-6 shadow-[0_4px_20px_rgba(0,0,0,0.04)] border border-gray-100/80 flex flex-col">
          <span class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Active Tenders</span>
          <span class="text-3xl font-extrabold text-gray-900">{stats.totalOpen}</span>
          <span class="text-xs text-[#057A55] font-semibold mt-2 flex items-center gap-1">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Live Monitoring
          </span>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-[0_4px_20px_rgba(0,0,0,0.04)] border border-gray-100/80 flex flex-col">
          <span class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Opportunity Size</span>
          <span class="text-3xl font-extrabold text-gray-900">{formatRupee(stats.totalValue)}</span>
          <span class="text-xs text-gray-500 mt-2">Disclosed Estimated Cost</span>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-[0_4px_20px_rgba(0,0,0,0.04)] border border-gray-100/80 flex flex-col">
          <span class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">GeM Portal Bids</span>
          <span class="text-3xl font-extrabold text-[#1A56DB]">{stats.countsBySource.GEM || 0}</span>
          <span class="text-xs text-gray-500 mt-2">Chhattisgarh State-filtered</span>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-[0_4px_20px_rgba(0,0,0,0.04)] border border-gray-100/80 flex flex-col">
          <span class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">CSPGCL Bids</span>
          <span class="text-3xl font-extrabold text-emerald-600">{stats.countsBySource.CSPGCL || 0}</span>
          <span class="text-xs text-gray-500 mt-2">Power plants & Offices</span>
        </div>

      </div>
    </section>

    <!-- Soonest Closing Featured Tenders -->
    <section class="max-w-7xl mx-auto px-4 py-16 w-full">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 tracking-tight">Closing Soon</h2>
          <p class="text-sm text-gray-500 mt-1">High-priority tenders nearing their submission deadline.</p>
        </div>
        <a href="/tenders" class="text-sm font-semibold text-[#1A56DB] hover:underline flex items-center gap-1">
          View all
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      {featuredTenders.length === 0 ? (
        <div class="bg-white border border-gray-150 rounded-2xl p-12 text-center shadow-sm">
          <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <h3 class="text-lg font-bold text-gray-900 mb-1">No active tenders found</h3>
          <p class="text-sm text-gray-500">The database appears to be empty. Use `/api/refresh` or check the scheduler.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredTenders.map(tender => {
            const daysLeft = getDaysLeft(tender.endDate);
            const isUrgent = daysLeft !== null && [0, 1, 2, 3].includes(daysLeft);
            
            return (
              <div class="bg-white rounded-2xl p-6 border border-gray-150/80 shadow-sm flex flex-col justify-between hover:shadow-md transition group">
                <div>
                  <div class="flex justify-between items-start mb-4 gap-2">
                    <span class={`text-[10px] uppercase font-bold tracking-wider px-2 py-0.5 rounded-md border ${
                      tender.source === 'GEM' 
                        ? 'bg-blue-50 text-blue-700 border-blue-100' 
                        : 'bg-emerald-50 text-emerald-700 border-emerald-100'
                    }`}>
                      {tender.source}
                    </span>
                    {tender.viabilityScore && (
                      <span class={`text-xs font-bold px-2 py-0.5 rounded ${
                        tender.viabilityScore >= 8 ? 'bg-[#057A55] text-white' : tender.viabilityScore >= 5 ? 'bg-[#C27803] text-white' : 'bg-[#E02424] text-white'
                      }`}>
                        Score: {tender.viabilityScore}
                      </span>
                    )}
                  </div>
                  <h3 class="text-sm font-semibold text-[#1A56DB] mb-1 line-clamp-1">
                    {tender.locationCity || 'Unspecified'}
                  </h3>
                  <p class="text-xs text-gray-500 mb-3 line-clamp-1">{tender.organization || 'Chhattisgarh State'}</p>
                  <p class="text-gray-900 text-sm font-medium line-clamp-3 mb-4 min-h-[60px]">
                    {tender.title}
                  </p>
                </div>

                <div class="mt-auto space-y-4">
                  <div class="grid grid-cols-2 gap-3 bg-gray-50 rounded-xl p-3 border border-gray-100">
                    <div>
                      <span class="text-[9px] text-gray-400 uppercase font-bold">Value</span>
                      <p class="text-xs font-bold text-gray-900 mt-0.5">{formatRupee(tender.bidValue)}</p>
                    </div>
                    <div>
                      <span class="text-[9px] text-gray-400 uppercase font-bold">EMD</span>
                      <p class="text-xs font-bold text-gray-900 mt-0.5">{formatRupee(tender.emdAmount)}</p>
                    </div>
                  </div>

                  <div class="flex items-center justify-between text-xs text-gray-500 pt-2 border-t border-gray-100">
                    <div class="flex items-center gap-1.5">
                      <svg class={`w-4 h-4 ${isUrgent ? 'text-[#C27803]' : 'text-gray-400'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      <span class={isUrgent ? 'text-[#C27803] font-bold' : ''}>
                        {daysLeft === null ? 'No date' : Math.sign(daysLeft) === -1 ? 'Expired' : daysLeft === 0 ? 'Closes today!' : `${daysLeft} days left`}
                      </span>
                    </div>
                    <a href={`/tenders/${getTenderSlug(tender)}`} class="font-semibold text-[#1A56DB] hover:underline group-hover:translate-x-0.5 transition-transform flex items-center gap-0.5">
                      Details
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </section>

    <!-- Districts section -->
    <section id="districts" class="bg-white border-t border-b border-gray-200/60 py-16 px-4 w-full">
      <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 tracking-tight">Browse by District</h2>
          <p class="text-sm text-gray-500 mt-2">Explore active procurement and construction tenders filtered by Chhattisgarh district divisions.</p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 sm:gap-4">
          {CITIES.sort().map(city => (
            <a 
              href={`/tenders/${cityToSlug(city)}`}
              class="flex flex-col items-center justify-center p-4 rounded-xl border border-gray-150/80 bg-gray-50 hover:bg-white hover:border-[#1A56DB] hover:shadow-sm transition text-center group"
            >
              <span class="text-xs font-semibold text-gray-700 group-hover:text-[#1A56DB] transition-colors">{city}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Footer />
  </div>
</TenderLayout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
