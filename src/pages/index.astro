---
import TenderLayout from '../layouts/TenderLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { fetchTenders, fetchStats, fetchCities } from '../lib/api.js';
import { formatRupee, formatDate, daysLeft, viabilityColor, tenderDetailPath } from '../lib/cities.js';

let stats = { totalOpenTenders: 0, totalEstimatedValue: 0, bySource: {}, byCategory: {}, lastFetchAt: null };
let soonest = [];
let topCities = [];

try {
  [stats, { tenders: soonest }, { cities: topCities }] = await Promise.all([
    fetchStats(),
    fetchTenders({ status: 'open', sort: 'endDate_asc', limit: 6 }),
    fetchCities(),
  ]);
} catch (e) {
  console.error('[homepage] API error:', e.message);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'CGTenders.com',
  url: 'https://cgtenders.com',
  description: 'Chhattisgarh government tender aggregator — GeM and CSPGCL portals in one place.',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: 'https://cgtenders.com/tenders?q={search_term_string}' },
    'query-input': 'required name=search_term_string',
  },
};
---

<TenderLayout
  title="CGTenders.com — Chhattisgarh Government Tender Aggregator"
  description="Browse open government tenders from GeM and CSPGCL portals, filtered to Chhattisgarh. Search by district, category, bid value, EMD, and closing date."
  canonical="/"
  jsonLd={jsonLd}
>
  <Navbar />

  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-br from-[#1A56DB] via-[#1e40af] to-[#1e3a8a] text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-3 py-1 text-sm mb-6">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
            Updated daily · GeM + CSPGCL
          </div>
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold leading-tight mb-4 font-['Outfit']">
            Chhattisgarh Government<br/>Tenders, All in One Place
          </h1>
          <p class="text-blue-100 text-base md:text-lg leading-relaxed mb-8 max-w-2xl">
            Browse open tenders from the GeM portal and CSPGCL, enriched with viability scores, risk analysis,
            and PDF-extracted details. Filter by any of the 33 CG districts.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/tenders"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-[#1A56DB] rounded-xl font-semibold text-sm hover:bg-blue-50 transition shadow">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
              Browse All Tenders
            </a>
            <a href="/districts"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white/10 border border-white/30 rounded-xl font-semibold text-sm hover:bg-white/20 transition">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              </svg>
              Browse by District
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
          <div class="text-center">
            <p class="text-2xl md:text-3xl font-extrabold text-[#1A56DB] font-['Outfit']">{stats.totalOpenTenders}</p>
            <p class="text-xs text-gray-500 mt-0.5">Open Tenders</p>
          </div>
          <div class="text-center">
            <p class="text-2xl md:text-3xl font-extrabold text-gray-900 font-['Outfit']">{formatRupee(stats.totalEstimatedValue)}</p>
            <p class="text-xs text-gray-500 mt-0.5">Total Estimated Value</p>
          </div>
          <div class="text-center">
            <p class="text-2xl md:text-3xl font-extrabold text-gray-900 font-['Outfit']">{stats.bySource?.GEM || 0}</p>
            <p class="text-xs text-gray-500 mt-0.5">GeM Tenders</p>
          </div>
          <div class="text-center">
            <p class="text-2xl md:text-3xl font-extrabold text-gray-900 font-['Outfit']">{stats.bySource?.CSPGCL || 0}</p>
            <p class="text-xs text-gray-500 mt-0.5">CSPGCL Tenders</p>
          </div>
        </div>
      </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">

      <!-- Closing Soon -->
      <section class="mb-14">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h2 class="text-xl md:text-2xl font-bold text-gray-900 font-['Outfit']">Closing Soon</h2>
            <p class="text-sm text-gray-500 mt-0.5">Tenders with the nearest deadline</p>
          </div>
          <a href="/tenders" class="text-sm font-medium text-[#1A56DB] hover:underline flex items-center gap-1">
            View all
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        {soonest.length === 0 ? (
          <div class="text-center py-12 bg-white rounded-2xl border border-gray-200 text-gray-400 text-sm">
            No open tenders found. The pipeline may still be loading data.
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {soonest.map((t) => {
              const dl = daysLeft(t.endDate);
              const path = tenderDetailPath(t);
              return (
                <a href={path} class="group bg-white rounded-2xl border border-gray-200 hover:border-[#1A56DB]/40 hover:shadow-md transition p-5 flex flex-col">
                  <!-- Header -->
                  <div class="flex items-start justify-between gap-2 mb-3">
                    <span class={`inline-flex items-center px-2 py-0.5 rounded-md text-xs font-semibold ${t.source === 'GEM' ? 'bg-violet-100 text-violet-700' : 'bg-amber-100 text-amber-700'}`}>
                      {t.source}
                    </span>
                    {t.viabilityScore != null && (
                      <span class={`inline-flex items-center px-2 py-0.5 rounded-md text-xs font-bold ${viabilityColor(t.viabilityScore)}`}>
                        {t.viabilityScore}/10
                      </span>
                    )}
                  </div>

                  <!-- Title -->
                  <h3 class="text-sm font-semibold text-gray-900 line-clamp-2 mb-2 group-hover:text-[#1A56DB] transition flex-1">
                    {t.title}
                  </h3>

                  <!-- Meta -->
                  <div class="space-y-1 mt-auto pt-3 border-t border-gray-100">
                    <div class="flex items-center justify-between text-xs">
                      <span class="text-gray-500">{t.locationCity || 'Unspecified'}</span>
                      {dl != null && (
                        <span class={`font-medium ${dl <= 3 ? 'text-red-600' : dl <= 7 ? 'text-amber-600' : 'text-green-600'}`}>
                          {dl < 0 ? 'Closed' : dl === 0 ? 'Closes today' : `${dl}d left`}
                        </span>
                      )}
                    </div>
                    <div class="flex items-center justify-between text-xs">
                      <span class="text-gray-400">Value: {formatRupee(t.bidValue)}</span>
                      <span class="text-gray-400">EMD: {formatRupee(t.emdAmount)}</span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </section>

      <!-- Active Districts -->
      {topCities.filter(c => c.openCount > 0).length > 0 && (
        <section class="mb-14">
          <div class="flex items-center justify-between mb-6">
            <div>
              <h2 class="text-xl md:text-2xl font-bold text-gray-900 font-['Outfit']">Active Districts</h2>
              <p class="text-sm text-gray-500 mt-0.5">Districts with open tenders right now</p>
            </div>
            <a href="/districts" class="text-sm font-medium text-[#1A56DB] hover:underline flex items-center gap-1">
              All 33 districts
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
          <div class="flex flex-wrap gap-2">
            {topCities
              .filter(c => c.openCount > 0)
              .sort((a, b) => b.openCount - a.openCount)
              .slice(0, 16)
              .map(c => (
                <a href={`/tenders/${c.slug}`}
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-[#1A56DB] hover:text-[#1A56DB] transition">
                  {c.name}
                  <span class="bg-blue-50 text-[#1A56DB] text-xs font-semibold px-1.5 py-0.5 rounded-full">{c.openCount}</span>
                </a>
              ))
            }
          </div>
        </section>
      )}

      <!-- How it works -->
      <section class="bg-white rounded-2xl border border-gray-200 p-6 md:p-10">
        <h2 class="text-xl md:text-2xl font-bold text-gray-900 mb-8 font-['Outfit']">How CGTenders.com Works</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { n:'1', icon:'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z', title:'Daily Fetch', body:'GeM and CSPGCL portals are scraped every morning. New tenders are upserted, closed ones archived.' },
            { n:'2', icon:'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414A1 1 0 0121 9.414V19a2 2 0 01-2 2z', title:'PDF Extraction', body:'Bid documents are downloaded and parsed for EMD, bid value, delivery terms, eligibility criteria, and more.' },
            { n:'3', icon:'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title:'Analysis & Scoring', body:'Each tender gets a viability score (1–10), risk tags, and category labels from our analysis engine.' },
            { n:'4', icon:'M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1v-2zM3 16a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1v-2z', title:'Filter & Decide', body:'Search by keyword, district, category, value range, EMD, source, and closing date — then view full details.' },
          ].map(({ n, icon, title, body }) => (
            <div class="flex flex-col gap-3">
              <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-[#1A56DB]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={icon}/>
                </svg>
              </div>
              <div>
                <span class="text-xs font-bold text-[#1A56DB] mb-0.5 block">Step {n}</span>
                <h3 class="font-semibold text-gray-900 text-sm mb-1">{title}</h3>
                <p class="text-xs text-gray-500 leading-relaxed">{body}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>

  <Footer />
</TenderLayout>
