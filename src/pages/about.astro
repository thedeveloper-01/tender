---
import TenderLayout from '../layouts/TenderLayout.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

const title = 'About Us | CGTenders.com';
const description = 'Learn about CGTenders.com - An AI-powered platform for tender analysis and market insights.';
---

<TenderLayout {title} {description}>
  <Navbar />
  <div style="max-width:1200px;margin:0 auto;padding:48px 32px 64px;color:#c2c6d6;font-family:'Inter',sans-serif;">
    <div style="max-width:800px;margin:0 auto;">
      <!-- Header -->
      <div style="margin-bottom:36px;">
        <a href="/" style="display:inline-flex;align-items:center;gap:8px;color:#adc6ff;text-decoration:none;font-size:14px;font-weight:600;transition:color 0.15s;" onmouseover="this.style.color='#d8e2ff'" onmouseout="this.style.color='#adc6ff'">
          <svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Dashboard
        </a>
        <h1 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:800;font-size:36px;color:#d4e4fa;margin:16px 0 6px;letter-spacing:-0.02em;">About CGTenders.com</h1>
        <p style="font-size:15px;color:#8c909f;margin:0;">Empowering procurement teams with AI-driven insights</p>
      </div>

      <!-- Content -->
      <div style="line-height:1.6;font-size:15px;">
        <!-- Mission -->
        <section style="margin-bottom:40px;">
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:22px;color:#d4e4fa;margin:0 0 16px;border-bottom:1px solid #424754;padding-bottom:8px;">Our Mission</h2>
          <p style="margin:0 0 16px;">
            CGTenders.com aggregates open government tenders relevant to Chhattisgarh from the GeM portal and the CSPGCL portal into a single place, enriched with categorisation and risk analysis — helping vendors and procurement teams find and evaluate opportunities faster.
          </p>
        </section>

        <!-- Features -->
        <section style="margin-bottom:40px;">
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:22px;color:#d4e4fa;margin:0 0 16px;border-bottom:1px solid #424754;padding-bottom:8px;">Key Features</h2>
          <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(250px, 1fr));gap:16px;margin-bottom:16px;">
            <div style="background:rgba(173,198,255,0.08);border:1px solid rgba(173,198,255,0.18);border-radius:6px;padding:20px;">
              <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#adc6ff;margin:0 0 8px;display:flex;align-items:center;gap:8px;">
                <svg style="width:20px;height:20px;color:#adc6ff;" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
                </svg>
                Live Data Integration
              </h3>
              <p style="font-size:13px;color:#8c909f;margin:0;">Daily updates from GeM and CSPGCL portals</p>
            </div>
            <div style="background:rgba(78,222,163,0.06);border:1px solid rgba(78,222,163,0.15);border-radius:6px;padding:20px;">
              <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#4edea3;margin:0 0 8px;display:flex;align-items:center;gap:8px;">
                <svg style="width:20px;height:20px;color:#4edea3;" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
                AI-Powered Analysis
              </h3>
              <p style="font-size:13px;color:#8c909f;margin:0;">Smart categorization and tags</p>
            </div>
            <div style="background:rgba(255,183,134,0.06);border:1px solid rgba(255,183,134,0.15);border-radius:6px;padding:20px;">
              <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#ffb786;margin:0 0 8px;display:flex;align-items:center;gap:8px;">
                <svg style="width:20px;height:20px;color:#ffb786;" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/>
                </svg>
                Risk Assessment
              </h3>
              <p style="font-size:13px;color:#8c909f;margin:0;">Identify potential risks before bidding</p>
            </div>
            <div style="background:rgba(173,198,255,0.06);border:1px solid rgba(173,198,255,0.12);border-radius:6px;padding:20px;">
              <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#adc6ff;margin:0 0 8px;display:flex;align-items:center;gap:8px;">
                <svg style="width:20px;height:20px;color:#adc6ff;" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h12a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6z"/>
                </svg>
                Smart Filters
              </h3>
              <p style="font-size:13px;color:#8c909f;margin:0;">Customizable search and filtering options</p>
            </div>
          </div>
        </section>

        <!-- How It Works -->
        <section style="margin-bottom:40px;">
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:22px;color:#d4e4fa;margin:0 0 20px;border-bottom:1px solid #424754;padding-bottom:8px;">How It Works</h2>
          <div style="display:flex;flex-direction:column;gap:18px;">
            <div style="display:flex;gap:16px;">
              <div style="flex-shrink:0;width:32px;height:32px;border-radius:50%;background:#1c2b3c;border:1px solid #424754;display:flex;align-items:center;justify-content:center;font-weight:700;color:#adc6ff;font-size:14px;">1</div>
              <div>
                <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#d4e4fa;margin:0 0 4px;">Data Collection</h3>
                <p style="font-size:14px;color:#8c909f;margin:0;">We fetch the latest tender notices from GeM and CSPGCL every day</p>
              </div>
            </div>
            <div style="display:flex;gap:16px;">
              <div style="flex-shrink:0;width:32px;height:32px;border-radius:50%;background:#1c2b3c;border:1px solid #424754;display:flex;align-items:center;justify-content:center;font-weight:700;color:#adc6ff;font-size:14px;">2</div>
              <div>
                <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#d4e4fa;margin:0 0 4px;">AI Analysis</h3>
                <p style="font-size:14px;color:#8c909f;margin:0;">Our algorithms analyze scope, costs, and risk factors</p>
              </div>
            </div>
            <div style="display:flex;gap:16px;">
              <div style="flex-shrink:0;width:32px;height:32px;border-radius:50%;background:#1c2b3c;border:1px solid #424754;display:flex;align-items:center;justify-content:center;font-weight:700;color:#adc6ff;font-size:14px;">3</div>
              <div>
                <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#d4e4fa;margin:0 0 4px;">Insights</h3>
                <p style="font-size:14px;color:#8c909f;margin:0;">Get market trends and actionable recommendations</p>
              </div>
            </div>
            <div style="display:flex;gap:16px;">
              <div style="flex-shrink:0;width:32px;height:32px;border-radius:50%;background:#1c2b3c;border:1px solid #424754;display:flex;align-items:center;justify-content:center;font-weight:700;color:#adc6ff;font-size:14px;">4</div>
              <div>
                <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#d4e4fa;margin:0 0 4px;">Decision Making</h3>
                <p style="font-size:14px;color:#8c909f;margin:0;">Make informed bidding decisions with confidence</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Technology Stack -->
        <section style="margin-bottom:40px;">
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:22px;color:#d4e4fa;margin:0 0 16px;border-bottom:1px solid #424754;padding-bottom:8px;">Built With Modern Technology</h2>
          <p style="margin:0 0 16px;">
            CGTenders.com is built using a modern, scalable tech stack:
          </p>
          <ul style="list-style-type:disc;padding-left:20px;margin:0 0 16px;display:flex;flex-direction:column;gap:8px;">
            <li><strong>Frontend:</strong> React, Astro, and Vanilla CSS for highly polished responsive layouts</li>
            <li><strong>Backend:</strong> Node.js for server-side pipeline and data scraping</li>
            <li><strong>Data Processing:</strong> AI/ML algorithms and keyword extractors for tender analysis</li>
            <li><strong>Database:</strong> Prisma ORM and MongoDB Atlas for reliable persistence</li>
            <li><strong>Performance:</strong> Cloudflare KV caching for fast load times</li>
          </ul>
        </section>

        <!-- Contact CTA -->
        <section style="background:linear-gradient(135deg, #122131 0%, #1c2b3c 100%);border:1px solid #424754;border-radius:8px;padding:36px;text-align:center;margin-top:48px;">
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:800;font-size:24px;color:#d4e4fa;margin:0 0 8px;">Ready to Transform Your Procurement?</h2>
          <p style="font-size:14px;color:#8c909f;margin:0 0 24px;">
            Start using CGTenders.com today and make smarter bidding decisions
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;">
            <a href="/" style="padding:10px 24px;background:#adc6ff;color:#002e6a;border-radius:4px;font-weight:700;text-decoration:none;font-size:14px;transition:filter 0.15s;" onmouseover="this.style.filter='brightness(1.1)'" onmouseout="this.style.filter='brightness(1)'">
              Go to Dashboard
            </a>
            <a href="/contact" style="padding:10px 24px;background:transparent;color:#adc6ff;border:1px solid #adc6ff;border-radius:4px;font-weight:700;text-decoration:none;font-size:14px;transition:all 0.15s;" onmouseover="this.style.background='rgba(173,198,255,0.08)'" onmouseout="this.style.background='transparent'">
              Get in Touch
            </a>
          </div>
        </section>
      </div>
    </div>
  </div>

  <Footer />
</TenderLayout>
