---
import TenderLayout from '../layouts/TenderLayout.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

const title = 'About Us | CGTenders.com';
const description = 'Learn about CGTenders.com - An AI-powered platform for tender analysis and market insights.';
---

<TenderLayout {title} {description}>
  <Navbar />
  <div class="max-w-7xl mx-auto px-3 sm:px-4 md:px-6 lg:px-8 py-8 md:py-12">
    <div class="max-w-3xl mx-auto">
      <!-- Header -->
      <div class="mb-8">
        <a href="/tenders" class="inline-flex items-center gap-2 text-[#1A56DB] hover:text-blue-700 mb-4 transition">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Dashboard
        </a>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">About CGTenders.com</h1>
        <p class="text-gray-600">Empowering procurement teams with AI-driven insights</p>
      </div>

      <!-- Content -->
      <div class="prose prose-sm md:prose max-w-none">
        <!-- Mission -->
        <section class="mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Our Mission</h2>
          <p class="text-gray-700 mb-4">
            CGTenders.com aggregates open government tenders relevant to Chhattisgarh from the GeM portal and the CSPGCL portal into a single place, enriched with categorisation and risk analysis — helping vendors and procurement teams find and evaluate opportunities faster.
          </p>
        </section>

        <!-- Features -->
        <section class="mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Key Features</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div class="bg-blue-50 border border-blue-100 rounded-lg p-4">
              <h3 class="font-semibold text-gray-900 mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-[#1A56DB]" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
                </svg>
                Live Data Integration
              </h3>
              <p class="text-sm text-gray-700">Daily updates from GeM and CSPGCL portals</p>
            </div>
            <div class="bg-green-50 border border-green-100 rounded-lg p-4">
              <h3 class="font-semibold text-gray-900 mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-[#057A55]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
                AI-Powered Analysis
              </h3>
              <p class="text-sm text-gray-700">Smart categorization and tags</p>
            </div>
            <div class="bg-orange-50 border border-orange-100 rounded-lg p-4">
              <h3 class="font-semibold text-gray-900 mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-[#C27803]" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/>
                </svg>
                Risk Assessment
              </h3>
              <p class="text-sm text-gray-700">Identify potential risks before bidding</p>
            </div>
            <div class="bg-purple-50 border border-purple-100 rounded-lg p-4">
              <h3 class="font-semibold text-gray-900 mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h12a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6z"/>
                </svg>
                Smart Filters
              </h3>
              <p class="text-sm text-gray-700">Customizable search and filtering options</p>
            </div>
          </div>
        </section>

        <!-- How It Works -->
        <section class="mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">How It Works</h2>
          <div class="space-y-4">
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-8 w-8 rounded-full bg-[#1A56DB] text-white font-bold text-sm">1</div>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Data Collection</h3>
                <p class="text-sm text-gray-600">We fetch the latest tender notices from GeM and CSPGCL every day</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-8 w-8 rounded-full bg-[#1A56DB] text-white font-bold text-sm">2</div>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">AI Analysis</h3>
                <p class="text-sm text-gray-600">Our algorithms analyze scope, costs, and risk factors</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-8 w-8 rounded-full bg-[#1A56DB] text-white font-bold text-sm">3</div>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Insights</h3>
                <p class="text-sm text-gray-600">Get market trends and actionable recommendations</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-8 w-8 rounded-full bg-[#1A56DB] text-white font-bold text-sm">4</div>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Decision Making</h3>
                <p class="text-sm text-gray-600">Make informed bidding decisions with confidence</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Technology Stack -->
        <section class="mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Built With Modern Technology</h2>
          <p class="text-gray-700 mb-4">
            CGTenders.com is built using a modern, scalable tech stack:
          </p>
          <ul class="list-disc list-inside space-y-2 text-gray-700">
            <li><strong>Frontend:</strong> React, Astro, and Tailwind CSS for responsive design</li>
            <li><strong>Backend:</strong> Node.js for server-side processing</li>
            <li><strong>Data Processing:</strong> AI/ML algorithms for tender analysis</li>
            <li><strong>Database:</strong> Optimized for fast queries and analytics</li>
            <li><strong>Security:</strong> Enterprise-grade encryption and compliance</li>
          </ul>
        </section>

        <!-- Contact CTA -->
        <section class="bg-gradient-to-r from-[#1A56DB] to-[#1e3a8a] text-white rounded-lg p-8 text-center mt-12">
          <h2 class="text-2xl font-bold mb-4">Ready to Transform Your Procurement?</h2>
          <p class="text-blue-100 mb-6">
            Start using CGTenders.com today and make smarter bidding decisions
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/tenders" class="px-6 py-3 bg-white text-[#1A56DB] rounded-lg font-semibold hover:bg-blue-50 transition">
              Go to Dashboard
            </a>
            <a href="/contact" class="px-6 py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition border border-blue-500">
              Get in Touch
            </a>
          </div>
        </section>
      </div>
    </div>
  </div>

  <Footer />
</TenderLayout>
