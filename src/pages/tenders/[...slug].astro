          </details>

          <details class="group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none select-none hover:bg-gray-50/60 dark:hover:bg-slate-800/20 transition-colors gap-4">
              <span class="text-sm font-medium text-gray-800 dark:text-slate-200">Who has issued this tender?</span>
              <svg class="w-4 h-4 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 pt-1">
              <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">
                {`This tender was issued by ${tender.organization || tender.department || 'the government authority'} via the ${tender.source === 'GEM' ? 'GeM (Government e-Marketplace) portal' : 'CSPGCL portal'}. It is a government procurement tender for ${tender.locationCity && tender.locationCity !== 'Unspecified' ? `${tender.locationCity}, Chhattisgarh` : 'Chhattisgarh, India'}.`}
              </p>
            </div>
          </details>

          <details class="group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none select-none hover:bg-gray-50/60 dark:hover:bg-slate-800/20 transition-colors gap-4">
              <span class="text-sm font-medium text-gray-800 dark:text-slate-200">What is the estimated bid value of this tender?</span>
              <svg class="w-4 h-4 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 pt-1">
              <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">
                {tender.bidValue
                  ? `The estimated bid value for this tender is ${formatRupee(tender.bidValue)} as listed on the ${tender.source === 'GEM' ? 'GeM portal' : 'CSPGCL portal'}.`
                  : 'The estimated bid value is not publicly specified. Refer to the bid document for more information.'}
              </p>
            </div>
          </details>

          <details class="group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none select-none hover:bg-gray-50/60 dark:hover:bg-slate-800/20 transition-colors gap-4">
              <span class="text-sm font-medium text-gray-800 dark:text-slate-200">How can I apply for this tender?</span>
              <svg class="w-4 h-4 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 pt-1">
              <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">
                {'To apply, visit the '}
                {tender.source === 'GEM' ? 'GeM portal (gem.gov.in)' : 'CSPGCL portal'}
                {' and search for bid number '}
                <strong class="font-mono text-gray-800 dark:text-slate-200">{tender.bidNumber}</strong>
                {`. Register as a vendor, download the bid document, review all terms and submit your bid electronically before ${tender.endDate ? formatDate(tender.endDate) : 'the closing date'}.`}
              </p>
            </div>
          </details>

        </div>
      </section>

      <!-- Fetched at -->
      <p class="text-xs text-gray-400 dark:text-slate-500 mt-2 mb-8 text-center">
        Last updated: {formatDate(tender.fetchedAt)} | Data sourced from official government portals
      </p>

      <!-- ------------------------------------------------------------- -->
      <!-- SEO BLOCK 4: Keyword-rich Internal Link Hub (SSR)               -->
      <!-- Each anchor uses descriptive keyword anchor text â€” search engines use -->
      <!-- these links to trace and index district, portal, and tender pages -->
      <!-- ------------------------------------------------------------- -->
      <aside
        aria-label="Explore more government tenders"
        class="border-t border-gray-100 dark:border-slate-800 pt-8 pb-4"
      >
        <h2 class="text-xs font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-5">Explore More Tenders</h2>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">

          <!-- Keyword link: District tenders page -->
          {tender.locationCity && tender.locationCity !== 'Unspecified' ? (
            <a
              href={`/tenders/${tender.locationCity.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
              class="group flex items-start gap-3 p-4 rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-[#1A56DB]/50 dark:hover:border-blue-500/40 hover:shadow-sm transition-all"
            >
              <span class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-950/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-[#1A56DB] dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </span>
              <div>
                <p class="text-xs text-gray-400 dark:text-slate-500 mb-0.5">District Tenders</p>
                <p class="text-sm font-semibold text-gray-900 dark:text-slate-100 group-hover:text-[#1A56DB] dark:group-hover:text-blue-400 transition">
                  {tender.locationCity} Government Tenders
                </p>
                <p class="text-xs text-gray-400 dark:text-slate-500 mt-0.5">Open bids in {tender.locationCity}, Chhattisgarh</p>
              </div>
            </a>
          ) : (
            <a
              href="/tenders"
              class="group flex items-start gap-3 p-4 rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-[#1A56DB]/50 dark:hover:border-blue-500/40 hover:shadow-sm transition-all"
            >
              <span class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-950/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-[#1A56DB] dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
                </svg>
              </span>
              <div>
                <p class="text-xs text-gray-400 dark:text-slate-500 mb-0.5">All Tenders</p>
                <p class="text-sm font-semibold text-gray-900 dark:text-slate-100 group-hover:text-[#1A56DB] dark:group-hover:text-blue-400 transition">Chhattisgarh Government Tenders</p>
                <p class="text-xs text-gray-400 dark:text-slate-500 mt-0.5">Browse all open GeM &amp; CSPGCL bids</p>
              </div>
            </a>
          )}

          <!-- Keyword link: Portal-specific tenders page -->
          <a
            href={tender.source === 'GEM' ? '/gem' : '/cspgcl'}
            class="group flex items-start gap-3 p-4 rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-violet-400/50 dark:hover:border-violet-500/40 hover:shadow-sm transition-all"
          >
            <span class="w-8 h-8 rounded-lg bg-violet-50 dark:bg-violet-950/30 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-violet-600 dark:text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/>
              </svg>
            </span>
            <div>
              <p class="text-xs text-gray-400 dark:text-slate-500 mb-0.5">{tender.source === 'GEM' ? 'GeM Portal' : 'CSPGCL Portal'}</p>
              <p class="text-sm font-semibold text-gray-900 dark:text-slate-100 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition">
                {tender.source === 'GEM' ? 'All GeM Tenders in Chhattisgarh' : 'All CSPGCL Tenders'}
              </p>
              <p class="text-xs text-gray-400 dark:text-slate-500 mt-0.5">
                {tender.source === 'GEM' ? 'Government e-Marketplace bids in CG' : 'CSPGCL power sector procurement'}
              </p>
            </div>
          </a>

          <!-- Keyword link: Districts directory -->
          <a
            href="/districts"
            class="group flex items-start gap-3 p-4 rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-amber-400/50 dark:hover:border-amber-500/40 hover:shadow-sm transition-all"
          >
            <span class="w-8 h-8 rounded-lg bg-amber-50 dark:bg-amber-950/30 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
              </svg>
            </span>
            <div>
              <p class="text-xs text-gray-400 dark:text-slate-500 mb-0.5">Browse by District</p>
              <p class="text-sm font-semibold text-gray-900 dark:text-slate-100 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition">All 33 CG Districts</p>
              <p class="text-xs text-gray-400 dark:text-slate-500 mt-0.5">Tenders by all Chhattisgarh districts</p>
            </div>
          </a>

        </div>

        <!-- Related tenders â€” SSR, each linked URL discovered by Googlebot -->
        {relatedTenders.length > 0 && (
          <div>
            <h3 class="text-xs font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-3">More Tenders Like This</h3>
            <ul class="space-y-2">
              {relatedTenders.map((rt: Tender) => (
                <li>
                  <a
                    href={tenderDetailPath(rt)}
                    class="group flex items-start gap-3 px-4 py-3 rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-[#1A56DB]/40 dark:hover:border-blue-500/40 transition"
                  >
                    <span class={`mt-0.5 px-1.5 py-0.5 rounded text-xs font-bold border flex-shrink-0 ${
                      rt.source === 'GEM'
                        ? 'bg-violet-50 text-violet-700 dark:bg-violet-950/60 dark:text-violet-400 border-violet-100 dark:border-violet-900/40'
                        : 'bg-amber-50 text-amber-700 dark:bg-amber-950/60 dark:text-amber-400 border-amber-100 dark:border-amber-900/40'
                    }`}>{rt.source}</span>
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-gray-900 dark:text-slate-100 group-hover:text-[#1A56DB] dark:group-hover:text-blue-400 transition line-clamp-2 leading-snug">{rt.title}</p>
                      <div class="flex items-center gap-2 mt-1 text-xs text-gray-400 dark:text-slate-500">
                        {rt.locationCity && <span>{rt.locationCity}, Chhattisgarh</span>}
                        {rt.locationCity && rt.endDate && <span aria-hidden="true">|</span>}
                        {rt.endDate && <span>Closes {formatDate(rt.endDate)}</span>}
                      </div>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

      </aside>
    </main>
  )}
  <Footer />
</TenderLayout>
