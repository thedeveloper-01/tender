---
import TenderLayout from '../../layouts/TenderLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import TenderDashboard from '../../components/TenderDashboard.jsx';
import TenderCard from '../../components/TenderCard.astro';
import { fetchTenderDetailCached, documentUrl, fetchTendersCached } from '../../lib/api.js';
import { formatRupee, formatDate, daysLeft, cityFromSlug, tenderDetailPath, titleSlug } from '../../lib/cities.js';

const { slug } = Astro.params as { slug: string };
const decodedSlug = decodeURIComponent(slug ?? '');

// Redirect legacy paths to new paths
const lowerSlug = decodedSlug.toLowerCase();
if (lowerSlug === 'gem') {
  return Astro.redirect('/gem', 301);
}
if (lowerSlug === 'cspgcl') {
  return Astro.redirect('/cspgcl', 301);
}

// Determine if it is a city/district route
const city = lowerSlug === 'unspecified' ? 'Unspecified' : cityFromSlug(lowerSlug);
const isCityRoute = !!city;

type ExtractField = { label: string; value: string };
type ExtractFields = Record<string, ExtractField>;

interface Tender {
  id: string;
  source: string;
  bidNumber: string;
  title: string;
  department?: string | null;
  organization?: string | null;
  category?: string[];
  locationCity?: string | null;
  startDate?: string | null;
  endDate?: string | null;
  quantity?: string | null;
  bidValue?: number | null;
  emdAmount?: number | null;
  valueExtractionStatus?: string;
  viabilityScore?: number | null;
  risks?: string[];
  pdfPath?: string | null;
  bidLink?: string | null;
  status: string;
  fetchedAt: string;
  sourceMeta?: {
    isEbidding?: boolean;
    pdfExtract?: { fields?: ExtractFields; text?: string };
    [key: string]: unknown;
  } | null;
}

let fetchedTender: Tender | null = null;
let err: string | null = null;

let dl: number | null = null;
let deadlineLabel: string | null = null;
let deadlineCls = '';
let pdfLink: string | null = null;
let sourceLink: string | null = null;
let extractFields: ExtractFields = {};
let rawText: string | null = null;
let hasExtraDetails = false;
let jsonLdItems: object[] = [];
let pageTitle = '';
let metaDesc = '';
let ogType = 'website';
let articlePublishedTime: string | undefined;
let articleModifiedTime: string | undefined;

let initialTenders = null;
let initialTotal = 0;

// --- Related tenders for "More like this" section (detail pages only) ---
let relatedTenders: Tender[] = [];

if (isCityRoute) {
  const year = new Date().getFullYear();
  pageTitle = `${city} Government Tenders ${year} — GeM & CSPGCL | CGTenders.com`;
  metaDesc = `Browse open government tenders in ${city}, Chhattisgarh from GeM and CSPGCL portals. Filter by district, category and closing date. Updated daily.`;

  const breadcrumbLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cgtenders.com/' },
      { '@type': 'ListItem', position: 2, name: `${city} Tenders`, item: `https://cgtenders.com/tenders/${slug}` },
    ],
  };

  jsonLdItems = [
    {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: pageTitle,
      description: metaDesc,
      url: `https://cgtenders.com/tenders/${slug}`,
    },
    breadcrumbLd,
  ];

  try {
    const tendersData = await fetchTendersCached({ status: 'open', city, limit: 100 }, Astro.locals);
    initialTenders = tendersData.tenders || [];
    initialTotal = tendersData.total || 0;
  } catch (e: any) {
    console.error(`[city tenders SSR] error for ${city}:`, e.message);
  }
} else {
  // slug format:  <source>-<bidNumber>-<title-slug>
  // GEM example:  gem-GEM/2026/B/7179248-amc-of-security-system
  // CSPGCL:       cspgcl-CSPGCL-GEN-123456789-scope-of-work
  //
  // Strategy:
  //  1. Strip the source prefix (gem- or cspgcl-).
  //  2. GEM bids always contain '/' — read up to and including the last
  //     slash, then grab the numeric ID that follows (stopping at the
  //     first '-' which begins the title slug).
  //  3. CSPGCL bids look like "CSPGCL-GEN-<digits>" — match that prefix.
  let source = '';
  let bidNumber = '';
  let titlePart = '';

  const match = decodedSlug.match(/^(gem|cspgcl)-(.+)$/i);
  if (match) {
    source = match[1].toUpperCase();
    const rest = match[2];   // everything after "gem-" or "cspgcl-"

    if (source === 'GEM') {
      // GEM bid numbers contain slashes: GEM/2026/B/7179248
      const gemMatch = rest.match(/^(GEM\/\d{4}\/[A-Z]\/\d+)/i);
      if (gemMatch) {
        bidNumber = gemMatch[1];
        titlePart = rest.slice(gemMatch[1].length).replace(/^-/, '');
      } else {
        const lastSlash = rest.lastIndexOf('/');
        if (lastSlash !== -1) {
          const prefix   = rest.substring(0, lastSlash);
          const afterSlash = rest.substring(lastSlash + 1);
          const dashIdx  = afterSlash.indexOf('-');
          const numPart  = dashIdx === -1 ? afterSlash : afterSlash.substring(0, dashIdx);
          bidNumber = `${prefix}/${numPart}`;
          titlePart = dashIdx === -1 ? '' : afterSlash.substring(dashIdx + 1);
        } else {
          bidNumber = rest.split('-')[0];
          titlePart = rest.split('-').slice(1).join('-');
        }
      }
    } else {
      // CSPGCL bid numbers:
      const genMatch = rest.match(/^(CSPGCL-GEN-\d+)/i);
      if (genMatch) {
        bidNumber = genMatch[1];
        titlePart = rest.slice(genMatch[1].length).replace(/^-/, '');
      } else {
        const lastSlash = rest.lastIndexOf('/');
        if (lastSlash !== -1) {
          const prefix   = rest.substring(0, lastSlash);
          const afterSlash = rest.substring(lastSlash + 1);
          const dashIdx  = afterSlash.indexOf('-');
          const numPart  = dashIdx === -1 ? afterSlash : afterSlash.substring(0, dashIdx);
          bidNumber = `${prefix}/${numPart}`;
          titlePart = dashIdx === -1 ? '' : afterSlash.substring(dashIdx + 1);
        } else {
          const dashLower = rest.search(/-[a-z]/);
          if (dashLower === -1) {
            bidNumber = rest;
          } else {
            bidNumber = rest.substring(0, dashLower);
            titlePart = rest.substring(dashLower + 1);
          }
        }
      }
    }
  }

  try {
    fetchedTender = await fetchTenderDetailCached(source, bidNumber, Astro.locals) as Tender;
  } catch (e: unknown) {
    err = e instanceof Error ? e.message : String(e);
  }

  if (!fetchedTender) {
    return Astro.redirect('/404');
  }

  // Issue #3 — Slug normalisation redirect for broken CSPGCL slugs
  // Compute the canonical slug for this tender and 301 if it differs
  const canonicalPath = tenderDetailPath(fetchedTender);
  const canonicalSlug = canonicalPath.replace(/^\/tenders\//, '');
  if (canonicalSlug !== decodedSlug && canonicalSlug !== slug) {
    return Astro.redirect(canonicalPath, 301);
  }

  dl = daysLeft(fetchedTender.endDate);
  deadlineLabel = dl == null ? null
    : dl < 0 ? 'Closed'
    : dl === 0 ? 'Closes today'
    : `${dl} day${dl === 1 ? '' : 's'} left`;

  deadlineCls = dl == null ? '' : dl <= 0 ? 'text-red-600' : dl <= 7 ? 'text-amber-600' : 'text-green-600';

  pdfLink = fetchedTender.pdfPath ? documentUrl(fetchedTender.source, fetchedTender.bidNumber) : null;
  sourceLink = fetchedTender.bidLink || null;
  extractFields = (fetchedTender.sourceMeta?.pdfExtract?.fields as ExtractFields) || {};
  rawText = fetchedTender.sourceMeta?.pdfExtract?.text || null;
  hasExtraDetails = Object.keys(extractFields).length > 0 || !!rawText;

  // Issue #6 — Keyword-rich meta templates
  const districtLabel = fetchedTender.locationCity && fetchedTender.locationCity !== 'Unspecified'
    ? fetchedTender.locationCity
    : 'Chhattisgarh';
  const emdStr = fetchedTender.emdAmount ? ` EMD: ${formatRupee(fetchedTender.emdAmount)}.` : '';
  const closingStr = fetchedTender.endDate ? ` Closing ${formatDate(fetchedTender.endDate)}.` : '';

  pageTitle = `${fetchedTender.title.slice(0, 70)} — ${districtLabel}, Chhattisgarh | CGTenders.com`;
  metaDesc = `Open ${fetchedTender.source} tender: ${fetchedTender.title.slice(0, 80)}. Issued by ${fetchedTender.organization || fetchedTender.department || 'Government of Chhattisgarh'}.${closingStr}${emdStr} View full details on CGTenders.com.`;

  // Issue #6 — og:type = article for detail pages
  ogType = 'article';
  articlePublishedTime = fetchedTender.fetchedAt
    ? new Date(fetchedTender.fetchedAt).toISOString()
    : undefined;
  articleModifiedTime = fetchedTender.fetchedAt
    ? new Date(fetchedTender.fetchedAt).toISOString()
    : undefined;

  // Issue #7 — GovernmentService JSON-LD (improved)
  const govServiceLd = {
    '@context': 'https://schema.org',
    '@type': 'GovernmentService',
    name: fetchedTender.title,
    description: `${fetchedTender.organization || fetchedTender.department || ''} — Bid value: ${formatRupee(fetchedTender.bidValue)}, EMD: ${formatRupee(fetchedTender.emdAmount)}, closing ${formatDate(fetchedTender.endDate)}`,
    provider: {
      '@type': 'GovernmentOrganization',
      name: fetchedTender.organization || fetchedTender.department || 'Government of Chhattisgarh',
    },
    availabilityEnds: fetchedTender.endDate ? new Date(fetchedTender.endDate).toISOString() : undefined,
    areaServed: {
      '@type': 'Place',
      name: `${fetchedTender.locationCity || 'Chhattisgarh'}, Chhattisgarh, India`,
    },
    serviceType: fetchedTender.category?.join(', ') || 'Government Procurement',
    url: `https://cgtenders.com${tenderDetailPath(fetchedTender)}`,
  };

  // Issue #7 — BreadcrumbList JSON-LD for detail page
  const districtBreadcrumb = fetchedTender.locationCity && fetchedTender.locationCity !== 'Unspecified'
    ? {
        '@type': 'ListItem',
        position: 2,
        name: fetchedTender.locationCity,
        item: `https://cgtenders.com/tenders/${fetchedTender.locationCity.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`,
      }
    : null;

  const breadcrumbItems = [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cgtenders.com/' },
    ...(districtBreadcrumb ? [districtBreadcrumb] : []),
    {
      '@type': 'ListItem',
      position: districtBreadcrumb ? 3 : 2,
      name: fetchedTender.title.slice(0, 60),
      item: `https://cgtenders.com${tenderDetailPath(fetchedTender)}`,
    },
  ];

  const breadcrumbLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbItems,
  };

  // SEO â€” FAQPage JSON-LD: auto-generated Q&A for Google FAQ rich results
  const _issuer = fetchedTender.organization || fetchedTender.department || 'the issuing government body';
  const _location = fetchedTender.locationCity && fetchedTender.locationCity !== 'Unspecified'
    ? `${fetchedTender.locationCity}, Chhattisgarh`
    : 'Chhattisgarh, India';
  const _portal = fetchedTender.source === 'GEM'
    ? 'the GeM (Government e-Marketplace) portal at gem.gov.in'
    : 'the CSPGCL portal';
  const faqLd = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: `What is the closing date for the tender "${fetchedTender.title.slice(0, 80)}"?`,
        acceptedAnswer: {
          '@type': 'Answer',
          text: fetchedTender.endDate
            ? `The bid closing date is ${formatDate(fetchedTender.endDate)}. Vendors must submit their bids on ${_portal} before this deadline.`
            : `The closing date is not currently specified. Please check ${_portal} for the latest deadline information.`,
        },
      },
      {
        '@type': 'Question',
        name: 'What is the EMD (Earnest Money Deposit) required for this tender?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: fetchedTender.emdAmount
            ? `The Earnest Money Deposit (EMD) required is ${formatRupee(fetchedTender.emdAmount)}. This amount must be submitted along with the bid on ${_portal}.`
            : `The EMD amount is not specified. Please refer to the bid document available on ${_portal} for EMD requirements.`,
        },
      },
      {
        '@type': 'Question',
        name: 'Who has issued this tender?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: `This tender was issued by ${_issuer} via ${_portal}. It is a government procurement tender for ${_location}.`,
        },
      },
      {
        '@type': 'Question',
        name: 'What is the estimated bid value of this tender?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: fetchedTender.bidValue
            ? `The estimated bid value is ${formatRupee(fetchedTender.bidValue)} as listed on ${_portal}.`
            : `The estimated bid value is not publicly specified. Refer to the bid document on ${_portal} for more information.`,
        },
      },
      {
        '@type': 'Question',
        name: 'How can I apply for this tender?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: `To apply, visit ${_portal} and search for bid number ${fetchedTender.bidNumber}. Register as a vendor, download the bid document, review all terms and submit your bid electronically before ${fetchedTender.endDate ? formatDate(fetchedTender.endDate) : 'the closing date'}.`,
        },
      },
    ],
  };

  jsonLdItems = [govServiceLd, breadcrumbLd, faqLd];

  // Issue #9 — Fetch 3 related tenders (same district, or same category if Unspecified)
  try {
    const relatedParams = fetchedTender.locationCity && fetchedTender.locationCity !== 'Unspecified'
      ? { status: 'open', city: fetchedTender.locationCity, limit: 4 }
      : { status: 'open', source: fetchedTender.source, limit: 4 };
    const relatedData = await fetchTendersCached(relatedParams, Astro.locals);
    relatedTenders = (relatedData.tenders || [])
      .filter((t: Tender) => t.bidNumber !== fetchedTender!.bidNumber)
      .slice(0, 3);
  } catch (e: any) {
    // Non-fatal — just skip the section
  }
}

const tender = fetchedTender!;

// SSR tender list for city pages (first 20 for Googlebot)
const ssrTenders = isCityRoute ? (initialTenders || []).slice(0, 20) : [];

// PDF text citation extractor for risk analysis
function getCitation(risk: string, pdfText: string | null): string | null {
  if (!pdfText) return null;
  const lines = pdfText.split('\n');
  const cleanRisk = risk.toLowerCase();
  
  let keywords = [cleanRisk];
  if (cleanRisk.includes('closing') || cleanRisk.includes('deadline') || cleanRisk.includes('48 hours')) {
    keywords = ['bid end date', 'bid opening', 'date', 'deadline', 'submission'];
  } else if (cleanRisk.includes('emd') || cleanRisk.includes('earnest')) {
    keywords = ['emd amount', 'earnest', 'amount', 'deposit'];
  } else if (cleanRisk.includes('experience')) {
    keywords = ['experience', 'past performance', 'years'];
  } else if (cleanRisk.includes('exempt')) {
    keywords = ['mse exemption', 'startup exemption', 'exemption'];
  } else if (cleanRisk.includes('validity')) {
    keywords = ['validity', 'bid offer validity', 'days'];
  } else if (cleanRisk.includes('packet') || cleanRisk.includes('single')) {
    keywords = ['bid type', 'packet', 'single bid'];
  }

  for (const kw of keywords) {
    for (const line of lines) {
      if (line.toLowerCase().includes(kw)) {
        return line.trim();
      }
    }
  }
  
  const words = cleanRisk.split(' ').slice(0, 3).join(' ');
  if (words.length > 5) {
    for (const line of lines) {
      if (line.toLowerCase().includes(words)) {
        return line.trim();
      }
    }
  }
  return null;
}

const riskCount = tender.risks?.length ?? 0;
const riskLevel = riskCount <= 1 ? 'Low' : riskCount <= 3 ? 'Medium' : 'High';
const riskMeterColor = riskLevel === 'Low' ? 'text-emerald-500'
  : riskLevel === 'Medium' ? 'text-amber-500'
  : 'text-red-500';
---

<TenderLayout
  title={pageTitle}
  description={metaDesc}
  canonical={`/tenders/${slug}`}
  jsonLd={jsonLdItems}
  ogType={ogType}
  articlePublishedTime={articlePublishedTime}
  articleModifiedTime={articleModifiedTime}
>
  <Navbar />

  {isCityRoute ? (
    <main class="transition-colors duration-200">
      <div style="background:#0d1c2d;border-bottom:1px solid #424754;padding:20px 32px 18px;">
        <div style="max-width:1440px;margin:0 auto;">
          <!-- Issue #8 — HTML Breadcrumb -->
          <nav aria-label="Breadcrumb" style="margin-bottom:8px;">
            <ol style="display:flex;align-items:center;gap:6px;list-style:none;margin:0;padding:0;font-size:12px;color:#636878;">
              <li><a href="/" style="color:#636878;text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='#adc6ff'" onmouseout="this.style.color='#636878'">Home</a></li>
              <li aria-hidden="true" style="color:#424754;">›</li>
              <li style="color:#8c909f;font-weight:600;">{city}</li>
            </ol>
          </nav>
          <h1 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:800;font-size:28px;color:#d4e4fa;margin:0 0 4px;letter-spacing:-0.02em;">{city} Tenders</h1>
          <p style="font-size:13px;color:#8c909f;margin:0;">
            Open government tenders in {city} district, Chhattisgarh — sourced from GeM and CSPGCL portals.
          </p>
        </div>
      </div>

      <!-- Issue #1 — SSR tender list for district pages -->
      {ssrTenders.length > 0 && (
        <noscript>
          <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-2">
            <p class="text-xs text-gray-400 dark:text-slate-500 mb-4">{initialTotal.toLocaleString()} open tenders in {city} — showing first {ssrTenders.length}</p>
            <div class="flex flex-col gap-3">
              {ssrTenders.map((t: any) => (
                <TenderCard tender={t} />
              ))}
            </div>
          </section>
        </noscript>
      )}

      <TenderDashboard 
        client:load 
        initialCity={city} 
        initialTenders={initialTenders} 
        initialTotal={initialTotal} 
      />
    </main>
  ) : (
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 transition-colors duration-200">

      <!-- Issue #8 — HTML Breadcrumb (aria-label, all <a> links except last) -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-1.5 text-xs text-gray-400 flex-wrap">
          <li><a href="/" class="hover:text-[#1A56DB] dark:hover:text-blue-400 transition">Home</a></li>
          {tender.locationCity && tender.locationCity !== 'Unspecified' && (
            <>
              <li aria-hidden="true">›</li>
              <li>
                <a href={`/tenders/${tender.locationCity.toLowerCase().replace(/[^a-z0-9]+/g,'-')}`}
                  class="hover:text-[#1A56DB] dark:hover:text-blue-400 transition">{tender.locationCity}</a>
              </li>
            </>
          )}
          <li aria-hidden="true">›</li>
          <li class="text-gray-500 dark:text-slate-400 truncate max-w-[180px]">{tender.title.slice(0, 40)}{tender.title.length > 40 ? '…' : ''}</li>
        </ol>
      </nav>

      <!-- Header card -->
      <div class="bg-white dark:bg-slate-900 rounded-2xl border border-gray-200 dark:border-slate-800 shadow-sm p-6 md:p-8 mb-6">
        <div class="flex flex-wrap gap-2 mb-4">
          <span class={`px-2.5 py-1 rounded-md text-xs font-bold ${tender.source === 'GEM' ? 'bg-violet-50 text-violet-700 dark:bg-violet-950/60 dark:text-violet-400 border border-violet-100 dark:border-violet-900/40' : 'bg-amber-50 text-amber-700 dark:bg-amber-950/60 dark:text-amber-400 border border-amber-100 dark:border-amber-900/40'}`}>
            {tender.source}
          </span>
          {tender.status === 'open'
            ? <span class="px-2.5 py-1 rounded-md text-xs font-bold bg-green-50 text-green-700 dark:bg-emerald-950/60 dark:text-emerald-400 border border-green-100 dark:border-emerald-900/40">Open</span>
            : <span class="px-2.5 py-1 rounded-md text-xs font-bold bg-gray-100 text-gray-600 dark:bg-slate-850 dark:text-slate-400 border border-gray-200 dark:border-slate-800">Closed</span>
          }
          {tender.sourceMeta?.isEbidding && (
            <span class="px-2.5 py-1 rounded-md text-xs font-bold bg-blue-50 text-blue-600 dark:bg-blue-950/60 dark:text-blue-400 border border-blue-100 dark:border-blue-900/40">e-Bidding</span>
          )}
          {tender.category?.map((c: string) => (
            <span class="px-2.5 py-1 rounded-md text-xs bg-blue-50/60 text-blue-700 dark:bg-blue-950/40 dark:text-blue-400 font-bold border border-blue-100/50 dark:border-blue-900/30">{c}</span>
          ))}
        </div>

        <h1 class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white leading-snug mb-2 font-['Outfit']">
          {tender.title}
        </h1>
        {tender.organization && (
          <p class="text-sm text-gray-500 dark:text-slate-300 mb-1">{tender.organization}</p>
        )}
        {tender.department && tender.department !== tender.organization && (
          <p class="text-xs text-gray-400 dark:text-slate-400">{tender.department}</p>
        )}

        <!-- Deadline -->
        {deadlineLabel && (
          <div class={`mt-4 inline-flex items-center gap-1.5 text-sm font-semibold ${deadlineCls}`}>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {deadlineLabel}
          </div>
        )}
      </div>

      <!-- Key figures -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        {[
          { label: 'Bid Value', value: formatRupee(tender.bidValue), sub: tender.valueExtractionStatus === 'not_found' ? 'Not extracted from PDF' : null },
          { label: 'EMD Amount', value: formatRupee(tender.emdAmount), sub: null },
          { label: tender.source === 'GEM' ? 'Bid End Date' : 'Closing Date', value: formatDate(tender.endDate), sub: null },
          { label: tender.source === 'GEM' ? 'Bid Start Date' : 'Bid Opening Date', value: formatDate(tender.startDate), sub: null },
        ].map(({ label, value, sub }) => (
          <div class="bg-white dark:bg-slate-900 rounded-xl border border-gray-200 dark:border-slate-800 p-4">
            <p class="text-xs text-gray-400 dark:text-slate-500 mb-0.5">{label}</p>
            <p class={`text-base font-bold ${value === 'Not available' ? 'text-gray-400 dark:text-slate-600 text-sm' : 'text-gray-900 dark:text-white'}`}>
              {value}
            </p>
            {sub && <p class="text-xs text-gray-400 dark:text-slate-500 mt-0.5 italic">{sub}</p>}
          </div>
        ))}
      </div>

      <!-- Location & Bid number row -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-6">
        <div class="bg-white dark:bg-slate-900 rounded-xl border border-gray-200 dark:border-slate-800 p-4">
          <p class="text-xs text-gray-400 dark:text-slate-500 mb-0.5">District</p>
          <p class="text-sm font-semibold text-gray-900 dark:text-white">{tender.locationCity || 'Unspecified'}, Chhattisgarh</p>
        </div>
        <div class="bg-white dark:bg-slate-900 rounded-xl border border-gray-200 dark:border-slate-800 p-4">
          <p class="text-xs text-gray-400 dark:text-slate-500 mb-0.5">Bid / Notice Number</p>
