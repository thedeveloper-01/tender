---
import TenderLayout from '../../layouts/TenderLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import TenderDashboard from '../../components/TenderDashboard.jsx';
import TenderCard from '../../components/TenderCard.astro';
import { fetchTenderDetailCached, documentUrl, fetchTendersCached } from '../../lib/api.js';
import { formatRupee, formatDate, daysLeft, cityFromSlug, tenderDetailPath, titleSlug } from '../../lib/cities.js';

const { slug } = Astro.params as { slug: string };
const decodedSlug = decodeURIComponent(slug ?? '');

// Determine if it is a city/district route
const lowerSlug = decodedSlug.toLowerCase();
const city = lowerSlug === 'unspecified' ? 'Unspecified' : cityFromSlug(lowerSlug);
const isCityRoute = !!city;

type ExtractField = { label: string; value: string };
type ExtractFields = Record<string, ExtractField>;

interface Tender {
  id: string;
  source: string;
  bidNumber: string;
  title: string;
  department?: string | null;
  organization?: string | null;
  category?: string[];
  locationCity?: string | null;
  startDate?: string | null;
  endDate?: string | null;
  quantity?: string | null;
  bidValue?: number | null;
  emdAmount?: number | null;
  valueExtractionStatus?: string;
  viabilityScore?: number | null;
  risks?: string[];
  pdfPath?: string | null;
  bidLink?: string | null;
  status: string;
  fetchedAt: string;
  sourceMeta?: {
    isEbidding?: boolean;
    pdfExtract?: { fields?: ExtractFields; text?: string };
    [key: string]: unknown;
  } | null;
}

let fetchedTender: Tender | null = null;
let err: string | null = null;

let dl: number | null = null;
let deadlineLabel: string | null = null;
let deadlineCls = '';
let pdfLink: string | null = null;
let sourceLink: string | null = null;
let extractFields: ExtractFields = {};
let rawText: string | null = null;
let hasExtraDetails = false;
let jsonLdItems: object[] = [];
let pageTitle = '';
let metaDesc = '';
let ogType = 'website';
let articlePublishedTime: string | undefined;
let articleModifiedTime: string | undefined;

let initialTenders = null;
let initialTotal = 0;

// --- Related tenders for "More like this" section (detail pages only) ---
let relatedTenders: Tender[] = [];

if (isCityRoute) {
  const year = new Date().getFullYear();
  pageTitle = `${city} Government Tenders ${year} — GeM & CSPGCL | CGTenders.com`;
  metaDesc = `Browse open government tenders in ${city}, Chhattisgarh from GeM and CSPGCL portals. Filter by district, category and closing date. Updated daily.`;

  const breadcrumbLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cgtenders.com/' },
      { '@type': 'ListItem', position: 2, name: 'All Tenders', item: 'https://cgtenders.com/tenders' },
      { '@type': 'ListItem', position: 3, name: `${city} Tenders`, item: `https://cgtenders.com/tenders/${slug}` },
    ],
  };

  jsonLdItems = [
    {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: pageTitle,
      description: metaDesc,
      url: `https://cgtenders.com/tenders/${slug}`,
    },
    breadcrumbLd,
  ];

  try {
    const tendersData = await fetchTendersCached({ status: 'open', city, limit: 100 }, Astro.locals);
    initialTenders = tendersData.tenders || [];
    initialTotal = tendersData.total || 0;
  } catch (e: any) {
    console.error(`[city tenders SSR] error for ${city}:`, e.message);
  }
} else {
  // slug format:  <source>-<bidNumber>-<title-slug>
  // GEM example:  gem-GEM/2026/B/7179248-amc-of-security-system
  // CSPGCL:       cspgcl-CSPGCL-GEN-123456789-scope-of-work
  //
  // Strategy:
  //  1. Strip the source prefix (gem- or cspgcl-).
  //  2. GEM bids always contain '/' — read up to and including the last
  //     slash, then grab the numeric ID that follows (stopping at the
  //     first '-' which begins the title slug).
  //  3. CSPGCL bids look like "CSPGCL-GEN-<digits>" — match that prefix.
  let source = '';
  let bidNumber = '';
  let titlePart = '';

  const match = decodedSlug.match(/^(gem|cspgcl)-(.+)$/i);
  if (match) {
    source = match[1].toUpperCase();
    const rest = match[2];   // everything after "gem-" or "cspgcl-"

    if (source === 'GEM') {
      // GEM bid numbers contain slashes: GEM/2026/B/7179248
      const gemMatch = rest.match(/^(GEM\/\d{4}\/[A-Z]\/\d+)/i);
      if (gemMatch) {
        bidNumber = gemMatch[1];
        titlePart = rest.slice(gemMatch[1].length).replace(/^-/, '');
      } else {
        const lastSlash = rest.lastIndexOf('/');
        if (lastSlash !== -1) {
          const prefix   = rest.substring(0, lastSlash);
          const afterSlash = rest.substring(lastSlash + 1);
          const dashIdx  = afterSlash.indexOf('-');
          const numPart  = dashIdx === -1 ? afterSlash : afterSlash.substring(0, dashIdx);
          bidNumber = `${prefix}/${numPart}`;
          titlePart = dashIdx === -1 ? '' : afterSlash.substring(dashIdx + 1);
        } else {
          bidNumber = rest.split('-')[0];
          titlePart = rest.split('-').slice(1).join('-');
        }
      }
    } else {
      // CSPGCL bid numbers:
      const genMatch = rest.match(/^(CSPGCL-GEN-\d+)/i);
      if (genMatch) {
        bidNumber = genMatch[1];
        titlePart = rest.slice(genMatch[1].length).replace(/^-/, '');
      } else {
        const lastSlash = rest.lastIndexOf('/');
        if (lastSlash !== -1) {
          const prefix   = rest.substring(0, lastSlash);
          const afterSlash = rest.substring(lastSlash + 1);
          const dashIdx  = afterSlash.indexOf('-');
          const numPart  = dashIdx === -1 ? afterSlash : afterSlash.substring(0, dashIdx);
          bidNumber = `${prefix}/${numPart}`;
          titlePart = dashIdx === -1 ? '' : afterSlash.substring(dashIdx + 1);
        } else {
          const dashLower = rest.search(/-[a-z]/);
          if (dashLower === -1) {
            bidNumber = rest;
          } else {
            bidNumber = rest.substring(0, dashLower);
            titlePart = rest.substring(dashLower + 1);
          }
        }
      }
    }
  }

  try {
    fetchedTender = await fetchTenderDetailCached(source, bidNumber, Astro.locals) as Tender;
  } catch (e: unknown) {
    err = e instanceof Error ? e.message : String(e);
  }

  if (!fetchedTender) {
    return Astro.redirect('/404');
  }

  // Issue #3 — Slug normalisation redirect for broken CSPGCL slugs
  // Compute the canonical slug for this tender and 301 if it differs
  const canonicalPath = tenderDetailPath(fetchedTender);
  const canonicalSlug = canonicalPath.replace(/^\/tenders\//, '');
  if (canonicalSlug !== decodedSlug && canonicalSlug !== slug) {
    return Astro.redirect(canonicalPath, 301);
  }

  dl = daysLeft(fetchedTender.endDate);
  deadlineLabel = dl == null ? null
    : dl < 0 ? 'Closed'
    : dl === 0 ? 'Closes today'
    : `${dl} day${dl === 1 ? '' : 's'} left`;

  deadlineCls = dl == null ? '' : dl <= 0 ? 'text-red-600' : dl <= 7 ? 'text-amber-600' : 'text-green-600';

  pdfLink = fetchedTender.pdfPath ? documentUrl(fetchedTender.source, fetchedTender.bidNumber) : null;
  sourceLink = fetchedTender.bidLink || null;
  extractFields = (fetchedTender.sourceMeta?.pdfExtract?.fields as ExtractFields) || {};
  rawText = fetchedTender.sourceMeta?.pdfExtract?.text || null;
  hasExtraDetails = Object.keys(extractFields).length > 0 || !!rawText;

  // Issue #6 — Keyword-rich meta templates
  const districtLabel = fetchedTender.locationCity && fetchedTender.locationCity !== 'Unspecified'
    ? fetchedTender.locationCity
    : 'Chhattisgarh';
  const emdStr = fetchedTender.emdAmount ? ` EMD: ${formatRupee(fetchedTender.emdAmount)}.` : '';
  const closingStr = fetchedTender.endDate ? ` Closing ${formatDate(fetchedTender.endDate)}.` : '';

  pageTitle = `${fetchedTender.title.slice(0, 70)} — ${districtLabel}, Chhattisgarh | CGTenders.com`;
  metaDesc = `Open ${fetchedTender.source} tender: ${fetchedTender.title.slice(0, 80)}. Issued by ${fetchedTender.organization || fetchedTender.department || 'Government of Chhattisgarh'}.${closingStr}${emdStr} View full details on CGTenders.com.`;

  // Issue #6 — og:type = article for detail pages
  ogType = 'article';
  articlePublishedTime = fetchedTender.fetchedAt
    ? new Date(fetchedTender.fetchedAt).toISOString()
    : undefined;
  articleModifiedTime = fetchedTender.fetchedAt
    ? new Date(fetchedTender.fetchedAt).toISOString()
    : undefined;

  // Issue #7 — GovernmentService JSON-LD (improved)
  const govServiceLd = {
    '@context': 'https://schema.org',
    '@type': 'GovernmentService',
    name: fetchedTender.title,
    description: `${fetchedTender.organization || fetchedTender.department || ''} — Bid value: ${formatRupee(fetchedTender.bidValue)}, EMD: ${formatRupee(fetchedTender.emdAmount)}, closing ${formatDate(fetchedTender.endDate)}`,
    provider: {
      '@type': 'GovernmentOrganization',
      name: fetchedTender.organization || fetchedTender.department || 'Government of Chhattisgarh',
    },
    availabilityEnds: fetchedTender.endDate ? new Date(fetchedTender.endDate).toISOString() : undefined,
    areaServed: {
      '@type': 'Place',
      name: `${fetchedTender.locationCity || 'Chhattisgarh'}, Chhattisgarh, India`,
    },
    serviceType: fetchedTender.category?.join(', ') || 'Government Procurement',
    url: `https://cgtenders.com${tenderDetailPath(fetchedTender)}`,
  };

  // Issue #7 — BreadcrumbList JSON-LD for detail page
  const districtBreadcrumb = fetchedTender.locationCity && fetchedTender.locationCity !== 'Unspecified'
    ? {
        '@type': 'ListItem',
        position: 3,
        name: fetchedTender.locationCity,
        item: `https://cgtenders.com/tenders/${fetchedTender.locationCity.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`,
      }
    : null;

  const breadcrumbItems = [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cgtenders.com/' },
    { '@type': 'ListItem', position: 2, name: 'All Tenders', item: 'https://cgtenders.com/tenders' },
    ...(districtBreadcrumb ? [districtBreadcrumb] : []),
    {
      '@type': 'ListItem',
      position: districtBreadcrumb ? 4 : 3,
      name: fetchedTender.title.slice(0, 60),
      item: `https://cgtenders.com${tenderDetailPath(fetchedTender)}`,
    },
  ];

  const breadcrumbLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbItems,
  };

  jsonLdItems = [govServiceLd, breadcrumbLd];

  // Issue #9 — Fetch 3 related tenders (same district, or same category if Unspecified)
  try {
    const relatedParams = fetchedTender.locationCity && fetchedTender.locationCity !== 'Unspecified'
      ? { status: 'open', city: fetchedTender.locationCity, limit: 4 }
      : { status: 'open', source: fetchedTender.source, limit: 4 };
    const relatedData = await fetchTendersCached(relatedParams, Astro.locals);
    relatedTenders = (relatedData.tenders || [])
      .filter((t: Tender) => t.bidNumber !== fetchedTender!.bidNumber)
      .slice(0, 3);
  } catch (e: any) {
    // Non-fatal — just skip the section
  }
}

const tender = fetchedTender!;

// SSR tender list for city pages (first 20 for Googlebot)
const ssrTenders = isCityRoute ? (initialTenders || []).slice(0, 20) : [];
---

<TenderLayout
  title={pageTitle}
  description={metaDesc}
  canonical={`/tenders/${slug}`}
  jsonLd={jsonLdItems}
  ogType={ogType}
  articlePublishedTime={articlePublishedTime}
  articleModifiedTime={articleModifiedTime}
>
  <Navbar />

  {isCityRoute ? (
    <main>
      <div class="bg-white border-b border-gray-100 py-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <!-- Issue #8 — HTML Breadcrumb -->
          <nav aria-label="Breadcrumb" class="mb-2">
            <ol class="flex items-center gap-1.5 text-xs text-gray-400">
              <li><a href="/" class="hover:text-[#1A56DB] transition">Home</a></li>
              <li aria-hidden="true">›</li>
              <li><a href="/tenders" class="hover:text-[#1A56DB] transition">All Tenders</a></li>
              <li aria-hidden="true">›</li>
              <li class="text-gray-600 font-medium">{city}</li>
            </ol>
          </nav>
          <h1 class="text-2xl md:text-3xl font-bold text-gray-900 font-['Outfit']">{city} Tenders</h1>
          <p class="text-sm text-gray-500 mt-1">
            Open government tenders in {city} district, Chhattisgarh — sourced from GeM and CSPGCL portals.
          </p>
        </div>
      </div>

      <!-- Issue #1 — SSR tender list for district pages -->
      {ssrTenders.length > 0 && (
        <noscript>
          <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-2">
            <p class="text-xs text-gray-400 mb-4">{initialTotal.toLocaleString()} open tenders in {city} — showing first {ssrTenders.length}</p>
            <div class="flex flex-col gap-3">
              {ssrTenders.map((t: any) => (
                <TenderCard tender={t} />
              ))}
            </div>
          </section>
        </noscript>
      )}

      <TenderDashboard 
        client:load 
        initialCity={city} 
        initialTenders={initialTenders} 
        initialTotal={initialTotal} 
      />
    </main>
  ) : (
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

      <!-- Issue #8 — HTML Breadcrumb (aria-label, all <a> links except last) -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-1.5 text-xs text-gray-400 flex-wrap">
          <li><a href="/tenders" class="hover:text-[#1A56DB] transition">All Tenders</a></li>
          {tender.locationCity && tender.locationCity !== 'Unspecified' && (
            <>
              <li aria-hidden="true">›</li>
              <li>
                <a href={`/tenders/${tender.locationCity.toLowerCase().replace(/[^a-z0-9]+/g,'-')}`}
                  class="hover:text-[#1A56DB] transition">{tender.locationCity}</a>
              </li>
            </>
          )}
          <li aria-hidden="true">›</li>
          <li class="text-gray-500 truncate max-w-[180px]">{tender.title.slice(0, 40)}{tender.title.length > 40 ? '…' : ''}</li>
        </ol>
      </nav>

      <!-- Header card -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 md:p-8 mb-6">
        <div class="flex flex-wrap gap-2 mb-4">
          <span class={`px-2.5 py-1 rounded-md text-xs font-bold ${tender.source === 'GEM' ? 'bg-violet-100 text-violet-700' : 'bg-amber-100 text-amber-700'}`}>
            {tender.source}
          </span>
          {tender.status === 'open'
            ? <span class="px-2.5 py-1 rounded-md text-xs font-bold bg-green-100 text-green-700">Open</span>
            : <span class="px-2.5 py-1 rounded-md text-xs font-bold bg-gray-100 text-gray-600">Closed</span>
          }
          {tender.sourceMeta?.isEbidding && (
            <span class="px-2.5 py-1 rounded-md text-xs font-medium bg-blue-50 text-blue-600">e-Bidding</span>
          )}
          {tender.category?.map((c: string) => (
            <span class="px-2.5 py-1 rounded-md text-xs bg-blue-50 text-blue-700 font-medium">{c}</span>
          ))}
        </div>

        <h1 class="text-xl md:text-2xl font-bold text-gray-900 leading-snug mb-2 font-['Outfit']">
          {tender.title}
        </h1>
        {tender.organization && (
          <p class="text-sm text-gray-500 mb-1">{tender.organization}</p>
        )}
        {tender.department && tender.department !== tender.organization && (
          <p class="text-xs text-gray-400">{tender.department}</p>
        )}

        <!-- Deadline -->
        {deadlineLabel && (
          <div class={`mt-4 inline-flex items-center gap-1.5 text-sm font-semibold ${deadlineCls}`}>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {deadlineLabel}
          </div>
        )}
      </div>

      <!-- Key figures -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        {[
          { label: 'Bid Value', value: formatRupee(tender.bidValue), sub: tender.valueExtractionStatus === 'not_found' ? 'Not extracted from PDF' : null },
          { label: 'EMD Amount', value: formatRupee(tender.emdAmount), sub: null },
          { label: tender.source === 'GEM' ? 'Bid End Date' : 'Closing Date', value: formatDate(tender.endDate), sub: null },
          { label: tender.source === 'GEM' ? 'Bid Start Date' : 'Bid Opening Date', value: formatDate(tender.startDate), sub: null },
        ].map(({ label, value, sub }) => (
          <div class="bg-white rounded-xl border border-gray-200 p-4">
            <p class="text-xs text-gray-400 mb-0.5">{label}</p>
            <p class={`text-base font-bold ${value === 'Not available' ? 'text-gray-400 text-sm' : 'text-gray-900'}`}>
              {value}
            </p>
            {sub && <p class="text-xs text-gray-400 mt-0.5 italic">{sub}</p>}
          </div>
        ))}
      </div>

      <!-- Location & Bid number row -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-6">
        <div class="bg-white rounded-xl border border-gray-200 p-4">
          <p class="text-xs text-gray-400 mb-0.5">District</p>
          <p class="text-sm font-semibold text-gray-900">{tender.locationCity || 'Unspecified'}, Chhattisgarh</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-4">
          <p class="text-xs text-gray-400 mb-0.5">Bid / Notice Number</p>
          <p class="text-sm font-semibold text-gray-900 break-all">{tender.bidNumber}</p>
        </div>
        {tender.quantity && (
          <div class="bg-white rounded-xl border border-gray-200 p-4">
            <p class="text-xs text-gray-400 mb-0.5">Quantity</p>
            <p class="text-sm font-semibold text-gray-900">{tender.quantity}</p>
          </div>
        )}
      </div>

      <!-- Risks -->
      {(tender.risks?.length ?? 0) > 0 && (
        <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-6">
          <p class="text-xs text-gray-400 mb-2 font-semibold">Risk Flags</p>
          <div class="flex flex-wrap gap-1.5">
            {tender.risks!.map((r: string) => (
              <span class="text-xs bg-red-50 text-red-700 border border-red-100 px-2.5 py-1 rounded-full font-medium">{r}</span>
            ))}
          </div>
        </div>
      )}

      <!-- Action buttons -->
      <div class="flex flex-wrap gap-3 mb-6">
        {pdfLink && (
          <a href={pdfLink} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#1A56DB] text-white rounded-xl text-sm font-semibold hover:bg-blue-700 transition shadow">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414A1 1 0 0121 9.414V19a2 2 0 01-2 2z"/>
            </svg>
            View Bid Document (PDF)
          </a>
        )}
        {!pdfLink && (
          <span class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-100 text-gray-400 rounded-xl text-sm font-semibold cursor-not-allowed">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414A1 1 0 0121 9.414V19a2 2 0 01-2 2z"/>
            </svg>
            PDF Not Available
          </span>
        )}
        {sourceLink && (
          <a href={sourceLink} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-xl text-sm font-semibold hover:border-[#1A56DB] hover:text-[#1A56DB] transition">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            View on {tender.source === 'GEM' ? 'GeM Portal' : 'CSPGCL Portal'}
          </a>
        )}
      </div>

      <!-- View More Details expander -->
      {hasExtraDetails && (
        <details class="bg-white rounded-2xl border border-gray-200 shadow-sm group">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none select-none">
            <span class="font-semibold text-gray-900 text-sm">View More Details</span>
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>

          <div class="px-6 pb-6 border-t border-gray-100 pt-4 space-y-6">

            <!-- Extracted fields table -->
            {Object.keys(extractFields).length > 0 && (
              <div>
                <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3">Extracted from Bid Document</h3>
                <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3">
                  {Object.entries(extractFields).map(([key, field]: [string, ExtractField]) => (
                    <div class="border-b border-gray-50 pb-2">
                      <dt class="text-xs text-gray-400">{field.label}</dt>
                      <dd class="text-sm font-medium text-gray-800 mt-0.5">{field.value}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )}

            <!-- Raw PDF text excerpt -->
            {rawText && (
              <div>
                <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3">Raw Document Excerpt</h3>
                <pre class="text-xs text-gray-600 bg-gray-50 rounded-xl p-4 overflow-x-auto whitespace-pre-wrap leading-relaxed max-h-72 overflow-y-auto">{rawText}</pre>
              </div>
            )}

            {!Object.keys(extractFields).length && !rawText && (
              <p class="text-sm text-gray-400 italic">No additional data could be extracted from the bid document.</p>
            )}
          </div>
        </details>
      )}

      <!-- Fetched at -->
      <p class="text-xs text-gray-400 mt-6 text-center">
        Last updated: {formatDate(tender.fetchedAt)} · Data sourced from official government portals
      </p>

      <!-- Issue #9 — "More tenders like this" — SSR HTML, crawlable by Googlebot -->
      {relatedTenders.length > 0 && (
        <section class="mt-10 pt-8 border-t border-gray-100">
          <h2 class="text-base font-bold text-gray-900 font-['Outfit'] mb-4">
            More Tenders Like This
          </h2>
          <ul class="space-y-3">
            {relatedTenders.map((rt: Tender) => (
              <li class="bg-white border border-gray-200 rounded-xl px-4 py-3 hover:border-[#1A56DB]/40 transition">
                <a href={tenderDetailPath(rt)} class="group">
                  <p class="text-sm font-semibold text-gray-900 group-hover:text-[#1A56DB] transition line-clamp-2 mb-1">{rt.title}</p>
                  <div class="flex items-center gap-3 text-xs text-gray-400">
                    <span class={`px-1.5 py-0.5 rounded text-xs font-bold ${rt.source === 'GEM' ? 'bg-violet-100 text-violet-700' : 'bg-amber-100 text-amber-700'}`}>{rt.source}</span>
                    {rt.locationCity && <span>{rt.locationCity}</span>}
                    {rt.endDate && <span>Closes {formatDate(rt.endDate)}</span>}
                  </div>
                </a>
              </li>
            ))}
          </ul>
          {tender.locationCity && tender.locationCity !== 'Unspecified' ? (
            <a href={`/tenders/${tender.locationCity.toLowerCase().replace(/[^a-z0-9]+/g,'-')}`}
              class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-[#1A56DB] hover:underline">
              View all {tender.locationCity} tenders →
            </a>
          ) : (
            <a href="/tenders" class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-[#1A56DB] hover:underline">
              View all tenders →
            </a>
          )}
        </section>
      )}
    </main>
  )}

  <Footer />
</TenderLayout>
