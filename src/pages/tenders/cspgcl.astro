---
import TenderLayout from '../../layouts/TenderLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import TenderDashboard from '../../components/TenderDashboard.jsx';
import TenderCard from '../../components/TenderCard.astro';
import { fetchStatsCached, fetchTendersCached } from '../../lib/api.js';

let stats: { totalOpenTenders: number; totalEstimatedValue: number; bySource: Record<string, number>; lastFetchAt: string | null } = { totalOpenTenders: 0, totalEstimatedValue: 0, bySource: {}, lastFetchAt: null };
let initialTenders = null;
let initialTotal = 0;

try {
  const [statsData, tendersData] = await Promise.all([
    fetchStatsCached(Astro.locals),
    fetchTendersCached({ status: 'open', source: 'CSPGCL', limit: 100 }, Astro.locals)
  ]);
  stats = statsData;
  initialTenders = tendersData.tenders || [];
  initialTotal = tendersData.total || 0;
} catch (e: any) {
  console.error('[tenders-cspgcl] SSR fetch error:', e.message);
}

const lastUpdated = stats.lastFetchAt
  ? new Date(stats.lastFetchAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })
  : null;

const cspgclCount = stats.bySource?.CSPGCL || initialTotal || 0;

// Issue #6 — keyword-rich meta
const year = new Date().getFullYear();
const metaTitle = `CSPGCL Tenders Chhattisgarh ${year} - Power Sector Open Procurement | CGTenders.com`;
const metaDesc = `Browse ${cspgclCount} open CSPGCL tender notices in Chhattisgarh ${year}. Power sector, infrastructure & supply bids. Filter by plant, district & closing date. Updated daily.`;

// Issue #7 — BreadcrumbList JSON-LD
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cgtenders.com/' },
    { '@type': 'ListItem', position: 2, name: 'All Tenders', item: 'https://cgtenders.com/tenders' },
    { '@type': 'ListItem', position: 3, name: 'CSPGCL Tenders', item: 'https://cgtenders.com/tenders/cspgcl' },
  ],
};

// SSR tender list (first 20 for Googlebot)
const ssrTenders = (initialTenders || []).slice(0, 20);
---

<TenderLayout
  title={metaTitle}
  description={metaDesc}
  canonical="/tenders/cspgcl"
  jsonLd={breadcrumbLd}
>
  <Navbar />
  <main>
    <!-- Issue #8 — HTML Breadcrumb -->
    <nav aria-label="Breadcrumb" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
      <ol class="flex items-center gap-1.5 text-xs text-gray-400">
        <li><a href="/" class="hover:text-[#1A56DB] transition">Home</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/tenders" class="hover:text-[#1A56DB] transition">All Tenders</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-gray-600 font-medium">CSPGCL Tenders</li>
      </ol>
    </nav>

    <div class="bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 md:py-6">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
          <div>
            <h1 class="text-2xl md:text-3xl font-bold text-gray-900 font-['Outfit']">CSPGCL Tenders</h1>
            <p class="text-sm text-gray-500 mt-0.5">
              Chhattisgarh State Power Generation Company open tenders
              {lastUpdated && <span class="text-gray-400"> · Updated {lastUpdated}</span>}
            </p>
          </div>
          <div class="flex items-center gap-3 flex-wrap">
            <div class="flex items-center gap-2 bg-amber-50 border border-amber-100 rounded-xl px-3 py-2">
              <span class="text-xl font-extrabold text-amber-700 font-['Outfit'] leading-none">{cspgclCount}</span>
              <span class="text-xs text-amber-600 font-medium leading-tight">CSPGCL Tenders<br/>Open</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- SSR tender list — always rendered in HTML so Googlebot indexes real content -->
    {ssrTenders.length > 0 && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-2" id="ssr-cspgcl-list">
        <p class="text-xs text-gray-400 dark:text-slate-500 mb-4">{initialTotal.toLocaleString()} open CSPGCL tenders in Chhattisgarh — showing first {ssrTenders.length}</p>
        <div class="flex flex-col gap-3">
          {ssrTenders.map((t: any) => (
            <TenderCard tender={t} />
          ))}
        </div>
        {initialTotal > ssrTenders.length && (
          <p class="text-xs text-gray-400 dark:text-slate-500 mt-3 text-center">Showing {ssrTenders.length} of {initialTotal.toLocaleString()} CSPGCL tenders — use filters below to narrow results</p>
        )}
      </section>
    )}

    <!-- JS-hydrated dashboard -->
    <TenderDashboard 
      client:load 
      initialSource="CSPGCL" 
      initialTenders={initialTenders} 
      initialTotal={initialTotal} 
    />
  </main>
  <Footer />
</TenderLayout>
