---
import TenderLayout from '../../layouts/TenderLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import TenderDashboard from '../../components/TenderDashboard.jsx';
---

<TenderLayout
  title="GeM Tenders — CGTenders.com"
  description="Search and filter open GeM tenders in Chhattisgarh. Filter by district, category, bid value, EMD, and closing date."
  canonical="/tenders/gem"
>
  <Navbar />
  <main>
    <div class="bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 md:py-6">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
          <div>
            <h1 class="text-2xl md:text-3xl font-bold text-gray-900 font-['Outfit']">GeM Tenders</h1>
            <p class="text-sm text-gray-500 mt-0.5">
              Government e-Marketplace open tenders in Chhattisgarh
              <span id="stats-updated" class="text-gray-400"></span>
            </p>
          </div>
          <div class="flex items-center gap-3 flex-wrap">
            <div class="flex items-center gap-2 bg-violet-50 border border-violet-100 rounded-xl px-3 py-2">
              <span id="stat-gem" class="text-xl font-extrabold text-violet-700 font-['Outfit'] leading-none">...</span>
              <span class="text-xs text-violet-600 font-medium leading-tight">GeM Tenders<br/>Open</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <TenderDashboard client:load initialSource="GEM" />
  </main>
  <Footer />
</TenderLayout>

<script define:vars={{ apiBase: import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:4000' }}>
  async function loadStats() {
    try {
      const res = await fetch(`${apiBase}/api/stats`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const stats = await res.json();
      
      document.getElementById('stat-gem').textContent = stats.bySource?.GEM || 0;
      
      if (stats.lastFetchAt) {
        const lastUpdated = new Date(stats.lastFetchAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
        document.getElementById('stats-updated').textContent = ` · Updated ${lastUpdated}`;
      }
    } catch (e) {
      console.error('[tenders-gem] stats fetch error:', e);
    }
  }
  loadStats();
</script>
