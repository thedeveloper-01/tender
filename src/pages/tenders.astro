---
import TenderLayout from '../layouts/TenderLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import TenderDashboard from '../components/TenderDashboard.jsx';
import { fetchStatsCached } from '../lib/api.js';
import { formatRupee } from '../lib/cities.js';

let stats: { totalOpenTenders: number; totalEstimatedValue: number; bySource: Record<string, number>; lastFetchAt: string | null } = { totalOpenTenders: 0, totalEstimatedValue: 0, bySource: {}, lastFetchAt: null };
try {
  stats = await fetchStatsCached(Astro.locals.runtime);
} catch (e) {
  console.error('[tenders] stats error:', (e as Error).message);
}

const lastUpdated = stats.lastFetchAt
  ? new Date(stats.lastFetchAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })
  : null;
---

<TenderLayout
  title="All Tenders — CGTenders.com"
  description="Search and filter all open government tenders from GeM and CSPGCL portals in Chhattisgarh. Filter by district, category, bid value, EMD, and closing date."
  canonical="/tenders"
>
  <Navbar />
  <main>
    <div class="bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 md:py-6">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
          <div>
            <h1 class="text-2xl md:text-3xl font-bold text-gray-900 font-['Outfit']">All Tenders</h1>
            <p class="text-sm text-gray-500 mt-0.5">
              GeM and CSPGCL open tenders in Chhattisgarh
              {lastUpdated && <span class="text-gray-400"> · Updated {lastUpdated}</span>}
            </p>
          </div>
          <div class="flex items-center gap-3 flex-wrap">
            <div class="flex items-center gap-2 bg-blue-50 border border-blue-100 rounded-xl px-3 py-2">
              <span class="text-xl font-extrabold text-[#1A56DB] font-['Outfit'] leading-none">{stats.totalOpenTenders}</span>
              <span class="text-xs text-blue-600 font-medium leading-tight">Open<br/>Tenders</span>
            </div>
            <div class="flex items-center gap-2 bg-violet-50 border border-violet-100 rounded-xl px-3 py-2">
              <span class="text-xl font-extrabold text-violet-700 font-['Outfit'] leading-none">{stats.bySource?.GEM || 0}</span>
              <span class="text-xs text-violet-600 font-medium leading-tight">GeM</span>
            </div>
            <div class="flex items-center gap-2 bg-amber-50 border border-amber-100 rounded-xl px-3 py-2">
              <span class="text-xl font-extrabold text-amber-700 font-['Outfit'] leading-none">{stats.bySource?.CSPGCL || 0}</span>
              <span class="text-xs text-amber-600 font-medium leading-tight">CSPGCL</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Static skeleton shown while React hydrates (client:idle) -->
    <div id="dashboard-shell" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Toolbar skeleton -->
      <div class="flex gap-3 mb-6">
        <div class="h-10 bg-gray-100 rounded-xl flex-1 animate-pulse"></div>
        <div class="h-10 w-44 bg-gray-100 rounded-xl animate-pulse"></div>
      </div>
      <div class="flex gap-6 items-start">
        <!-- Sidebar skeleton -->
        <aside class="hidden lg:block w-64 xl:w-72 flex-shrink-0">
          <div class="bg-white border border-gray-200 rounded-2xl p-5 space-y-4">
            {[56, 44, 32, 44, 56].map((w, i) => (
              <div class={`h-4 bg-gray-100 rounded animate-pulse`} style={`width:${w}%`}></div>
            ))}
          </div>
        </aside>
        <!-- Cards skeleton -->
        <div class="flex-1 grid grid-cols-1 xl:grid-cols-2 gap-4">
          {Array.from({length: 6}).map((_, i) => (
            <div class="bg-white rounded-2xl border border-gray-200 p-5 h-40 animate-pulse space-y-3">
              <div class="flex gap-2">
                <div class="h-5 w-10 bg-gray-100 rounded-md"></div>
                <div class="h-5 w-16 bg-gray-100 rounded-md"></div>
                <div class="ml-auto h-5 w-14 bg-gray-100 rounded-full"></div>
              </div>
              <div class="h-4 bg-gray-100 rounded w-5/6"></div>
              <div class="h-3 bg-gray-100 rounded w-3/4"></div>
              <div class="grid grid-cols-2 gap-2 pt-1">
                <div class="h-3 bg-gray-100 rounded"></div>
                <div class="h-3 bg-gray-100 rounded"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
    <TenderDashboard client:idle />
    <script>
      // Hide skeleton once React dashboard has rendered its first real content
      (function () {
        const shell = document.getElementById('dashboard-shell');
        if (!shell) return;
        const observer = new MutationObserver(() => {
          // Only hide when TenderCard <article> elements appear — not the skeleton divs
          if (document.body.querySelector('article')) {
            shell.style.display = 'none';
            observer.disconnect();
          }
        });
        observer.observe(document.body, { childList: true, subtree: true });
        // Safety: hide after 6s regardless
        setTimeout(() => { shell.style.display = 'none'; observer.disconnect(); }, 6000);
      })();
    </script>
  </main>
  <Footer />
</TenderLayout>
