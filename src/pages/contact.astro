---
import TenderLayout from '../layouts/TenderLayout.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

const title = 'Contact Us | CGTenders.com';
const description = 'Get in touch with our team. We are here to help with any questions or support you may need.';
---

<TenderLayout {title} {description}>
  <Navbar />
  <div style="max-width:1200px;margin:0 auto;padding:48px 32px 64px;color:#c2c6d6;font-family:'Inter',sans-serif;">
    <div style="max-width:800px;margin:0 auto;">
      <!-- Header -->
      <div style="margin-bottom:36px;">
        <a href="/" style="display:inline-flex;align-items:center;gap:8px;color:#adc6ff;text-decoration:none;font-size:14px;font-weight:600;transition:color 0.15s;" onmouseover="this.style.color='#d8e2ff'" onmouseout="this.style.color='#adc6ff'">
          <svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Dashboard
        </a>
        <h1 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:800;font-size:36px;color:#d4e4fa;margin:16px 0 6px;letter-spacing:-0.02em;">Contact Us</h1>
        <p style="font-size:15px;color:#8c909f;margin:0;">We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));gap:16px;margin-bottom:40px;">
        <!-- Contact Info Cards -->
        <div style="background:#122131;border:1px solid #424754;border-radius:6px;padding:24px;">
          <div style="width:40px;height:40px;background:rgba(173,198,255,0.08);border-radius:6px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
            <svg style="width:20px;height:20px;color:#adc6ff;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#d4e4fa;margin:0 0 4px;">Email</h3>
          <p style="font-size:13px;color:#8c909f;margin:0 0 12px;">For general inquiries</p>
          <a href="mailto:info@cgtenders.com" style="color:#adc6ff;text-decoration:none;font-weight:600;font-size:13px;transition:color 0.15s;" onmouseover="this.style.color='#d8e2ff'" onmouseout="this.style.color='#adc6ff'">
            info@cgtenders.com
          </a>
        </div>

        <div style="background:#122131;border:1px solid #424754;border-radius:6px;padding:24px;">
          <div style="width:40px;height:40px;background:rgba(78,222,163,0.06);border-radius:6px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
            <svg style="width:20px;height:20px;color:#4edea3;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#d4e4fa;margin:0 0 4px;">Support</h3>
          <p style="font-size:13px;color:#8c909f;margin:0 0 12px;">Technical &amp; data support</p>
          <a href="mailto:support@cgtenders.com" style="color:#4edea3;text-decoration:none;font-weight:600;font-size:13px;transition:color 0.15s;" onmouseover="this.style.color='#76ecc0'" onmouseout="this.style.color='#4edea3'">
            support@cgtenders.com
          </a>
        </div>

        <div style="background:#122131;border:1px solid #424754;border-radius:6px;padding:24px;">
          <div style="width:40px;height:40px;background:rgba(255,183,134,0.06);border-radius:6px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
            <svg style="width:20px;height:20px;color:#ffb786;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#d4e4fa;margin:0 0 4px;">Location</h3>
          <p style="font-size:13px;color:#8c909f;margin:0;">
            CGTenders Head Office<br/>
            Central India
          </p>
        </div>
      </div>

      <!-- Contact Form -->
      <div style="background:#122131;border:1px solid #424754;border-radius:6px;padding:32px;margin-bottom:32px;">
        <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:800;font-size:22px;color:#d4e4fa;margin:0 0 24px;">Send us a Message</h2>
        
        <form style="display:flex;flex-direction:column;gap:20px;">
          <!-- Name Field -->
          <div>
            <label for="name" style="display:block;font-size:13px;font-weight:700;color:#8c909f;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.05em;">
              Full Name
            </label>
            <input 
              type="text" 
              id="name" 
              name="name"
              required
              style="width:100%;padding:10px 14px;background:var(--surface-container);border:1px solid var(--outline-variant);border-radius:4px;color:var(--on-surface);font-size:14px;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='var(--primary)'"
              onblur="this.style.borderColor='var(--outline-variant)'"
              placeholder="Your full name"
            />
          </div>

          <!-- Email Field -->
          <div>
            <label for="email" style="display:block;font-size:13px;font-weight:700;color:var(--outline);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.05em;">
              Email Address
            </label>
            <input 
              type="email" 
              id="email" 
              name="email"
              required
              style="width:100%;padding:10px 14px;background:var(--surface-container);border:1px solid var(--outline-variant);border-radius:4px;color:var(--on-surface);font-size:14px;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='var(--primary)'"
              onblur="this.style.borderColor='var(--outline-variant)'"
              placeholder="your.email@company.com"
            />
          </div>

          <!-- Organization Field -->
          <div>
            <label for="organization" style="display:block;font-size:13px;font-weight:700;color:var(--outline);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.05em;">
              Organization / Company
            </label>
            <input 
              type="text" 
              id="organization" 
              name="organization"
              style="width:100%;padding:10px 14px;background:var(--surface-container);border:1px solid var(--outline-variant);border-radius:4px;color:var(--on-surface);font-size:14px;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='var(--primary)'"
              onblur="this.style.borderColor='var(--outline-variant)'"
              placeholder="Your organization"
            />
          </div>

          <!-- Subject Field -->
          <div>
            <label for="subject" style="display:block;font-size:13px;font-weight:700;color:var(--outline);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.05em;">
              Subject
            </label>
            <div style="position:relative;">
              <select 
                id="subject" 
                name="subject"
                style="width:100%;padding:10px 14px;background:var(--surface-container);border:1px solid var(--outline-variant);border-radius:4px;color:var(--on-surface);font-size:14px;outline:none;appearance:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='var(--primary)'"
                onblur="this.style.borderColor='var(--outline-variant)'"
              >
                <option value="" style="background:var(--surface-container);">Select a subject</option>
                <option value="support" style="background:var(--surface-container);">Technical Support</option>
                <option value="feedback" style="background:var(--surface-container);">Feedback</option>
                <option value="partnership" style="background:var(--surface-container);">Partnership Inquiry</option>
                <option value="bug" style="background:var(--surface-container);">Report a Bug</option>
                <option value="other" style="background:var(--surface-container);">Other</option>
              </select>
              <span class="material-symbols-outlined" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);color:var(--outline);font-size:20px;pointer-events:none;">expand_more</span>
            </div>
          </div>

          <!-- Message Field -->
          <div>
            <label for="message" style="display:block;font-size:13px;font-weight:700;color:var(--outline);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.05em;">
              Message
            </label>
            <textarea 
              id="message" 
              name="message"
              rows={6}
              required
              style="width:100%;padding:10px 14px;background:var(--surface-container);border:1px solid var(--outline-variant);border-radius:4px;color:var(--on-surface);font-size:14px;outline:none;resize:none;font-family:inherit;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='var(--primary)'"
              onblur="this.style.borderColor='var(--outline-variant)'"
              placeholder="Tell us how we can help..."
            />
          </div>

          <!-- Checkbox -->
          <div style="display:flex;align-items:flex-start;gap:10px;">
            <input 
              type="checkbox" 
              id="consent" 
              name="consent"
              style="margin-top:3px;cursor:pointer;"
            />
            <label for="consent" style="font-size:13px;color:var(--outline);cursor:pointer;">
              I agree to be contacted about my inquiry and accept the privacy policy
            </label>
          </div>

          <!-- Submit Button -->
          <div style="margin-top:10px;">
            <button 
              type="submit"
              style="width:100%;padding:12px;background:#adc6ff;color:#002e6a;border:none;border-radius:4px;font-weight:700;font-size:14px;cursor:pointer;transition:filter 0.15s;"
              onmouseover="this.style.filter='brightness(1.1)'"
              onmouseout="this.style.filter='brightness(1)'"
            >
              Send Message
            </button>
          </div>
        </form>

        <!-- Note -->
        <p style="font-size:11px;color:#8c909f;margin:16px 0 0;text-align:center;">
          We'll get back to you within 24-48 business hours. Thank you for reaching out!
        </p>
      </div>

      <!-- FAQ Section -->
      <div style="background:rgba(173,198,255,0.04);border:1px solid #424754;border-radius:6px;padding:32px;">
        <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:800;font-size:22px;color:#d4e4fa;margin:0 0 24px;">Frequently Asked Questions</h2>
        
        <div style="display:flex;flex-direction:column;gap:24px;">
          <div>
            <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#adc6ff;margin:0 0 8px;">How often is the tender data updated?</h3>
            <p style="font-size:14px;color:#8c909f;margin:0;line-height:1.5;">Our system updates tender data daily from both the GeM and CSPGCL portals, ensuring you always have the latest information.</p>
          </div>
          
          <div>
            <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#adc6ff;margin:0 0 8px;">Is my data secure?</h3>
            <p style="font-size:14px;color:#8c909f;margin:0;line-height:1.5;">Yes, we implement enterprise-grade security measures. Please review our Privacy Policy for detailed information.</p>
          </div>
          
          <div>
            <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#adc6ff;margin:0 0 8px;">How can I get technical support?</h3>
            <p style="font-size:14px;color:#8c909f;margin:0;line-height:1.5;">You can reach our support team via email. We also have a help center with comprehensive documentation.</p>
          </div>
          
          <div>
            <h3 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:16px;color:#adc6ff;margin:0 0 8px;">Can I export tender data?</h3>
            <p style="font-size:14px;color:#8c909f;margin:0;line-height:1.5;">Yes, you can export tender data in various formats. Contact support for export options and guidelines.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</TenderLayout>
