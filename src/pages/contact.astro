---
import TenderLayout from '../layouts/TenderLayout.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

const title = 'Contact Us | CGTenders.com';
const description = 'Get in touch with our team. We are here to help with any questions or support you may need.';
---

<TenderLayout {title} {description}>
  <Navbar />
  <div class="max-w-7xl mx-auto px-3 sm:px-4 md:px-6 lg:px-8 py-8 md:py-12">
    <div class="max-w-3xl mx-auto">
      <!-- Header -->
      <div class="mb-12">
        <a href="/tenders" class="inline-flex items-center gap-2 text-[#1A56DB] hover:text-blue-700 mb-4 transition">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 19l-7-7 7-7" />
          </svg>
          Back to Dashboard
        </a>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">Contact Us</h1>
        <p class="text-gray-600">We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-12">
        <!-- Contact Info Cards -->
        <div class="bg-white rounded-lg border border-gray-100 p-6 shadow-sm">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#1A56DB]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Email</h3>
          <p class="text-sm text-gray-600 mb-3">For general inquiries</p>
          <a href="mailto:info@cspgcl-tender.com" class="text-[#1A56DB] hover:text-blue-700 font-medium text-sm transition">
            info@cspgcl-tender.com
          </a>
        </div>

        <div class="bg-white rounded-lg border border-gray-100 p-6 shadow-sm">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#057A55]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Support</h3>
          <p class="text-sm text-gray-600 mb-3">Technical support available</p>
          <a href="tel:+91-XXXX-XXXX-XXXX" class="text-[#057A55] hover:text-green-700 font-medium text-sm transition">
            +91-XXXX-XXXX-XXXX
          </a>
        </div>

        <div class="bg-white rounded-lg border border-gray-100 p-6 shadow-sm">
          <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C27803]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Location</h3>
          <p class="text-sm text-gray-600">
            CGTenders Head Office<br/>
            Central India
          </p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-lg border border-gray-100 p-6 md:p-8 shadow-sm mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Send us a Message</h2>
        
        <form class="space-y-5">
          <!-- Name Field -->
          <div>
            <label htmlFor="name" class="block text-sm font-medium text-gray-900 mb-2">
              Full Name
            </label>
            <input 
              type="text" 
              id="name" 
              name="name"
              required
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:border-[#1A56DB] focus:ring-1 focus:ring-[#1A56DB] outline-none transition text-gray-900"
              placeholder="Your full name"
            />
          </div>

          <!-- Email Field -->
          <div>
            <label htmlFor="email" class="block text-sm font-medium text-gray-900 mb-2">
              Email Address
            </label>
            <input 
              type="email" 
              id="email" 
              name="email"
              required
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:border-[#1A56DB] focus:ring-1 focus:ring-[#1A56DB] outline-none transition text-gray-900"
              placeholder="your.email@company.com"
            />
          </div>

          <!-- Organization Field -->
          <div>
            <label htmlFor="organization" class="block text-sm font-medium text-gray-900 mb-2">
              Organization / Company
            </label>
            <input 
              type="text" 
              id="organization" 
              name="organization"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:border-[#1A56DB] focus:ring-1 focus:ring-[#1A56DB] outline-none transition text-gray-900"
              placeholder="Your organization"
            />
          </div>

          <!-- Subject Field -->
          <div>
            <label htmlFor="subject" class="block text-sm font-medium text-gray-900 mb-2">
              Subject
            </label>
            <select 
              id="subject" 
              name="subject"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:border-[#1A56DB] focus:ring-1 focus:ring-[#1A56DB] outline-none transition text-gray-900"
            >
              <option value="">Select a subject</option>
              <option value="support">Technical Support</option>
              <option value="feedback">Feedback</option>
              <option value="partnership">Partnership Inquiry</option>
              <option value="bug">Report a Bug</option>
              <option value="other">Other</option>
            </select>
          </div>

          <!-- Message Field -->
          <div>
            <label htmlFor="message" class="block text-sm font-medium text-gray-900 mb-2">
              Message
            </label>
            <textarea 
              id="message" 
              name="message"
              rows={6}
              required
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:border-[#1A56DB] focus:ring-1 focus:ring-[#1A56DB] outline-none transition text-gray-900 resize-none"
              placeholder="Tell us how we can help..."
            />
          </div>

          <!-- Checkbox -->
          <div class="flex items-start">
            <input 
              type="checkbox" 
              id="consent" 
              name="consent"
              class="mt-1 rounded border-gray-300 text-[#1A56DB] focus:ring-[#1A56DB]"
            />
            <label htmlFor="consent" class="ml-3 text-sm text-gray-600">
              I agree to be contacted about my inquiry and accept the privacy policy
            </label>
          </div>

          <!-- Submit Button -->
          <div class="pt-4">
            <button 
              type="submit"
              class="w-full bg-[#1A56DB] text-white font-medium py-3 rounded-lg hover:bg-blue-700 transition focus:outline-none focus:ring-2 focus:ring-[#1A56DB] focus:ring-offset-2"
            >
              Send Message
            </button>
          </div>
        </form>

        <!-- Note -->
        <p class="text-xs text-gray-500 mt-4 text-center">
          We'll get back to you within 24-48 business hours. Thank you for reaching out!
        </p>
      </div>

      <!-- FAQ Section -->
      <div class="bg-blue-50 border border-blue-100 rounded-lg p-6 md:p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
        
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">How often is the tender data updated?</h3>
            <p class="text-sm text-gray-700">Our system updates tender data in real-time from the CGTenders portal, ensuring you always have the latest information.</p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">Is my data secure?</h3>
            <p class="text-sm text-gray-700">Yes, we implement enterprise-grade security measures. Please review our Privacy Policy for detailed information.</p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">How can I get technical support?</h3>
            <p class="text-sm text-gray-700">You can reach our support team via email or phone. We also have a help center with comprehensive documentation.</p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">Can I export tender data?</h3>
            <p class="text-sm text-gray-700">Yes, you can export tender data in various formats. Contact support for export options and guidelines.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</TenderLayout>
