---
import TenderLayout from '../layouts/TenderLayout.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

const title = 'Terms & Conditions | CGTenders.com';
const description = 'Terms and Conditions for CGTenders Tender Intelligence Dashboard.';
---

<TenderLayout {title} {description}>
  <Navbar />
  <div style="max-width:1200px;margin:0 auto;padding:48px 32px 64px;color:#c2c6d6;font-family:'Inter',sans-serif;">
    <div style="max-width:800px;margin:0 auto;">
      <!-- Header -->
      <div style="margin-bottom:36px;">
        <a href="/" style="display:inline-flex;align-items:center;gap:8px;color:#adc6ff;text-decoration:none;font-size:14px;font-weight:600;transition:color 0.15s;" onmouseover="this.style.color='#d8e2ff'" onmouseout="this.style.color='#adc6ff'">
          <svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Dashboard
        </a>
        <h1 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:800;font-size:36px;color:#d4e4fa;margin:16px 0 6px;letter-spacing:-0.02em;">Terms &amp; Conditions</h1>
        <p style="font-size:15px;color:#8c909f;margin:0;">Last updated: June 2026</p>
      </div>

      <!-- Content -->
      <div style="line-height:1.6;font-size:15px;display:flex;flex-direction:column;gap:32px;">

        <div style="background:rgba(173,198,255,0.06);border:1px solid rgba(173,198,255,0.18);border-radius:6px;padding:24px;">
          <p style="font-size:14px;color:#adc6ff;margin:0;">
            By accessing or using CGTenders.com, you agree to be bound by these Terms &amp; Conditions. Please read them carefully before using the service.
          </p>
        </div>

        <section>
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:22px;color:#d4e4fa;margin:0 0 16px;border-bottom:1px solid #424754;padding-bottom:8px;">1. Acceptance of Terms</h2>
          <p style="margin:0;">
            These Terms &amp; Conditions govern your use of CGTenders.com ("the Service"). By accessing the Service, you confirm that you have read, understood, and agree to be bound by these terms. If you do not agree, please discontinue use immediately.
          </p>
        </section>

        <section>
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:22px;color:#d4e4fa;margin:0 0 16px;border-bottom:1px solid #424754;padding-bottom:8px;">2. Nature of the Service</h2>
          <p style="margin:0 0 12px;">
            CGTenders.com is an independent analytics tool that aggregates and presents publicly available tender information from the CGTenders portal. We are not affiliated with, endorsed by, or officially connected to Chhattisgarh State Power Generation Company Limited (CGTenders).
          </p>
          <p style="margin:0;">
            All tender data is sourced from publicly accessible government portals. The analysis and risk assessments are generated algorithmically and are provided for informational purposes only.
          </p>
        </section>

        <section>
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:22px;color:#d4e4fa;margin:0 0 16px;border-bottom:1px solid #424754;padding-bottom:8px;">3. Disclaimer of Warranties</h2>
          <p style="margin:0 0 12px;">
            The Service is provided on an "as is" and "as available" basis without any warranties of any kind, either express or implied, including but not limited to warranties of merchantability, fitness for a particular purpose, or non-infringement.
          </p>
          <p style="margin:0;">
            We do not warrant that the information presented is complete, accurate, up-to-date, or free from errors. Tender data may be delayed or unavailable due to changes on the source portal. Always verify critical information directly on the official portals before making bidding decisions.
          </p>
        </section>

        <section>
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:22px;color:#d4e4fa;margin:0 0 16px;border-bottom:1px solid #424754;padding-bottom:8px;">4. Limitation of Liability</h2>
          <p style="margin:0;">
            To the fullest extent permitted by law, CGTenders.com and its operators shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising from your use of the Service, including but not limited to: missed tender deadlines, incorrect financial assessments, loss of business opportunity, or reliance on inaccurate data.
          </p>
        </section>

        <section>
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:22px;color:#d4e4fa;margin:0 0 16px;border-bottom:1px solid #424754;padding-bottom:8px;">5. Permitted Use</h2>
          <p style="margin:0 0 12px;">You may use this Service for lawful purposes only. You agree not to:</p>
          <ul style="list-style-type:disc;padding-left:20px;margin:0;display:flex;flex-direction:column;gap:8px;">
            <li>Attempt to scrape, copy, or redistribute the Service's content at scale</li>
            <li>Use automated tools to overload or disrupt the Service</li>
            <li>Misrepresent data from this Service as official government portal communications</li>
            <li>Use the Service for any unlawful or fraudulent purpose</li>
          </ul>
        </section>

        <section>
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:22px;color:#d4e4fa;margin:0 0 16px;border-bottom:1px solid #424754;padding-bottom:8px;">6. Intellectual Property</h2>
          <p style="margin:0;">
            The design, code, and analytical frameworks of this dashboard are proprietary. Tender data itself is sourced from public government records and remains the property of the respective government bodies. You may not reproduce or distribute our analytical outputs without written permission.
          </p>
        </section>

        <section>
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:22px;color:#d4e4fa;margin:0 0 16px;border-bottom:1px solid #424754;padding-bottom:8px;">7. Changes to Terms</h2>
          <p style="margin:0;">
            We reserve the right to update these Terms &amp; Conditions at any time. Continued use of the Service after any changes constitutes acceptance of the revised terms. We encourage you to review this page periodically.
          </p>
        </section>

        <section>
          <h2 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:700;font-size:22px;color:#d4e4fa;margin:0 0 16px;border-bottom:1px solid #424754;padding-bottom:8px;">8. Contact</h2>
          <p style="margin:0;">
            For questions regarding these Terms &amp; Conditions, please visit our <a href="/contact" style="color:#adc6ff;text-decoration:none;font-weight:600;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">Contact page</a>.
          </p>
        </section>

      </div>
    </div>
  </div>
  <Footer />
</TenderLayout>
