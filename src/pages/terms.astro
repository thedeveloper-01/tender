---
import TenderLayout from '../layouts/TenderLayout.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

const title = 'Terms & Conditions | CGTenders.com';
const description = 'Terms and Conditions for CGTenders Tender Intelligence Dashboard.';
---

<TenderLayout {title} {description}>
  <Navbar />
  <div class="max-w-7xl mx-auto px-3 sm:px-4 md:px-6 lg:px-8 py-8 md:py-12">
    <div class="max-w-3xl mx-auto">
      <!-- Header -->
      <div class="mb-8">
        <a href="/" class="inline-flex items-center gap-2 text-[#1A56DB] hover:text-blue-700 mb-4 transition">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M15 19l-7-7 7-7" />
          </svg>
          Back to Dashboard
        </a>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">Terms &amp; Conditions</h1>
        <p class="text-gray-600">Last updated: June 2026</p>
      </div>

      <!-- Content -->
      <div class="prose prose-sm md:prose max-w-none space-y-8">

        <div class="bg-blue-50 border border-blue-100 rounded-lg p-4 md:p-6">
          <p class="text-sm text-gray-700">
            By accessing or using the CGTenders.com, you agree to be bound by these Terms &amp; Conditions. Please read them carefully before using the service.
          </p>
        </div>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">1. Acceptance of Terms</h2>
          <p class="text-gray-700">
            These Terms &amp; Conditions govern your use of the CGTenders.com ("the Service"). By accessing the Service, you confirm that you have read, understood, and agree to be bound by these terms. If you do not agree, please discontinue use immediately.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">2. Nature of the Service</h2>
          <p class="text-gray-700 mb-3">
            The CGTenders.com is an independent analytics tool that aggregates and presents publicly available tender information from the CGTenders portal. We are not affiliated with, endorsed by, or officially connected to Chhattisgarh State Power Generation Company Limited (CGTenders).
          </p>
          <p class="text-gray-700">
            All tender data is sourced from publicly accessible government portals. The analysis and risk assessments are generated algorithmically and are provided for informational purposes only.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">3. Disclaimer of Warranties</h2>
          <p class="text-gray-700 mb-3">
            The Service is provided on an "as is" and "as available" basis without any warranties of any kind, either express or implied, including but not limited to warranties of merchantability, fitness for a particular purpose, or non-infringement.
          </p>
          <p class="text-gray-700">
            We do not warrant that the information presented is complete, accurate, up-to-date, or free from errors. Tender data may be delayed or unavailable due to changes on the source portal. Always verify critical information directly on the official CGTenders portal before making bidding decisions.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">4. Limitation of Liability</h2>
          <p class="text-gray-700">
            To the fullest extent permitted by law, CGTenders.com and its operators shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising from your use of the Service, including but not limited to: missed tender deadlines, incorrect financial assessments, loss of business opportunity, or reliance on inaccurate data.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">5. Permitted Use</h2>
          <p class="text-gray-700 mb-3">You may use this Service for lawful purposes only. You agree not to:</p>
          <ul class="list-disc pl-6 text-gray-700 space-y-2">
            <li>Attempt to scrape, copy, or redistribute the Service's content at scale</li>
            <li>Use automated tools to overload or disrupt the Service</li>
            <li>Misrepresent data from this Service as official CGTenders communications</li>
            <li>Use the Service for any unlawful or fraudulent purpose</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">6. Intellectual Property</h2>
          <p class="text-gray-700">
            The design, code, and analytical frameworks of this dashboard are proprietary. Tender data itself is sourced from public government records and remains the property of the respective government bodies. You may not reproduce or distribute our analytical outputs without written permission.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">7. Changes to Terms</h2>
          <p class="text-gray-700">
            We reserve the right to update these Terms &amp; Conditions at any time. Continued use of the Service after any changes constitutes acceptance of the revised terms. We encourage you to review this page periodically.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">8. Contact</h2>
          <p class="text-gray-700">
            For questions regarding these Terms &amp; Conditions, please visit our <a href="/contact" class="text-[#1A56DB] hover:underline">Contact page</a>.
          </p>
        </section>

      </div>
    </div>
  </div>
  <Footer />
</TenderLayout>
