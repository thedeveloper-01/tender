---
import TenderLayout from '../layouts/TenderLayout.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

const title = '500 — Server Error | CGTenders.com';

// Astro passes the error in SSR mode
const { error } = Astro.props as { error?: Error };
---

<TenderLayout title={title}>
  <Navbar />
  <div class="min-h-screen flex flex-col">
    <main class="flex-1 flex items-center justify-center px-4 py-16">
      <div class="max-w-lg w-full text-center">

        <!-- Illustration -->
        <div class="relative mx-auto mb-8 w-48 h-48">
          <!-- Outer ring — red tint for error -->
          <div class="absolute inset-0 rounded-full bg-red-50 border-2 border-red-100"></div>
          <!-- Pulsing warning ring -->
          <div class="absolute inset-2 rounded-full border-2 border-red-200 opacity-60 animate-ping" style="animation-duration: 2.5s;"></div>
          <!-- Inner content -->
          <div class="absolute inset-4 rounded-full bg-white shadow-inner flex flex-col items-center justify-center">
            <svg class="w-10 h-10 text-[#E02424] mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span class="text-2xl font-black text-[#E02424] leading-none font-['Outfit']">500</span>
          </div>
          <!-- Decorative dots -->
          <div class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-[#E02424] opacity-30"></div>
          <div class="absolute -bottom-2 left-6 w-3 h-3 rounded-full bg-[#C27803] opacity-40"></div>
          <div class="absolute top-6 -left-2 w-2.5 h-2.5 rounded-full bg-red-300 opacity-50"></div>
        </div>

        <!-- Text -->
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3 font-['Outfit']">
          Something went wrong
        </h1>
        <p class="text-gray-500 mb-6 leading-relaxed max-w-sm mx-auto">
          The server ran into an unexpected problem. This is usually temporary — try refreshing the page or come back in a moment.
        </p>

        <!-- Error detail (only in dev / if error is passed) -->
        {error && (
          <div class="mb-6 text-left bg-red-50 border border-red-200 rounded-lg px-4 py-3 max-w-sm mx-auto">
            <p class="text-xs font-semibold text-red-700 uppercase tracking-wider mb-1">Error detail</p>
            <p class="text-xs text-red-600 font-mono break-all">{error.message}</p>
          </div>
        )}

        <!-- CGTenders-specific hint since timeout is the most likely cause -->
        <div class="mb-8 bg-amber-50 border border-amber-100 rounded-lg px-4 py-3 max-w-sm mx-auto text-left">
          <div class="flex gap-2">
            <svg class="w-4 h-4 text-[#C27803] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-xs text-amber-800 leading-relaxed">
              If this error occurred while loading tenders, the <strong>CSPGCL portal</strong> or backend API may be temporarily slow or unavailable. Try again in a few minutes.
            </p>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <button
            onclick="location.reload()"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#E02424] text-white font-semibold rounded-lg hover:bg-red-700 transition shadow-sm"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            Retry
          </button>
          <a
            href="/"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white border border-gray-200 text-gray-700 font-semibold rounded-lg hover:bg-gray-50 transition shadow-sm"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Go to Dashboard
          </a>
        </div>

        <!-- Status check link -->
        <p class="mt-8 text-xs text-gray-400">
          If the problem persists, please
          <a href="/contact" class="text-[#1A56DB] hover:underline">contact us</a>.
        </p>

      </div>
    </main>
    <Footer />
  </div>
</TenderLayout>
