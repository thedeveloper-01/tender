---
import TenderLayout from "../layouts/TenderLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import TenderDashboard from "../components/TenderDashboard.jsx";
import TenderCard from "../components/TenderCard.astro";
import { fetchStatsCached, fetchTendersCached } from '../lib/api.js';

let stats: { totalOpenTenders: number; totalEstimatedValue: number; bySource: Record<string, number>; lastFetchAt: string | null } = { totalOpenTenders: 0, totalEstimatedValue: 0, bySource: {}, lastFetchAt: null };
let initialTenders = null;
let initialTotal = 0;

try {
  const [statsData, tendersData] = await Promise.all([
    fetchStatsCached(Astro.locals),
    fetchTendersCached({ status: 'open', source: 'GEM', limit: 100 }, Astro.locals)
  ]);
  stats = statsData;
  initialTenders = tendersData.tenders || [];
  initialTotal = tendersData.total || 0;
} catch (e: any) {
  console.error('[tenders-gem] SSR fetch error:', e.message);
}

const lastUpdated = stats.lastFetchAt
  ? new Date(stats.lastFetchAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })
  : null;

const gemCount = stats.bySource?.GEM || initialTotal || 0;

const year = new Date().getFullYear();
const metaTitle = `GeM Tenders Chhattisgarh ${year} - Live Open Bids & eProcurement | CGTenders.com`;
const metaDesc = `Browse ${gemCount} open GeM (Government e-Marketplace) tenders in Chhattisgarh ${year}. Filter by district, category, EMD & closing date. CG GeM bid notices updated daily.`;

// Issue #7 — BreadcrumbList JSON-LD
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cgtenders.com/' },
    { '@type': 'ListItem', position: 2, name: 'GeM Tenders', item: 'https://cgtenders.com/gem' },
  ],
};

// SSR tender list (first 20 for Googlebot)
const ssrTenders = (initialTenders || []).slice(0, 20);
---

<TenderLayout
  title={metaTitle}
  description={metaDesc}
  canonical="/gem"
  jsonLd={breadcrumbLd}
>
  <Navbar />
  <main>
    <!-- Issue #8 — HTML Breadcrumb -->
    <nav aria-label="Breadcrumb" style="max-width:1440px;margin:0 auto;padding:12px 32px 0;">
      <ol style="display:flex;align-items:center;gap:6px;list-style:none;margin:0;padding:0;font-size:12px;color:var(--on-surface-variant);">
        <li><a href="/" style="color:var(--on-surface-variant);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--on-surface-variant)'">Home</a></li>
        <li aria-hidden="true" style="color:var(--outline-variant);">›</li>
        <li style="color:var(--outline);font-weight:600;">GeM Tenders</li>
      </ol>
    </nav>

    <div style="background:var(--surface-dim);border-bottom:1px solid var(--outline-variant);">
      <div style="max-width:1440px;margin:0 auto;padding:20px 32px 18px;">
        <div style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:16px;">
          <div>
            <h1 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:800;font-size:28px;color:var(--on-surface);margin:0 0 4px;letter-spacing:-0.02em;">GeM Tenders</h1>
            <p style="font-size:13px;color:var(--outline);margin:0;">
              Government e-Marketplace open tenders in Chhattisgarh{lastUpdated && ` · Updated {lastUpdated}`}
            </p>
          </div>
          <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:10px;background:color-mix(in srgb, var(--primary) 8%, transparent);border:1px solid color-mix(in srgb, var(--primary) 18%, transparent);border-radius:6px;padding:10px 16px;">
              <span style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:800;font-size:22px;color:var(--primary);line-height:1;">{gemCount}</span>
              <span style="font-size:11px;color:var(--on-surface-variant);font-weight:600;line-height:1.3;">GeM Tenders<br/>Open</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- SSR tender list — rendered in HTML for Googlebot to index; hidden visually since the interactive dashboard shows the same data -->
    {ssrTenders.length > 0 && (
      <section id="ssr-gem-list" aria-hidden="true" style="display:none;">
        {ssrTenders.map((t: any) => (
          <TenderCard tender={t} />
        ))}
      </section>
    )}

    <!-- JS-hydrated dashboard -->
    <TenderDashboard 
      client:load 
      initialSource="GEM" 
      initialTenders={initialTenders} 
      initialTotal={initialTotal} 
    />
  </main>
  <Footer />
</TenderLayout>
