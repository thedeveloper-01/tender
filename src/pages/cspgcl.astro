---
import TenderLayout from '../layouts/TenderLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import TenderDashboard from '../components/TenderDashboard.jsx';
import TenderCard from '../components/TenderCard.astro';
import { fetchStatsCached, fetchTendersCached } from '../lib/api.js';

let stats: { totalOpenTenders: number; totalEstimatedValue: number; bySource: Record<string, number>; lastFetchAt: string | null } = { totalOpenTenders: 0, totalEstimatedValue: 0, bySource: {}, lastFetchAt: null };
let initialTenders = null;
let initialTotal = 0;

try {
  const [statsData, tendersData] = await Promise.all([
    fetchStatsCached(Astro.locals),
    fetchTendersCached({ status: 'open', source: 'CSPGCL', limit: 100 }, Astro.locals)
  ]);
  stats = statsData;
  initialTenders = tendersData.tenders || [];
  initialTotal = tendersData.total || 0;
} catch (e: any) {
  console.error('[tenders-cspgcl] SSR fetch error:', e.message);
}

const lastUpdated = stats.lastFetchAt
  ? new Date(stats.lastFetchAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })
  : null;

const cspgclCount = stats.bySource?.CSPGCL || initialTotal || 0;

// Issue #6 — keyword-rich meta
const year = new Date().getFullYear();
const metaTitle = `CSPGCL Tenders Chhattisgarh ${year} - Power Sector Open Procurement | CGTenders.com`;
const metaDesc = `Browse ${cspgclCount} open CSPGCL tender notices in Chhattisgarh ${year}. Power sector, infrastructure & supply bids. Filter by plant, district & closing date. Updated daily.`;

// Issue #7 — BreadcrumbList JSON-LD
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cgtenders.com/' },
    { '@type': 'ListItem', position: 2, name: 'CSPGCL Tenders', item: 'https://cgtenders.com/cspgcl' },
  ],
};

// SSR tender list (first 20 for Googlebot)
const ssrTenders = (initialTenders || []).slice(0, 20);
---

<TenderLayout
  title={metaTitle}
  description={metaDesc}
  canonical="/cspgcl"
  jsonLd={breadcrumbLd}
>
  <Navbar />
  <main>
    <!-- Issue #8 — HTML Breadcrumb -->
    <nav class="container-pad" aria-label="Breadcrumb" style="max-width:1440px;margin:0 auto;padding-top:12px;">
      <ol style="display:flex;align-items:center;gap:6px;list-style:none;margin:0;padding:0;font-size:12px;color:var(--on-surface-variant);">
        <li><a href="/" style="color:var(--on-surface-variant);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--on-surface-variant)'">Home</a></li>
        <li aria-hidden="true" style="color:var(--outline-variant);">›</li>
        <li style="color:var(--outline);font-weight:600;">CSPGCL Tenders</li>
      </ol>
    </nav>

    <div style="background:var(--surface-dim);border-bottom:1px solid var(--outline-variant);">
      <div class="container-pad" style="max-width:1440px;margin:0 auto;padding-top:20px;padding-bottom:18px;">
        <div style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:16px;">
          <div>
            <h1 style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:800;font-size:28px;color:var(--on-surface);margin:0 0 4px;letter-spacing:-0.02em;">CSPGCL Tenders</h1>
            <p style="font-size:13px;color:var(--outline);margin:0;">
              Chhattisgarh State Power Generation Company open tenders{lastUpdated && ` · Updated {lastUpdated}`}
            </p>
          </div>
          <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:10px;background:color-mix(in srgb, var(--tertiary) 7%, transparent);border:1px solid color-mix(in srgb, var(--tertiary) 18%, transparent);border-radius:6px;padding:10px 16px;">
              <span style="font-family:'Hanken Grotesk','Inter',sans-serif;font-weight:800;font-size:22px;color:var(--tertiary);line-height:1;">{cspgclCount}</span>
              <span style="font-size:11px;color:var(--on-surface-variant);font-weight:600;line-height:1.3;">CSPGCL Tenders<br/>Open</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- SSR tender list — rendered in HTML for Googlebot to index; hidden visually since the interactive dashboard shows the same data -->
    {ssrTenders.length > 0 && (
      <section id="ssr-cspgcl-list" aria-hidden="true" style="display:none;">
        {ssrTenders.map((t: any) => (
          <TenderCard tender={t} />
        ))}
      </section>
    )}

    <!-- JS-hydrated dashboard -->
    <TenderDashboard 
      client:load 
      initialSource="CSPGCL" 
      initialTenders={initialTenders} 
      initialTotal={initialTotal} 
    />
  </main>
  <Footer />
</TenderLayout>
