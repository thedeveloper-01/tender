---
import TenderLayout from '../layouts/TenderLayout.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

const title = '404 — Page Not Found | CGTenders.com';
---

<TenderLayout title={title}>
  <Navbar />
  <div class="min-h-screen flex flex-col">
    <main class="flex-1 flex items-center justify-center px-4 py-16">
      <div class="max-w-lg w-full text-center">

        <!-- Illustration -->
        <div class="relative mx-auto mb-8 w-48 h-48">
          <!-- Outer ring -->
          <div class="absolute inset-0 rounded-full bg-blue-50 border-2 border-blue-100 animate-pulse"></div>
          <!-- Inner content -->
          <div class="absolute inset-4 rounded-full bg-white shadow-inner flex flex-col items-center justify-center">
            <span class="text-5xl font-black text-[#1A56DB] leading-none font-['Outfit']">404</span>
            <span class="text-xs font-semibold text-gray-400 tracking-widest uppercase mt-1">Not Found</span>
          </div>
          <!-- Decorative dots -->
          <div class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-[#1A56DB] opacity-40"></div>
          <div class="absolute -bottom-2 left-6 w-3 h-3 rounded-full bg-[#C27803] opacity-50"></div>
          <div class="absolute top-6 -left-2 w-2.5 h-2.5 rounded-full bg-[#057A55] opacity-40"></div>
        </div>

        <!-- Text -->
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3 font-['Outfit']">
          This page doesn't exist
        </h1>
        <p class="text-gray-500 mb-8 leading-relaxed max-w-sm mx-auto">
          The page you're looking for may have been moved, deleted, or you may have typed the address incorrectly.
        </p>

        <!-- Actions -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#1A56DB] text-white font-semibold rounded-lg hover:bg-blue-700 transition shadow-sm"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Go to Dashboard
          </a>
          <button
            onclick="history.back()"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white border border-gray-200 text-gray-700 font-semibold rounded-lg hover:bg-gray-50 transition shadow-sm"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Go Back
          </button>
        </div>

        <!-- Quick links -->
        <div class="mt-12 pt-8 border-t border-gray-100">
          <p class="text-xs text-gray-400 uppercase font-semibold tracking-wider mb-4">Quick Links</p>
          <div class="flex flex-wrap justify-center gap-x-6 gap-y-2">
            <a href="/" class="text-sm text-[#1A56DB] hover:underline">Dashboard</a>
            <a href="/about" class="text-sm text-[#1A56DB] hover:underline">About</a>
            <a href="/contact" class="text-sm text-[#1A56DB] hover:underline">Contact</a>
            <a href="/privacy" class="text-sm text-[#1A56DB] hover:underline">Privacy</a>
            <a href="/terms" class="text-sm text-[#1A56DB] hover:underline">Terms</a>
          </div>
        </div>

      </div>
    </main>
    <Footer />
  </div>
</TenderLayout>
