---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  /** JSON-LD object(s). Pass an array to emit multiple <script type="application/ld+json"> blocks. */
  jsonLd?: object | object[];
  noindex?: boolean;
  /** og:type — defaults to "website". Pass "article" for tender detail pages. */
  ogType?: string;
  /** ISO 8601 string — used for article:published_time on detail pages */
  articlePublishedTime?: string;
  /** ISO 8601 string — used for article:modified_time on detail pages */
  articleModifiedTime?: string;
}

const {
  title = 'CGTenders.com — Chhattisgarh Government Tender Aggregator',
  description = 'Browse open government tenders from GeM and CSPGCL portals in Chhattisgarh — enriched with risk analysis and PDF-extracted details.',
  canonical,
  ogImage,
  jsonLd,
  noindex = false,
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
} = Astro.props;

const siteUrl = 'https://cgtenders.com';
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : `${siteUrl}${Astro.url.pathname}`;
const ogImg = ogImage || `${siteUrl}/og-default.png`;

// Normalise jsonLd to an array so we can emit multiple blocks
const jsonLdItems: object[] = jsonLd
  ? Array.isArray(jsonLd) ? jsonLd : [jsonLd]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="theme-color" content="#051424" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="CGTenders.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:locale" content="en_IN" />
    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === 'article' && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImg} />

    <!-- JSON-LD (one block per item) -->
    {jsonLdItems.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Fonts: Hanken Grotesk (display/headlines) + Inter (body) + JetBrains Mono (ids/numbers) + Material Symbols -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- DNS prefetch -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://cgtenders-com.onrender.com" />
    <link rel="preconnect" href="https://cgtenders-com.onrender.com" crossorigin />
    <link rel="preconnect" href="https://mkp.gem.gov.in" crossorigin />
    <link rel="dns-prefetch" href="https://mkp.gem.gov.in" />

    <!-- Always dark — no flash, no toggle -->
    <style>
      html { background: #051424; color: #d4e4fa; }
    </style>
  </head>
  <body style="background:#051424;color:#d4e4fa;min-height:100vh;">
    <slot />
  </body>
</html>
