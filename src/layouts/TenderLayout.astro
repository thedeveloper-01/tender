---
import '../styles/global.css';
import '../styles/tenders.css';

export interface Props {
  title?: string;
  description?: string;
  jsonLd?: string;
}

const {
  title = 'CGTenders.com | Chhattisgarh Government Tender Aggregator',
  description = 'Aggregate, search, and analyze open government tenders relevant to Chhattisgarh from GeM and CSPGCL with smart filters and AI-powered insights.',
  jsonLd,
} = Astro.props;

const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="CGTenders.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Google Fonts: Outfit (headings) + DM Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />

    <style>
      html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100%;
        font-family: 'DM Sans', system-ui, sans-serif;
        background: #F8F9FC;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: 'Outfit', system-ui, sans-serif;
      }

      *, *::before, *::after {
        box-sizing: border-box;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
