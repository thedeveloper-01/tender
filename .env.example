# Base URL of the CGTenders backend API (Express + Prisma on Railway)
PUBLIC_API_BASE_URL=http://localhost:4000

# Used for sitemap/canonical/JSON-LD URLs
SITE_URL=https://cgtenders.com

# Proxy URL for GeM scraping (required in production — GeM blocks cloud IPs).
# Uses undici ProxyAgent, so use standard proxy format:
#   HTTP:   http://user:pass@proxy-host:port
#   SOCKS5: socks5://user:pass@proxy-host:port
# Set USE_MOCK_GEM=false to enable live fetching.
PROXY_URL=
USE_MOCK_GEM=true
